    "changelog.0_4_1.profileGrid.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nastaven\u00ed profil\u016f zobrazuje v\u0161echny zapamatovan\u00e9 profily vedle sebe se zelenou zna\u010dkou na aktivn\u00edm."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profilindstillingerne viser hver husket profil side om side med et gr\u00f8nt m\u00e6rke p\u00e5 den aktive."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Profil-Einstellungen zeigen alle gespeicherten Profile nebeneinander, mit gr\u00fcnem Marker am aktiven."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u039f\u03b9 \u03c1\u03c5\u03b8\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03c0\u03c1\u03bf\u03c6\u03af\u03bb \u03b4\u03b5\u03af\u03c7\u03bd\u03bf\u03c5\u03bd \u03ba\u03ac\u03b8\u03b5 \u03b1\u03c0\u03bf\u03b8\u03b7\u03ba\u03b5\u03c5\u03bc\u03ad\u03bd\u03bf \u03c0\u03c1\u03bf\u03c6\u03af\u03bb \u03b4\u03af\u03c0\u03bb\u03b1-\u03b4\u03af\u03c0\u03bb\u03b1, \u03bc\u03b5 \u03c0\u03c1\u03ac\u03c3\u03b9\u03bd\u03bf \u03c3\u03b7\u03bc\u03ac\u03b4\u03b9 \u03c3\u03c4\u03bf \u03b5\u03bd\u03b5\u03c1\u03b3\u03cc."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profile settings shows every remembered profile side-by-side, with a green check on the active session."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los ajustes de perfil muestran cada perfil recordado lado a lado, con marca verde en la sesi\u00f3n activa."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profiiliasetukset n\u00e4ytt\u00e4\u00e4 kaikki muistetut profiilit rinnakkain ja vihre\u00e4ll\u00e4 merkill\u00e4 aktiivisen istunnon."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les r\u00e9glages de profil affichent chaque profil m\u00e9moris\u00e9 c\u00f4te \u00e0 c\u00f4te, avec une coche verte sur la session active."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Postavke profila prikazuju sve zapam\u0107ene profile jedan do drugog, sa zelenom oznakom na aktivnoj sesiji."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A profilbe\u00e1ll\u00edt\u00e1sok minden megjegyzett profilt egym\u00e1s mellett mutatnak, z\u00f6ld pip\u00e1val az akt\u00edv munkameneten."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le impostazioni profilo mostrano ogni profilo ricordato affiancato, con segno verde sulla sessione attiva."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u8a2d\u5b9a\u3067\u8a18\u61b6\u3055\u308c\u305f\u5168\u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u3092\u6a2a\u4e26\u3073\u306b\u8868\u793a\u3057\u3001\u30a2\u30af\u30c6\u30a3\u30d6\u306a\u30bb\u30c3\u30b7\u30e7\u30f3\u306b\u306f\u7dd1\u306e\u30c1\u30a7\u30c3\u30af\u3092\u4ed8\u3051\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\ud504\ub85c\ud544 \uc124\uc815\uc5d0\uc11c \uae30\uc5b5\ub41c \ubaa8\ub4e0 \ud504\ub85c\ud544\uc744 \ub098\ub780\ud788 \ud45c\uc2dc\ud558\uba70, \ud65c\uc131 \uc138\uc158\uc5d0 \ub179\uc0c9 \uccb4\ud06c \ud45c\uc2dc\ub97c \ud569\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profilinnstillingene viser hver husket profil side ved side, med gr\u00f8nt merke p\u00e5 den aktive \u00f8kten."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profielinstellingen tonen elk onthouden profiel naast elkaar, met een groen vinkje op de actieve sessie."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ustawienia profilu pokazuj\u0105 ka\u017cdy zapami\u0119tany profil obok siebie, z zielonym znacznikiem na aktywnej sesji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configura\u00e7\u00f5es de perfil mostram cada perfil lembrado lado a lado, com marca verde na sess\u00e3o ativa."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As defini\u00e7\u00f5es de perfil mostram cada perfil lembrado lado a lado, com marca verde na sess\u00e3o ativa."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set\u0103rile de profil afi\u0219eaz\u0103 fiecare profil memorat al\u0103turat, cu bif\u0103 verde pe sesiunea activ\u0103."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u043f\u0440\u043e\u0444\u0438\u043b\u044f \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u044e\u0442 \u0432\u0441\u0435 \u0441\u043e\u0445\u0440\u0430\u043d\u0451\u043d\u043d\u044b\u0435 \u043f\u0440\u043e\u0444\u0438\u043b\u0438 \u0432 \u043e\u0434\u043d\u043e\u0439 \u0441\u0435\u0442\u043a\u0435 \u0441 \u0437\u0435\u043b\u0451\u043d\u043e\u0439 \u043e\u0442\u043c\u0435\u0442\u043a\u043e\u0439 \u043d\u0430 \u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0439 \u0441\u0435\u0441\u0441\u0438\u0438."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nastavenia profilov zobrazuj\u00fa ka\u017ed\u00fd zapam\u00e4tan\u00fd profil ved\u013ea seba, so zelenou zna\u010dkou na akt\u00edvnej rel\u00e1cii."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profilinst\u00e4llningarna visar varje minns profil sida vid sida, med en gr\u00f6n bock p\u00e5 den aktiva sessionen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profil ayarlar\u0131, her hat\u0131rlanan profili yan yana ve aktif oturumda ye\u015fil bir i\u015faretle g\u00f6sterir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u043f\u0440\u043e\u0444\u0456\u043b\u044e \u043f\u043e\u043a\u0430\u0437\u0443\u044e\u0442\u044c \u043a\u043e\u0436\u0435\u043d \u0437\u0430\u043f\u0430\u043c'\u044f\u0442\u043e\u0432\u0430\u043d\u0438\u0439 \u043f\u0440\u043e\u0444\u0456\u043b\u044c \u043f\u043e\u0440\u044f\u0434, \u0456\u0437 \u0437\u0435\u043b\u0435\u043d\u043e\u044e \u043f\u043e\u0437\u043d\u0430\u0447\u043a\u043e\u044e \u043d\u0430 \u0430\u043a\u0442\u0438\u0432\u043d\u0456\u0439 \u0441\u0435\u0441\u0456\u0457."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u6863\u6848\u8bbe\u7f6e\u4e2d\u5c06\u6bcf\u4e2a\u8bb0\u4f4f\u7684\u6863\u6848\u5e76\u6392\u663e\u793a,\u5e76\u5728\u5f53\u524d\u4f1a\u8bdd\u4e0a\u52a0\u7eff\u8272\u5bf9\u52fe\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u6a94\u6848\u8a2d\u5b9a\u4e2d\u5c07\u6bcf\u500b\u8a18\u4f4f\u7684\u6a94\u6848\u4e26\u6392\u986f\u793a,\u4e26\u5728\u7576\u524d\u5de5\u4f5c\u968e\u6bb5\u4e0a\u52a0\u7da0\u8272\u52fe\u865f\u3002"
          }
        }
      }
    },

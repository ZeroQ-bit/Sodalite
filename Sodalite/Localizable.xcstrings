    "settings.about.tmdbAttribution" : {
      "comment" : "TMDB API attribution shown in the About / footer of Settings",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tato aplikace pou\u017e\u00edv\u00e1 rozhran\u00ed TMDB API, ale nen\u00ed podporov\u00e1na ani certifikov\u00e1na spole\u010dnost\u00ed TMDB."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Denne app bruger TMDB API'en, men er ikke godkendt eller certificeret af TMDB."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese App nutzt die TMDB API, ist jedoch nicht von TMDB unterst\u00fctzt oder zertifiziert."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0391\u03c5\u03c4\u03ae \u03b7 \u03b5\u03c6\u03b1\u03c1\u03bc\u03bf\u03b3\u03ae \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03b5\u03af \u03c4\u03bf TMDB API, \u03b1\u03bb\u03bb\u03ac \u03b4\u03b5\u03bd \u03c5\u03c0\u03bf\u03c3\u03c4\u03b7\u03c1\u03af\u03b6\u03b5\u03c4\u03b1\u03b9 \u03ae \u03c0\u03b9\u03c3\u03c4\u03bf\u03c0\u03bf\u03b9\u03b5\u03af\u03c4\u03b1\u03b9 \u03b1\u03c0\u03cc \u03c4\u03bf TMDB."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This product uses the TMDB API but is not endorsed or certified by TMDB."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este producto utiliza la API de TMDB pero no est\u00e1 respaldado ni certificado por TMDB."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "T\u00e4m\u00e4 tuote k\u00e4ytt\u00e4\u00e4 TMDB:n APIa, mutta TMDB ei tue tai sertifioi sit\u00e4."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce produit utilise l'API TMDB mais n'est ni approuv\u00e9 ni certifi\u00e9 par TMDB."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ovaj proizvod koristi TMDB API, ali ga TMDB ne podr\u017eava niti certificira."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ez a term\u00e9k a TMDB API-t haszn\u00e1lja, de azt a TMDB nem t\u00e1mogatja \u00e9s nem hiteles\u00edti."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo prodotto utilizza le API di TMDB ma non \u00e8 approvato o certificato da TMDB."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u3053\u306e\u30a2\u30d7\u30ea\u306f TMDB API \u3092\u4f7f\u7528\u3057\u3066\u3044\u307e\u3059\u304c\u3001TMDB \u306e\u627f\u8a8d\u3084\u8a8d\u5b9a\u3092\u53d7\u3051\u305f\u3082\u306e\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc774 \uc81c\ud488\uc740 TMDB API\ub97c \uc0ac\uc6a9\ud558\uc9c0\ub9cc TMDB\uc758 \uc2b9\uc778\uc774\ub098 \uc778\uc99d\uc744 \ubc1b\uc9c0 \uc54a\uc558\uc2b5\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette produktet bruker TMDB API, men er ikke godkjent eller sertifisert av TMDB."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit product gebruikt de TMDB API, maar wordt niet ondersteund of gecertificeerd door TMDB."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ten produkt korzysta z API TMDB, ale nie jest wspierany ani certyfikowany przez TMDB."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este produto usa a API do TMDB, mas n\u00e3o \u00e9 endossado ou certificado pelo TMDB."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este produto utiliza a API do TMDB, mas n\u00e3o \u00e9 avalizado nem certificado pelo TMDB."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acest produs utilizeaz\u0103 API-ul TMDB, dar nu este aprobat sau certificat de TMDB."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u042d\u0442\u043e\u0442 \u043f\u0440\u043e\u0434\u0443\u043a\u0442 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442 TMDB API, \u043d\u043e \u043d\u0435 \u043e\u0434\u043e\u0431\u0440\u0435\u043d \u0438 \u043d\u0435 \u0441\u0435\u0440\u0442\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d TMDB."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "T\u00e1to aplik\u00e1cia pou\u017e\u00edva rozhranie TMDB API, ale nie je podporovan\u00e1 ani certifikovan\u00e1 spolo\u010dnos\u0165ou TMDB."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den h\u00e4r produkten anv\u00e4nder TMDB API, men \u00e4r inte godk\u00e4nd eller certifierad av TMDB."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu \u00fcr\u00fcn TMDB API'sini kullan\u0131r ancak TMDB taraf\u0131ndan onaylanmam\u0131\u015f veya sertifikaland\u0131r\u0131lmam\u0131\u015ft\u0131r."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0426\u0435\u0439 \u043f\u0440\u043e\u0434\u0443\u043a\u0442 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454 TMDB API, \u0430\u043b\u0435 \u043d\u0435 \u0441\u0445\u0432\u0430\u043b\u0435\u043d\u0438\u0439 \u0456 \u043d\u0435 \u0441\u0435\u0440\u0442\u0438\u0444\u0456\u043a\u043e\u0432\u0430\u043d\u0438\u0439 TMDB."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u672c\u5e94\u7528\u4f7f\u7528 TMDB API\uff0c\u4f46\u672a\u83b7 TMDB \u7684\u8ba4\u53ef\u6216\u8ba4\u8bc1\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u672c\u61c9\u7528\u7a0b\u5f0f\u4f7f\u7528 TMDB API\uff0c\u4f46\u4e26\u672a\u7372\u5f97 TMDB \u7684\u8a8d\u53ef\u6216\u8a8d\u8b49\u3002"
          }
        }
      }

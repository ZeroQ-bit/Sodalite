        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri Remote, iPhone \ub610\ub294 HomePod\uc5d0 \u2018Sodalite \uc5f4\uae30\u2019\ub77c\uace0 \ub9d0\ud558\uc138\uc694. 26\uac1c \uc5b8\uc5b4 \uc9c0\uc6d0."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si \u201e\u00c5pne Sodalite\u201c til Siri-fjernkontrollen, iPhone eller HomePod. Tilgjengelig p\u00e5 26 spr\u00e5k."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeg \u2018Open Sodalite\u2019 tegen de Siri Remote, iPhone of HomePod. Beschikbaar in 26 talen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powiedz \u201eOtw\u00f3rz Sodalite\u201c do pilota Siri Remote, iPhone\u2019a lub HomePoda. Dost\u0119pne w 26 j\u0119zykach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diga \u201cAbrir Sodalite\u201d pelo Siri Remote, iPhone ou HomePod. Dispon\u00edvel em 26 idiomas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diz \u201cAbre o Sodalite\u201d ao Siri Remote, iPhone ou HomePod. Dispon\u00edvel em 26 idiomas."

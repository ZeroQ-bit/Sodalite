    "changelog.0_4_1.atmosLabel.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos zvukov\u00e9 stopy se v rozbalovac\u00ed nab\u00eddce zobrazuj\u00ed jako \u201eDolby Atmos\u201c m\u00edsto pouh\u00e9ho po\u010dtu kan\u00e1l\u016f."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos-lydspor vises nu som \"Dolby Atmos\" i menuen i stedet for blot kanalantallet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos-Tonspuren werden im Audio-Men\u00fc als \u201eDolby Atmos\" angezeigt statt nur als Kanalanzahl."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a4\u03b1 \u03ba\u03bf\u03bc\u03bc\u03ac\u03c4\u03b9\u03b1 \u03ae\u03c7\u03bf\u03c5 Atmos \u03b5\u03bc\u03c6\u03b1\u03bd\u03af\u03b6\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c0\u03bb\u03ad\u03bf\u03bd \u03c9\u03c2 \u00abDolby Atmos\u00bb \u03c3\u03c4\u03bf \u03bc\u03b5\u03bd\u03bf\u03cd \u03b1\u03bd\u03c4\u03af \u03b3\u03b9\u03b1 \u03c4\u03bf\u03bd \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc \u03ba\u03b1\u03bd\u03b1\u03bb\u03b9\u03ce\u03bd."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos audio tracks read \"Dolby Atmos\" in the dropdown instead of just the channel count."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las pistas Atmos aparecen como \u00abDolby Atmos\u00bb en el men\u00fa en lugar de solo el n\u00famero de canales."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos-\u00e4\u00e4niraidat n\u00e4kyv\u00e4t valikossa nimell\u00e4 \"Dolby Atmos\" pelk\u00e4n kanavam\u00e4\u00e4r\u00e4n sijaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les pistes audio Atmos affichent \u00ab Dolby Atmos \u00bb dans le menu plut\u00f4t que leur nombre de canaux."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos audio zapisi sada se prikazuju kao \u201eDolby Atmos\u201c umjesto samo broja kanala."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az Atmos hangs\u00e1vok \u201eDolby Atmos\u201c n\u00e9ven jelennek meg a men\u00fcben, nem csak a csatornasz\u00e1mmal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le tracce Atmos appaiono come \u00abDolby Atmos\u00bb nel men\u00f9 invece del solo conteggio canali."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos\u30aa\u30fc\u30c7\u30a3\u30aa\u30c8\u30e9\u30c3\u30af\u304c\u30c1\u30e3\u30f3\u30cd\u30eb\u6570\u3067\u306f\u306a\u304f\u300cDolby Atmos\u300d\u3068\u30c9\u30ed\u30c3\u30d7\u30c0\u30a6\u30f3\u306b\u8868\u793a\u3055\u308c\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos \uc624\ub514\uc624 \ud2b8\ub799\uc774 \ucc44\ub110 \uc218 \ub300\uc2e0 \ub4dc\ub86d\ub2e4\uc6b4\uc5d0 \"Dolby Atmos\"\ub85c \ud45c\uc2dc\ub429\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos-lydspor vises n\u00e5 som \"Dolby Atmos\" i menyen i stedet for bare kanalantallet."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos-audiotracks staan nu als \"Dolby Atmos\" in het menu in plaats van alleen het aantal kanalen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u015acie\u017cki audio Atmos s\u0105 oznaczane \u201eDolby Atmos\u201c w menu zamiast samej liczby kana\u0142\u00f3w."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As faixas Atmos aparecem como \"Dolby Atmos\" no menu em vez de apenas a contagem de canais."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As faixas Atmos aparecem como \"Dolby Atmos\" no menu em vez de apenas a contagem de canais."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pistele audio Atmos apar ca \u201eDolby Atmos\u201c \u00een meniu \u00een loc de doar num\u0103rul de canale."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0414\u043e\u0440\u043e\u0436\u043a\u0438 Atmos \u0432 \u043c\u0435\u043d\u044e \u0442\u0435\u043f\u0435\u0440\u044c \u043e\u0442\u043c\u0435\u0447\u0435\u043d\u044b \u043a\u0430\u043a \u00abDolby Atmos\u00bb, \u0430 \u043d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e\u043c \u043a\u0430\u043d\u0430\u043b\u043e\u0432."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos zvukov\u00e9 stopy sa v menu zobrazuj\u00fa ako \u201eDolby Atmos\u201c namiesto po\u010dtu kan\u00e1lov."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos-ljudsp\u00e5r visas som \"Dolby Atmos\" i menyn ist\u00e4llet f\u00f6r bara kanalantalet."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos ses par\u00e7alar\u0131 men\u00fcde kanal say\u0131s\u0131 yerine \"Dolby Atmos\" olarak g\u00f6r\u00fcn\u00fcr."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0414\u043e\u0440\u0456\u0436\u043a\u0438 Atmos \u0443 \u043c\u0435\u043d\u044e \u0442\u0435\u043f\u0435\u0440 \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u044e\u0442\u044c\u0441\u044f \u044f\u043a \u00abDolby Atmos\u00bb, \u0430 \u043d\u0435 \u043b\u0438\u0448\u0435 \u043a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044e \u043a\u0430\u043d\u0430\u043b\u0456\u0432."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos \u97f3\u8f68\u5728\u4e0b\u62c9\u83dc\u5355\u4e2d\u663e\u793a\u4e3a\"Dolby Atmos\",\u800c\u4e0d\u4ec5\u662f\u58f0\u9053\u6570\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmos \u97f3\u8ecc\u5728\u4e0b\u62c9\u9078\u55ae\u4e2d\u986f\u793a\u70ba\u300cDolby Atmos\u300d,\u800c\u4e0d\u53ea\u662f\u8072\u9053\u6578\u3002"
          }
        }
      }
    },

    "settings.playback.autoSubtitleForeign.subtitle" : {
      "comment" : "Subtitle for the autoSubtitleForeign preference",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automaticky zobrazit titulky, pokud p\u0159ehr\u00e1van\u00fd zvuk nen\u00ed ve va\u0161em preferovan\u00e9m jazyce."

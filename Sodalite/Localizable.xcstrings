        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spune \u201eDeschide Sodalite\u201c c\u0103tre Siri Remote, iPhone sau HomePod. Disponibil \u00een 26 de limbi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0421\u043a\u0430\u0436\u0438\u0442\u0435 \u201e\u041e\u0442\u043a\u0440\u043e\u0439 Sodalite\u201c \u043f\u0443\u043b\u044c\u0442\u0443 Siri Remote, iPhone \u0438\u043b\u0438 HomePod. \u0414\u043e\u0441\u0442\u0443\u043f\u043d\u043e \u043d\u0430 26 \u044f\u0437\u044b\u043a\u0430\u0445."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povedzte \u201eOtvor Sodalite\u201c Siri Remote, iPhonu alebo HomePodu. Dostupn\u00e9 v 26 jazykoch."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S\u00e4g \u201e\u00d6ppna Sodalite\u201c till Siri Remote, iPhone eller HomePod. Tillg\u00e4ngligt p\u00e5 26 spr\u00e5k."
          }

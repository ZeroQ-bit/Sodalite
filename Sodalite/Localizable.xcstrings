    "settings.appearance.subtitle" : {
      "comment" : "Subtitle on the Appearance screen explaining what the accent color affects",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte zv\u00fdraz\u0148ovac\u00ed barvu pro tla\u010d\u00edtka, fokusov\u00e9 prstence a zv\u00fdrazn\u011bn\u00ed."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V\u00e6lg en fremh\u00e6vningsfarve til knapper, fokusringe og fremh\u00e6vninger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "W\u00e4hle eine Akzentfarbe f\u00fcr Buttons, Fokusrahmen und Hervorhebungen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0395\u03c0\u03b9\u03bb\u03ad\u03be\u03c4\u03b5 \u03ad\u03bd\u03b1 \u03c7\u03c1\u03ce\u03bc\u03b1 \u03ad\u03bc\u03c6\u03b1\u03c3\u03b7\u03c2 \u03b3\u03b9\u03b1 \u03ba\u03bf\u03c5\u03bc\u03c0\u03b9\u03ac, \u03b4\u03b1\u03c7\u03c4\u03c5\u03bb\u03af\u03b4\u03b9\u03b1 \u03b5\u03c3\u03c4\u03af\u03b1\u03c3\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03b5\u03c0\u03b9\u03c3\u03b7\u03bc\u03ac\u03bd\u03c3\u03b5\u03b9\u03c2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pick an accent color for buttons, focus rings, and highlights."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige un color de acento para botones, anillos de enfoque y resaltados."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valitse korostusv\u00e4ri painikkeille, kohdistusrenkaille ja korostuksille."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez une couleur d'accent pour les boutons, les anneaux de focus et les surlignages."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odaberite naglasnu boju za gumbe, prstenove fokusa i isticanja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V\u00e1lassz kiemel\u0151sz\u00ednt a gombokhoz, f\u00f3kuszgy\u0171r\u0171kh\u00f6z \u00e9s kiemel\u00e9sekhez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli un colore di accento per pulsanti, anelli di messa a fuoco ed evidenziazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30dc\u30bf\u30f3\u3001\u30d5\u30a9\u30fc\u30ab\u30b9\u30ea\u30f3\u30b0\u3001\u30cf\u30a4\u30e9\u30a4\u30c8\u306e\u30a2\u30af\u30bb\u30f3\u30c8\u30ab\u30e9\u30fc\u3092\u9078\u629e\u3057\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\ubc84\ud2bc, \ud3ec\ucee4\uc2a4 \ub9c1 \ubc0f \uac15\uc870 \ud45c\uc2dc\uc5d0 \uc0ac\uc6a9\ud560 \uac15\uc870 \uc0c9\uc0c1\uc744 \uc120\ud0dd\ud558\uc138\uc694."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velg en aksentfarge for knapper, fokusringer og fremhevinger."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kies een accentkleur voor knoppen, focusringen en markeringen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybierz kolor akcentu dla przycisk\u00f3w, pier\u015bcieni fokusu i wyr\u00f3\u017cnie\u0144."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha uma cor de destaque para bot\u00f5es, an\u00e9is de foco e realces."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha uma cor de realce para bot\u00f5es, an\u00e9is de foco e destaques."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alege o culoare de accent pentru butoane, inele de focalizare \u0219i eviden\u021bieri."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0412\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0430\u043a\u0446\u0435\u043d\u0442\u043d\u044b\u0439 \u0446\u0432\u0435\u0442 \u0434\u043b\u044f \u043a\u043d\u043e\u043f\u043e\u043a, \u043a\u043e\u043b\u0435\u0446 \u0444\u043e\u043a\u0443\u0441\u0430 \u0438 \u0432\u044b\u0434\u0435\u043b\u0435\u043d\u0438\u0439."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte zv\u00fdraz\u0148ovaciu farbu pre tla\u010didl\u00e1, fokusov\u00e9 prstence a zv\u00fdraznenia."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V\u00e4lj en accentf\u00e4rg f\u00f6r knappar, fokusringar och markeringar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "D\u00fc\u011fmeler, odak halkalar\u0131 ve vurgular i\u00e7in bir vurgu rengi se\u00e7in."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0412\u0438\u0431\u0435\u0440\u0456\u0442\u044c \u0430\u043a\u0446\u0435\u043d\u0442\u043d\u0438\u0439 \u043a\u043e\u043b\u0456\u0440 \u0434\u043b\u044f \u043a\u043d\u043e\u043f\u043e\u043a, \u043a\u0456\u043b\u0435\u0446\u044c \u0444\u043e\u043a\u0443\u0441\u0443 \u0442\u0430 \u0432\u0438\u0434\u0456\u043b\u0435\u043d\u044c."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u4e3a\u6309\u94ae\u3001\u7126\u70b9\u73af\u548c\u9ad8\u4eae\u9009\u62e9\u4e00\u4e2a\u5f3a\u8c03\u8272\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u70ba\u6309\u9215\u3001\u7126\u9ede\u74b0\u548c\u9ad8\u4eae\u9078\u64c7\u4e00\u500b\u5f37\u8abf\u8272\u3002"
          }
        }
      }
    },

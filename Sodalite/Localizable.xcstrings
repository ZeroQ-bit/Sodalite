    "settings.profile.switchTo.hint" : {
      "comment" : "Hint under switch-profile grid",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klepnut\u00edm p\u0159epnete bez op\u011btovn\u00e9ho p\u0159ihl\u00e1\u0161en\u00ed. Dlouh\u00fdm stisknut\u00edm odstran\u00edte."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryk for at skifte uden at logge ind igen. Hold nede for at fjerne."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen zum Wechseln ohne erneute Anmeldung. Langer Druck zum Entfernen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a0\u03b1\u03c4\u03ae\u03c3\u03c4\u03b5 \u03b3\u03b9\u03b1 \u03b5\u03bd\u03b1\u03bb\u03bb\u03b1\u03b3\u03ae \u03c7\u03c9\u03c1\u03af\u03c2 \u03bd\u03ad\u03b1 \u03c3\u03cd\u03bd\u03b4\u03b5\u03c3\u03b7. \u03a0\u03b1\u03c1\u03b1\u03c4\u03b5\u03c4\u03b1\u03bc\u03ad\u03bd\u03bf \u03c0\u03ac\u03c4\u03b7\u03bc\u03b1 \u03b3\u03b9\u03b1 \u03b1\u03c6\u03b1\u03af\u03c1\u03b5\u03c3\u03b7."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap to switch without signing in again. Long-press to remove."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca para cambiar sin iniciar sesi\u00f3n de nuevo. Mant\u00e9n pulsado para eliminar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaihda napauttamalla ilman uudelleenkirjautumista. Poista pitk\u00e4ll\u00e4 painalluksella."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez pour changer sans vous reconnecter. Maintenez pour supprimer."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dodirnite za promjenu bez ponovne prijave. Dugo pritisnite za uklanjanje."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u00c9rintsd meg a v\u00e1lt\u00e1shoz \u00fajrabejelentkez\u00e9s n\u00e9lk\u00fcl. Hossz\u00fa nyom\u00e1s az elt\u00e1vol\u00edt\u00e1shoz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca per cambiare senza accedere di nuovo. Premi a lungo per rimuovere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30bf\u30c3\u30d7\u3067\u518d\u30b5\u30a4\u30f3\u30a4\u30f3\u306a\u3057\u306b\u5207\u308a\u66ff\u3048\u3002\u9577\u62bc\u3057\u3067\u524a\u9664\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\ud0ed\ud558\uba74 \ub2e4\uc2dc \ub85c\uadf8\uc778 \uc5c6\uc774 \uc804\ud658\ub429\ub2c8\ub2e4. \uae38\uac8c \ub204\ub974\uba74 \uc81c\uac70\ub429\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trykk for \u00e5 bytte uten \u00e5 logge inn p\u00e5 nytt. Hold nede for \u00e5 fjerne."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik om te wisselen zonder opnieuw in te loggen. Houd ingedrukt om te verwijderen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dotknij, aby prze\u0142\u0105czy\u0107 bez ponownego logowania. Przytrzymaj, aby usun\u0105\u0107."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque para trocar sem entrar de novo. Pressione e segure para remover."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque para mudar sem iniciar sess\u00e3o novamente. Mantenha premido para remover."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atinge pentru a schimba f\u0103r\u0103 a te conecta din nou. Apas\u0103 lung pentru a elimina."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041a\u043e\u0441\u043d\u0438\u0442\u0435\u0441\u044c, \u0447\u0442\u043e\u0431\u044b \u043f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0438\u0442\u044c\u0441\u044f \u0431\u0435\u0437 \u043f\u043e\u0432\u0442\u043e\u0440\u043d\u043e\u0433\u043e \u0432\u0445\u043e\u0434\u0430. \u0423\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439\u0442\u0435, \u0447\u0442\u043e\u0431\u044b \u0443\u0434\u0430\u043b\u0438\u0442\u044c."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klepnut\u00edm prepnete bez op\u00e4tovn\u00e9ho prihl\u00e1senia. Dlh\u00fdm stla\u010den\u00edm odstr\u00e1nite."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryck f\u00f6r att byta utan att logga in igen. H\u00e5ll nedtryckt f\u00f6r att ta bort."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekrar giri\u015f yapmadan de\u011fi\u015ftirmek i\u00e7in dokunun. Kald\u0131rmak i\u00e7in uzun bas\u0131n."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0422\u043e\u0440\u043a\u043d\u0456\u0442\u044c\u0441\u044f, \u0449\u043e\u0431 \u043f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0438\u0442\u0438\u0441\u044f \u0431\u0435\u0437 \u043f\u043e\u0432\u0442\u043e\u0440\u043d\u043e\u0433\u043e \u0432\u0445\u043e\u0434\u0443. \u0423\u0442\u0440\u0438\u043c\u0443\u0439\u0442\u0435, \u0449\u043e\u0431 \u0432\u0438\u0434\u0430\u043b\u0438\u0442\u0438."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u70b9\u6309\u5373\u53ef\u5207\u6362,\u65e0\u9700\u518d\u6b21\u767b\u5f55\u3002\u957f\u6309\u53ef\u79fb\u9664\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u9ede\u6309\u5373\u53ef\u5207\u63db,\u7121\u9700\u518d\u6b21\u767b\u5165\u3002\u9577\u6309\u53ef\u79fb\u9664\u3002"
          }
        }
      }
    },

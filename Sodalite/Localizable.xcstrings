        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri Remote\u2019a, iPhone\u2019a ya da HomePod\u2019a \u201eSodalite uygulamas\u0131n\u0131 a\u00e7\u201c deyin. 26 dilde mevcut."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0421\u043a\u0430\u0436\u0456\u0442\u044c \u201e\u0412\u0456\u0434\u043a\u0440\u0438\u0439 Sodalite\u201c Siri Remote, iPhone \u0430\u0431\u043e HomePod. \u0414\u043e\u0441\u0442\u0443\u043f\u043d\u043e 26 \u043c\u043e\u0432\u0430\u043c\u0438."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5bf9 Siri Remote\u3001iPhone \u6216 HomePod \u8bf4\u300c\u6253\u5f00 Sodalite\u300d\u3002\u652f\u6301 26 \u79cd\u8bed\u8a00\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5c0d Siri Remote\u3001iPhone \u6216 HomePod \u8aaa\u300c\u958b\u555f Sodalite\u300d\u3002\u652f\u63f4 26 \u7a2e\u8a9e\u8a00\u3002"

    "changelog.0_4_0.cardHeights.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obl\u00edben\u00e9 sb\u00edrky se nyn\u00ed zobrazuj\u00ed ve stejn\u00e9 v\u00fd\u0161ce jako filmy a seri\u00e1ly."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Favoritsamlinger vises nu i samme h\u00f8jde som film og serier."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Favorisierte Sammlungen sind jetzt gleich hoch wie Filme und Serien."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u039f\u03b9 \u03b1\u03b3\u03b1\u03c0\u03b7\u03bc\u03ad\u03bd\u03b5\u03c2 \u03c3\u03c5\u03bb\u03bb\u03bf\u03b3\u03ad\u03c2 \u03b5\u03bc\u03c6\u03b1\u03bd\u03af\u03b6\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c4\u03ce\u03c1\u03b1 \u03c3\u03c4\u03bf \u03af\u03b4\u03b9\u03bf \u03cd\u03c8\u03bf\u03c2 \u03bc\u03b5 \u03c4\u03b9\u03c2 \u03c4\u03b1\u03b9\u03bd\u03af\u03b5\u03c2 \u03ba\u03b1\u03b9 \u03c4\u03b9\u03c2 \u03c3\u03b5\u03b9\u03c1\u03ad\u03c2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Favourited collections now sit at the same height as movies and series."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las colecciones favoritas ahora tienen la misma altura que pel\u00edculas y series."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suosikkikokoelmat n\u00e4kyv\u00e4t nyt samalla korkeudella kuin elokuvat ja sarjat."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les collections favorites s'affichent maintenant \u00e0 la m\u00eame hauteur que les films et les s\u00e9ries."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omiljene zbirke sada su iste visine kao filmovi i serije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A kedvenc gy\u0171jtem\u00e9nyek most ugyanolyan magasak, mint a filmek \u00e9s sorozatok."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le collezioni preferite ora hanno la stessa altezza di film e serie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u304a\u6c17\u306b\u5165\u308a\u306e\u30b3\u30ec\u30af\u30b7\u30e7\u30f3\u304c\u6620\u753b\u3084\u30b7\u30ea\u30fc\u30ba\u3068\u540c\u3058\u9ad8\u3055\u3067\u8868\u793a\u3055\u308c\u308b\u3088\u3046\u306b\u306a\u308a\u307e\u3057\u305f\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc990\uaca8\ucc3e\uae30\ud55c \uceec\ub809\uc158\uc774 \uc774\uc81c \uc601\ud654 \ubc0f \uc2dc\ub9ac\uc988\uc640 \uac19\uc740 \ub192\uc774\ub85c \ud45c\uc2dc\ub429\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Favorittsamlinger har n\u00e5 samme h\u00f8yde som filmer og serier."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Favoriete collecties hebben nu dezelfde hoogte als films en series."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ulubione kolekcje maj\u0105 teraz t\u0119 sam\u0105 wysoko\u015b\u0107 co filmy i seriale."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cole\u00e7\u00f5es favoritas agora ficam na mesma altura que filmes e s\u00e9ries."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As cole\u00e7\u00f5es favoritas agora ficam \u00e0 mesma altura que filmes e s\u00e9ries."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Colec\u021biile favorite au acum aceea\u0219i \u00een\u0103l\u021bime ca filmele \u0219i serialele."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0418\u0437\u0431\u0440\u0430\u043d\u043d\u044b\u0435 \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438 \u0442\u0435\u043f\u0435\u0440\u044c \u043e\u0442\u043e\u0431\u0440\u0430\u0436\u0430\u044e\u0442\u0441\u044f \u0442\u043e\u0439 \u0436\u0435 \u0432\u044b\u0441\u043e\u0442\u044b, \u0447\u0442\u043e \u0444\u0438\u043b\u044c\u043c\u044b \u0438 \u0441\u0435\u0440\u0438\u0430\u043b\u044b."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ob\u013e\u00faben\u00e9 kolekcie s\u00fa teraz rovnako vysok\u00e9 ako filmy a seri\u00e1ly."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Favoritsamlingar har nu samma h\u00f6jd som filmer och serier."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Favori koleksiyonlar art\u0131k filmler ve dizilerle ayn\u0131 y\u00fckseklikte g\u00f6r\u00fcn\u00fcyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0423\u043b\u044e\u0431\u043b\u0435\u043d\u0456 \u043a\u043e\u043b\u0435\u043a\u0446\u0456\u0457 \u0442\u0435\u043f\u0435\u0440 \u043c\u0430\u044e\u0442\u044c \u0442\u0430\u043a\u0443 \u0441\u0430\u043c\u0443 \u0432\u0438\u0441\u043e\u0442\u0443, \u044f\u043a \u0444\u0456\u043b\u044c\u043c\u0438 \u0442\u0430 \u0441\u0435\u0440\u0456\u0430\u043b\u0438."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u6536\u85cf\u7684\u5408\u96c6\u73b0\u5728\u4e0e\u7535\u5f71\u548c\u5267\u96c6\u4fdd\u6301\u76f8\u540c\u7684\u9ad8\u5ea6\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u6536\u85cf\u7684\u5408\u96c6\u73fe\u5728\u8207\u96fb\u5f71\u548c\u5287\u96c6\u4fdd\u6301\u76f8\u540c\u7684\u9ad8\u5ea6\u3002"
          }
        }
      }
    },

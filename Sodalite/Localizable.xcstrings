        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u0440\u043e\u043f\u0443\u0441\u0442\u0438\u0442\u0438 \u0432\u0438\u0431\u0456\u0440 \u0456 \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u043d\u043e \u0443\u0432\u0456\u0439\u0442\u0438 \u044f\u043a \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u0438\u0439 \u043f\u0440\u043e\u0444\u0456\u043b\u044c."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8df3\u8fc7\u9009\u62e9\u5668,\u81ea\u52a8\u4f7f\u7528\u9ed8\u8ba4\u914d\u7f6e\u6587\u4ef6\u767b\u5f55\u3002"

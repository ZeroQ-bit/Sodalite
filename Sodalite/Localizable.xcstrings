    "settings.playback.picture.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jak video vypl\u0148uje obrazovku \u2014 zachovat pom\u011br stran nebo p\u0159ibl\u00ed\u017eit a o\u0159\u00edznout."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvordan videoen udfylder sk\u00e6rmen \u2014 bevar forholdet eller zoom og besk\u00e6r."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie das Video den Bildschirm f\u00fcllt \u2014 Seitenverh\u00e4ltnis beibehalten oder hineinzoomen und beschneiden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a0\u03ce\u03c2 \u03b3\u03b5\u03bc\u03af\u03b6\u03b5\u03b9 \u03b7 \u03b5\u03b9\u03ba\u03cc\u03bd\u03b1 \u03c4\u03b7\u03bd \u03bf\u03b8\u03cc\u03bd\u03b7 \u2014 \u03b4\u03b9\u03b1\u03c4\u03ae\u03c1\u03b7\u03c3\u03b7 \u03b1\u03bd\u03b1\u03bb\u03bf\u03b3\u03af\u03b1\u03c2 \u03ae \u03b6\u03bf\u03c5\u03bc \u03ba\u03b1\u03b9 \u03c0\u03b5\u03c1\u03b9\u03ba\u03bf\u03c0\u03ae."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How the video fills the screen \u2014 preserve aspect or zoom and crop."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C\u00f3mo llena la pantalla el v\u00eddeo: mantener proporci\u00f3n o ampliar y recortar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Miten kuva t\u00e4ytt\u00e4\u00e4 n\u00e4yt\u00f6n \u2014 s\u00e4ilyt\u00e4 mittasuhteet tai zoomaa ja rajaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comment la vid\u00e9o remplit l'\u00e9cran : conserver le ratio ou zoomer et rogner."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kako video ispunjava zaslon \u2014 sa\u010duvaj omjer ili zumiraj i izre\u017ei."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hogyan t\u00f6lti ki a k\u00e9p a k\u00e9perny\u0151t \u2014 ar\u00e1ny megtartva, vagy r\u00e1k\u00f6zel\u00edtve \u00e9s v\u00e1gva."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Come il video riempie lo schermo: mantieni proporzioni o zoom e ritaglio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u6620\u50cf\u304c\u753b\u9762\u3092\u3069\u3046\u57cb\u3081\u308b\u304b \u2014 \u30a2\u30b9\u30da\u30af\u30c8\u6bd4\u4fdd\u6301\u304b\u3001\u30ba\u30fc\u30e0\u3057\u3066\u5207\u308a\u629c\u304f\u304b\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc601\uc0c1\uc774 \ud654\uba74\uc744 \ucc44\uc6b0\ub294 \ubc29\uc2dd \u2014 \ube44\uc728 \uc720\uc9c0 \ub610\ub294 \ud655\ub300 \ud6c4 \uc790\ub974\uae30."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvordan videoen fyller skjermen \u2014 behold forhold eller zoom og beskj\u00e6r."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoe de video het scherm vult \u2014 verhouding behouden of zoomen en bijsnijden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jak wideo wype\u0142nia ekran \u2014 zachowaj proporcje lub przybli\u017c i przytnij."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Como o v\u00eddeo preenche a tela \u2014 preservar propor\u00e7\u00e3o ou aproximar e cortar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Como o v\u00eddeo preenche o ecr\u00e3 \u2014 preservar propor\u00e7\u00e3o ou ampliar e cortar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cum umple imaginea ecranul \u2014 p\u0103streaz\u0103 raportul sau apropie \u0219i decupeaz\u0103."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041a\u0430\u043a \u0432\u0438\u0434\u0435\u043e \u0437\u0430\u043f\u043e\u043b\u043d\u044f\u0435\u0442 \u044d\u043a\u0440\u0430\u043d \u2014 \u0441\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c \u043f\u0440\u043e\u043f\u043e\u0440\u0446\u0438\u0438 \u0438\u043b\u0438 \u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0442\u044c \u0438 \u043e\u0431\u0440\u0435\u0437\u0430\u0442\u044c."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako video vyp\u013a\u0148a obrazovku \u2014 zachova\u0165 pomer alebo pribl\u00ed\u017ei\u0165 a oreza\u0165."

        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u039a\u03bb\u03af\u03bc\u03b1\u03ba\u03b1 \u03b3\u03c1\u03b1\u03bc\u03bc\u03b1\u03c4\u03bf\u03c3\u03b5\u03b9\u03c1\u03ac\u03c2 \u03c5\u03c0\u03cc\u03c4\u03b9\u03c4\u03bb\u03c9\u03bd \u03ba\u03b5\u03b9\u03bc\u03ad\u03bd\u03bf\u03c5."
          }
        },

    "support.pack.subtitle" : {
      "comment" : "Subtitle explaining what the Supporter Pack unlocks",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jednor\u00e1zov\u00e9 odem\u010den\u00ed. Kosmetick\u00e9 extra \u2014 speci\u00e1ln\u00ed \u00favodn\u00ed ikona, vlastn\u00ed zv\u00fdraz\u0148ovac\u00ed barvy a odznak podporovatele v nastaven\u00ed."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engangsopl\u00e5sning. Kosmetiske ekstras \u2014 et specielt splash-ikon, brugerdefinerede fremh\u00e6vningsfarver og et supporter-badge i Indstillinger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einmaliger Freischaltkauf. Kosmetische Extras \u2014 ein spezielles Splash-Icon, eigene Akzentfarben und ein Supporter-Abzeichen in den Einstellungen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0395\u03c6\u03ac\u03c0\u03b1\u03be \u03be\u03b5\u03ba\u03bb\u03b5\u03af\u03b4\u03c9\u03bc\u03b1. \u039a\u03bf\u03c3\u03bc\u03b7\u03c4\u03b9\u03ba\u03ac \u03ad\u03be\u03c4\u03c1\u03b1 \u2014 \u03ad\u03bd\u03b1 \u03b5\u03b9\u03b4\u03b9\u03ba\u03cc \u03b5\u03b9\u03ba\u03bf\u03bd\u03af\u03b4\u03b9\u03bf \u03ad\u03bd\u03b1\u03c1\u03be\u03b7\u03c2, \u03c0\u03c1\u03bf\u03c3\u03b1\u03c1\u03bc\u03bf\u03c3\u03bc\u03ad\u03bd\u03b1 \u03c7\u03c1\u03ce\u03bc\u03b1\u03c4\u03b1 \u03ad\u03bc\u03c6\u03b1\u03c3\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03ad\u03bd\u03b1 \u03c3\u03ae\u03bc\u03b1 \u03c5\u03c0\u03bf\u03c3\u03c4\u03b7\u03c1\u03b9\u03ba\u03c4\u03ae \u03c3\u03c4\u03b9\u03c2 \u03a1\u03c5\u03b8\u03bc\u03af\u03c3\u03b5\u03b9\u03c2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "One-time unlock. Cosmetic extras \u2014 a special splash icon, custom accent colors, and a supporter badge in Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueo \u00fanico. Extras cosm\u00e9ticos: un icono de inicio especial, colores de acento personalizados y una insignia de apoyo en Ajustes."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kertakertainen avaus. Kosmeettiset lis\u00e4t \u2014 erityinen k\u00e4ynnistyskuvake, mukautetut korostusv\u00e4rit ja tukija-merkki asetuksissa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "D\u00e9blocage unique. Extras cosm\u00e9tiques \u2014 une ic\u00f4ne de lancement sp\u00e9ciale, des couleurs d'accent personnalis\u00e9es et un badge de soutien dans les R\u00e9glages."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jednokratno otklju\u010davanje. Kozmeti\u010dki dodaci \u2014 posebna uvodna ikona, prilago\u0111ene naglasne boje i podr\u017eavateljska zna\u010dka u postavkama."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egyszeri felold\u00e1s. Kozmetikai extr\u00e1k \u2014 egy k\u00fcl\u00f6nleges nyit\u00f3ikon, egy\u00e9ni kiemel\u0151sz\u00ednek \u00e9s egy t\u00e1mogat\u00f3i jelv\u00e9ny a Be\u00e1ll\u00edt\u00e1sokban."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sblocco una tantum. Extra estetici \u2014 un'icona iniziale speciale, colori di accento personalizzati e un badge sostenitore in Impostazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u4e00\u56de\u9650\u308a\u306e\u30a2\u30f3\u30ed\u30c3\u30af\u3002\u30b3\u30b9\u30e1\u30c6\u30a3\u30c3\u30af\u30a8\u30af\u30b9\u30c8\u30e9 \u2014 \u7279\u5225\u306a\u30b9\u30d7\u30e9\u30c3\u30b7\u30e5\u30a2\u30a4\u30b3\u30f3\u3001\u30ab\u30b9\u30bf\u30e0\u30a2\u30af\u30bb\u30f3\u30c8\u30ab\u30e9\u30fc\u3001\u8a2d\u5b9a\u5185\u306e\u30b5\u30dd\u30fc\u30bf\u30fc\u30d0\u30c3\u30b8\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc77c\ud68c\uc131 \uc7a0\uae08 \ud574\uc81c. \uafb8\ubbf8\uae30 \ucd94\uac00 \uae30\ub2a5 \u2014 \ud2b9\ubcc4\ud55c \uc2a4\ud50c\ub798\uc2dc \uc544\uc774\ucf58, \ub9de\ucda4 \uac15\uc870 \uc0c9\uc0c1, \uc124\uc815\uc758 \uc11c\ud3ec\ud130 \ubc30\uc9c0."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engangsoppl\u00e5sing. Kosmetiske ekstra \u2014 et spesielt splash-ikon, tilpassede aksentfarger og et supporter-merke i Innstillinger."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eenmalige ontgrendeling. Cosmetische extra's \u2014 een speciaal splash-icoon, aangepaste accentkleuren en een supportersbadge in Instellingen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jednorazowe odblokowanie. Dodatki kosmetyczne \u2014 specjalna ikona powitalna, niestandardowe kolory akcentu i odznaka wspieraj\u0105cego w Ustawieniach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueio \u00fanico. Extras cosm\u00e9ticos \u2014 um \u00edcone de abertura especial, cores de destaque personalizadas e um distintivo de apoiador nos Ajustes."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueio \u00fanico. Extras cosm\u00e9ticos \u2014 um \u00edcone de abertura especial, cores de realce personalizadas e um distintivo de apoiante nas Defini\u00e7\u00f5es."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deblocare unic\u0103. Extra cosmetice \u2014 o pictogram\u0103 de pornire special\u0103, culori de accent personalizate \u0219i o insign\u0103 de sus\u021bin\u0103tor \u00een Set\u0103ri."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0420\u0430\u0437\u043e\u0432\u0430\u044f \u0440\u0430\u0437\u0431\u043b\u043e\u043a\u0438\u0440\u043e\u0432\u043a\u0430. \u041a\u043e\u0441\u043c\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0434\u043e\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f \u2014 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u0430\u044f \u0437\u0430\u0441\u0442\u0430\u0432\u043a\u0430, \u043d\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0435\u043c\u044b\u0435 \u0430\u043a\u0446\u0435\u043d\u0442\u043d\u044b\u0435 \u0446\u0432\u0435\u0442\u0430 \u0438 \u0437\u043d\u0430\u0447\u043e\u043a \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0438 \u0432 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0430\u0445."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jednorazov\u00e9 odomknutie. Kozmetick\u00e9 extra \u2014 \u0161peci\u00e1lna \u00favodn\u00e1 ikona, vlastn\u00e9 zv\u00fdraz\u0148ovacie farby a odznak podporovate\u013ea v nastaveniach."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eng\u00e5ngsuppl\u00e5sning. Kosmetiska extra \u2014 en speciell startikon, anpassade accentf\u00e4rger och ett supporter-m\u00e4rke i Inst\u00e4llningar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tek seferlik kilit a\u00e7ma. Kozmetik ekstralar \u2014 \u00f6zel bir a\u00e7\u0131l\u0131\u015f simgesi, \u00f6zel vurgu renkleri ve Ayarlar'da bir destek\u00e7i rozeti."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0420\u0430\u0437\u043e\u0432\u0435 \u0440\u043e\u0437\u0431\u043b\u043e\u043a\u0443\u0432\u0430\u043d\u043d\u044f. \u041a\u043e\u0441\u043c\u0435\u0442\u0438\u0447\u043d\u0456 \u0434\u043e\u043f\u043e\u0432\u043d\u0435\u043d\u043d\u044f \u2014 \u0441\u043f\u0435\u0446\u0456\u0430\u043b\u044c\u043d\u0430 \u0437\u0430\u0441\u0442\u0430\u0432\u043a\u0430, \u0432\u043b\u0430\u0441\u043d\u0456 \u0430\u043a\u0446\u0435\u043d\u0442\u043d\u0456 \u043a\u043e\u043b\u044c\u043e\u0440\u0438 \u0442\u0430 \u0437\u043d\u0430\u0447\u043e\u043a \u043f\u0440\u0438\u0445\u0438\u043b\u044c\u043d\u0438\u043a\u0430 \u0432 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f\u0445."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u4e00\u6b21\u6027\u89e3\u9501\u3002\u88c5\u9970\u6027\u9644\u52a0\u5185\u5bb9 \u2014 \u7279\u6b8a\u542f\u52a8\u56fe\u6807\u3001\u81ea\u5b9a\u4e49\u5f3a\u8c03\u8272\u548c\u8bbe\u7f6e\u4e2d\u7684\u652f\u6301\u8005\u5fbd\u7ae0\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u4e00\u6b21\u6027\u89e3\u9396\u3002\u88dd\u98fe\u6027\u9644\u52a0\u5167\u5bb9 \u2014 \u7279\u6b8a\u555f\u52d5\u5716\u793a\u3001\u81ea\u8a02\u5f37\u8abf\u8272\u548c\u8a2d\u5b9a\u4e2d\u7684\u652f\u6301\u8005\u5fbd\u7ae0\u3002"
          }
        }
      }
    },
    "support.pack.thanks" : {
      "comment" : "Status banner after purchasing the Supporter Pack",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V\u00edtejte! Bal\u00ed\u010dek podporovatele odem\u010den."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velkommen ombord! Supporter-pakke l\u00e5st op."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Willkommen an Bord! Supporter-Paket freigeschaltet."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u039a\u03b1\u03bb\u03ce\u03c2 \u03ae\u03c1\u03b8\u03b1\u03c4\u03b5! \u03a4\u03bf \u03a0\u03b1\u03ba\u03ad\u03c4\u03bf \u03a5\u03c0\u03bf\u03c3\u03c4\u03ae\u03c1\u03b9\u03be\u03b7\u03c2 \u03be\u03b5\u03ba\u03bb\u03b5\u03b9\u03b4\u03ce\u03b8\u03b7\u03ba\u03b5."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome aboard! Supporter Pack unlocked."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u00a1Bienvenido a bordo! Pack de Apoyo desbloqueado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tervetuloa! Tukijapaketti avattu."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bienvenue \u00e0 bord ! Pack de soutien d\u00e9bloqu\u00e9."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dobrodo\u0161li! Podr\u017eavateljski paket otklju\u010dan."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u00dcdv\u00f6zl\u00fcnk! T\u00e1mogat\u00f3i csomag feloldva."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benvenuto a bordo! Pacchetto Sostenitore sbloccato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u3088\u3046\u3053\u305d\uff01\u30b5\u30dd\u30fc\u30bf\u30fc\u30d1\u30c3\u30af\u304c\u30a2\u30f3\u30ed\u30c3\u30af\u3055\u308c\u307e\u3057\u305f\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\ud658\uc601\ud569\ub2c8\ub2e4! \uc11c\ud3ec\ud130 \ud329\uc774 \uc7a0\uae08 \ud574\uc81c\ub418\uc5c8\uc2b5\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velkommen om bord! Supporter-pakke l\u00e5st opp."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welkom aan boord! Supporterspakket ontgrendeld."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Witamy na pok\u0142adzie! Pakiet Wspieraj\u0105cy odblokowany."
          }
        },
        "pt-BR" : {

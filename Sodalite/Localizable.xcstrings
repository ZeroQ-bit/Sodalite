    "changelog.0_5_0.errorCategories.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Probl\u00e9my s p\u0159ipojen\u00edm, chyby p\u0159ihl\u00e1\u0161en\u00ed, \u010dasov\u00e9 limity a 404 maj\u00ed vlastn\u00ed ikonu a nadpis m\u00edsto obecn\u00e9 zpr\u00e1vy \u201ep\u0159ehr\u00e1v\u00e1n\u00ed selhalo\"."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forbindelsesproblemer, login-fejl, timeouts og 404'ere f\u00e5r hver sit ikon og overskrift i stedet for en generisk \"afspilning mislykkedes\"-besked."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbindungsprobleme, Anmeldefehler, Zeit\u00fcberschreitungen und 404er bekommen je ein eigenes Icon und eine passende \u00dcberschrift statt einer allgemeinen \"Wiedergabe fehlgeschlagen\"-Meldung."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a4\u03b1 \u03c0\u03c1\u03bf\u03b2\u03bb\u03ae\u03bc\u03b1\u03c4\u03b1 \u03c3\u03cd\u03bd\u03b4\u03b5\u03c3\u03b7\u03c2, \u03c4\u03b1 \u03c3\u03c6\u03ac\u03bb\u03bc\u03b1\u03c4\u03b1 \u03c3\u03cd\u03bd\u03b4\u03b5\u03c3\u03b7\u03c2, \u03c4\u03b1 \u03c7\u03c1\u03bf\u03bd\u03b9\u03ba\u03ac \u03cc\u03c1\u03b9\u03b1 \u03ba\u03b1\u03b9 \u03c4\u03b1 404 \u03ad\u03c7\u03bf\u03c5\u03bd \u03c4\u03bf \u03ba\u03b1\u03b8\u03ad\u03bd\u03b1 \u03b4\u03b9\u03ba\u03cc \u03c4\u03bf\u03c5 \u03b5\u03b9\u03ba\u03bf\u03bd\u03af\u03b4\u03b9\u03bf \u03ba\u03b1\u03b9 \u03c4\u03af\u03c4\u03bb\u03bf \u03b1\u03bd\u03c4\u03af \u03b3\u03b9\u03b1 \u03ad\u03bd\u03b1 \u03b3\u03b5\u03bd\u03b9\u03ba\u03cc \u03bc\u03ae\u03bd\u03c5\u03bc\u03b1 \u00ab\u03b7 \u03b1\u03bd\u03b1\u03c0\u03b1\u03c1\u03b1\u03b3\u03c9\u03b3\u03ae \u03b1\u03c0\u03ad\u03c4\u03c5\u03c7\u03b5\u00bb."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connection issues, sign-in problems, timeouts and 404s each get their own icon and headline instead of a generic 'playback failed' message."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los problemas de conexi\u00f3n, los errores de inicio de sesi\u00f3n, los tiempos de espera y los 404 reciben cada uno su propio icono y t\u00edtulo en lugar de un mensaje gen\u00e9rico de \"fallo de reproducci\u00f3n\"."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yhteysongelmat, kirjautumisvirheet, aikakatkaisut ja 404-virheet saavat kukin oman kuvakkeensa ja otsikkonsa yleisen \"toisto ep\u00e4onnistui\"-viestin sijaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les probl\u00e8mes de connexion, d'authentification, les d\u00e9lais d'attente et les 404 ont chacun leur propre ic\u00f4ne et leur propre titre au lieu d'un message g\u00e9n\u00e9rique \"\u00e9chec de la lecture\"."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemi s vezom, pogre\u0161ke prijave, isteci vremena i 404 svaki dobivaju vlastitu ikonu i naslov umjesto op\u0107enite poruke \"reprodukcija nije uspjela\"."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A kapcsol\u00f3d\u00e1si probl\u00e9m\u00e1k, bejelentkez\u00e9si hib\u00e1k, id\u0151t\u00fall\u00e9p\u00e9sek \u00e9s 404-esek mindegyike saj\u00e1t ikont \u00e9s c\u00edmet kap az \u00e1ltal\u00e1nos \"a lej\u00e1tsz\u00e1s sikertelen\" \u00fczenet helyett."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemi di connessione, errori di accesso, timeout e 404 ottengono ciascuno la propria icona e il proprio titolo invece di un generico messaggio \"riproduzione non riuscita\"."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u63a5\u7d9a\u306e\u554f\u984c\u3001\u30b5\u30a4\u30f3\u30a4\u30f3\u30a8\u30e9\u30fc\u3001\u30bf\u30a4\u30e0\u30a2\u30a6\u30c8\u3001404\u306b\u305d\u308c\u305e\u308c\u5c02\u7528\u306e\u30a2\u30a4\u30b3\u30f3\u3068\u898b\u51fa\u3057\u3092\u8868\u793a\u3057\u3001\u6c4e\u7528\u7684\u306a\u300c\u518d\u751f\u306b\u5931\u6557\u3057\u307e\u3057\u305f\u300d\u8868\u793a\u3092\u7f6e\u304d\u63db\u3048\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc5f0\uacb0 \ubb38\uc81c, \ub85c\uadf8\uc778 \uc624\ub958, \ud0c0\uc784\uc544\uc6c3, 404 \uac01\uac01\uc774 \uc77c\ubc18\uc801\uc778 \"\uc7ac\uc0dd \uc2e4\ud328\" \uba54\uc2dc\uc9c0 \ub300\uc2e0 \uace0\uc720\ud55c \uc544\uc774\ucf58\uacfc \uc81c\ubaa9\uc744 \uac00\uc9d1\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tilkoblingsproblemer, innloggingsfeil, tidsavbrudd og 404-er f\u00e5r hver sin ikon og overskrift i stedet for en generisk \"avspilling mislyktes\"-melding."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbindingsproblemen, aanmeldfouten, time-outs en 404's krijgen elk een eigen pictogram en kop in plaats van een generieke 'afspelen mislukt'-melding."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemy z po\u0142\u0105czeniem, b\u0142\u0119dy logowania, przekroczenia limitu czasu i 404 maj\u0105 teraz w\u0142asn\u0105 ikon\u0119 i nag\u0142\u00f3wek zamiast og\u00f3lnego komunikatu \u201eodtwarzanie nieudane\"."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemas de conex\u00e3o, erros de login, timeouts e 404s recebem cada um seu pr\u00f3prio \u00edcone e t\u00edtulo em vez de uma mensagem gen\u00e9rica de \"falha na reprodu\u00e7\u00e3o\"."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemas de liga\u00e7\u00e3o, erros de in\u00edcio de sess\u00e3o, timeouts e 404 recebem cada um o seu pr\u00f3prio \u00edcone e t\u00edtulo em vez de uma mensagem gen\u00e9rica de \"reprodu\u00e7\u00e3o falhou\"."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemele de conexiune, erorile de autentificare, timeout-urile \u0219i 404-urile primesc fiecare propria pictogram\u0103 \u0219i titlu \u00een locul unui mesaj generic \"redare e\u0219uat\u0103\"."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u0440\u043e\u0431\u043b\u0435\u043c\u044b \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u044f, \u043e\u0448\u0438\u0431\u043a\u0438 \u0432\u0445\u043e\u0434\u0430, \u0442\u0430\u0439\u043c-\u0430\u0443\u0442\u044b \u0438 404-\u0435 \u043f\u043e\u043b\u0443\u0447\u0430\u044e\u0442 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0443\u044e \u0438\u043a\u043e\u043d\u043a\u0443 \u0438 \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a \u0432\u043c\u0435\u0441\u0442\u043e \u043e\u0431\u0449\u0435\u0433\u043e \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f \u00ab\u0432\u043e\u0441\u043f\u0440\u043e\u0438\u0437\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u043d\u0435 \u0443\u0434\u0430\u043b\u043e\u0441\u044c\u00bb."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Probl\u00e9my s pripojen\u00edm, chyby prihl\u00e1senia, \u010dasov\u00e9 limity a 404 maj\u00fa vlastn\u00fa ikonu a nadpis namiesto v\u0161eobecnej spr\u00e1vy \u201eprehr\u00e1vanie zlyhalo\"."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anslutningsproblem, inloggningsfel, timeouts och 404:or f\u00e5r var sin ikon och rubrik ist\u00e4llet f\u00f6r ett generiskt \"uppspelning misslyckades\"-meddelande."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ba\u011flant\u0131 sorunlar\u0131, oturum a\u00e7ma hatalar\u0131, zaman a\u015f\u0131mlar\u0131 ve 404'ler genel \"oynatma ba\u015far\u0131s\u0131z\" mesaj\u0131 yerine her biri kendi simgesini ve ba\u015fl\u0131\u011f\u0131n\u0131 al\u0131r."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u0440\u043e\u0431\u043b\u0435\u043c\u0438 \u0437\u0456 \u0437'\u0454\u0434\u043d\u0430\u043d\u043d\u044f\u043c, \u043f\u043e\u043c\u0438\u043b\u043a\u0438 \u0432\u0445\u043e\u0434\u0443, \u0442\u0430\u0439\u043c-\u0430\u0443\u0442\u0438 \u0442\u0430 404 \u043e\u0442\u0440\u0438\u043c\u0443\u044e\u0442\u044c \u0432\u043b\u0430\u0441\u043d\u0443 \u0456\u043a\u043e\u043d\u043a\u0443 \u0439 \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a \u0437\u0430\u043c\u0456\u0441\u0442\u044c \u0437\u0430\u0433\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u043f\u043e\u0432\u0456\u0434\u043e\u043c\u043b\u0435\u043d\u043d\u044f \u00ab\u043d\u0435 \u0432\u0434\u0430\u043b\u043e\u0441\u044f \u0432\u0456\u0434\u0442\u0432\u043e\u0440\u0438\u0442\u0438\u00bb."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8fde\u63a5\u95ee\u9898\u3001\u767b\u5f55\u95ee\u9898\u3001\u8d85\u65f6\u548c 404 \u9519\u8bef\u73b0\u5728\u5404\u81ea\u6709\u4e13\u5c5e\u56fe\u6807\u548c\u6807\u9898,\u800c\u4e0d\u662f\u901a\u7528\u7684\u201c\u64ad\u653e\u5931\u8d25\u201d\u6d88\u606f\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u9023\u7dda\u554f\u984c\u3001\u767b\u5165\u554f\u984c\u3001\u903e\u6642\u548c 404 \u932f\u8aa4\u73fe\u5728\u5404\u81ea\u6709\u5c08\u5c6c\u5716\u793a\u548c\u6a19\u984c,\u800c\u975e\u901a\u7528\u7684\u300c\u64ad\u653e\u5931\u6557\u300d\u8a0a\u606f\u3002"
          }
        }
      }
    },

    "changelog.0_4_1.endOfContent.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P\u0159ehr\u00e1va\u010d v\u00e1s po skon\u010den\u00ed filmu nebo posledn\u00ed epizody seri\u00e1lu automaticky vr\u00e1t\u00ed na detail."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afspilleren returnerer dig til detaljevisningen n\u00e5r en film eller seriens sidste afsnit slutter."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn ein Film oder die letzte Folge einer Serie endet, schlie\u00dft der Player automatisch zur\u00fcck zur Detailansicht."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u038c\u03c4\u03b1\u03bd \u03c4\u03b5\u03bb\u03b5\u03b9\u03ce\u03bd\u03b5\u03b9 \u03bc\u03b9\u03b1 \u03c4\u03b1\u03b9\u03bd\u03af\u03b1 \u03ae \u03c4\u03bf \u03c4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03bf \u03b5\u03c0\u03b5\u03b9\u03c3\u03cc\u03b4\u03b9\u03bf, \u03c4\u03bf \u03c0\u03c1\u03cc\u03b3\u03c1\u03b1\u03bc\u03bc\u03b1 \u03b1\u03bd\u03b1\u03c0\u03b1\u03c1\u03b1\u03b3\u03c9\u03b3\u03ae\u03c2 \u03c3\u03b1\u03c2 \u03b5\u03c0\u03b9\u03c3\u03c4\u03c1\u03ad\u03c6\u03b5\u03b9 \u03b1\u03c5\u03c4\u03cc\u03bc\u03b1\u03c4\u03b1 \u03c3\u03c4\u03b9\u03c2 \u03bb\u03b5\u03c0\u03c4\u03bf\u03bc\u03ad\u03c1\u03b5\u03b9\u03b5\u03c2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Player returns you to the detail view when a movie or the last episode of a series ends."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El reproductor te devuelve a la vista de detalle cuando termina una pel\u00edcula o el \u00faltimo episodio."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soitin palauttaa sinut tieton\u00e4kym\u00e4\u00e4n, kun elokuva tai sarjan viimeinen jakso p\u00e4\u00e4ttyy."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le lecteur vous ram\u00e8ne \u00e0 la vue d\u00e9tail \u00e0 la fin d'un film ou du dernier \u00e9pisode d'une s\u00e9rie."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reproduktor vas vra\u0107a na pregled detalja kad film ili posljednja epizoda serije zavr\u0161i."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A lej\u00e1tsz\u00f3 visszavisz a r\u00e9szletek n\u00e9zetbe, ha egy film vagy a sorozat utols\u00f3 epiz\u00f3dja v\u00e9get \u00e9r."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il player ti riporta alla schermata dettagli quando un film o l'ultimo episodio finisce."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u6620\u753b\u3084\u30b7\u30ea\u30fc\u30ba\u306e\u6700\u7d42\u8a71\u304c\u7d42\u308f\u308b\u3068\u3001\u30d7\u30ec\u30fc\u30e4\u30fc\u306f\u81ea\u52d5\u7684\u306b\u8a73\u7d30\u753b\u9762\u306b\u623b\u308a\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc601\ud654\ub098 \uc2dc\ub9ac\uc988\uc758 \ub9c8\uc9c0\ub9c9 \uc5d0\ud53c\uc18c\ub4dc\uac00 \ub05d\ub098\uba74 \ud50c\ub808\uc774\uc5b4\uac00 \uc790\ub3d9\uc73c\ub85c \uc0c1\uc138 \ud654\uba74\uc73c\ub85c \ub3cc\uc544\uac11\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spilleren returnerer deg til detaljvisningen n\u00e5r en film eller seriens siste episode slutter."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De speler keert terug naar de detailweergave wanneer een film of laatste aflevering eindigt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odtwarzacz wraca do widoku szczeg\u00f3\u0142\u00f3w po zako\u0144czeniu filmu lub ostatniego odcinka serialu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O player retorna \u00e0 tela de detalhes quando um filme ou o \u00faltimo epis\u00f3dio termina."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O reprodutor regressa ao ecr\u00e3 de detalhes quando um filme ou o \u00faltimo epis\u00f3dio termina."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Playerul te returneaz\u0103 la vizualizarea detaliilor c\u00e2nd un film sau ultimul episod se termin\u0103."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u043b\u0435\u0435\u0440 \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442 \u0432\u0430\u0441 \u043a \u044d\u043a\u0440\u0430\u043d\u0443 \u0434\u0435\u0442\u0430\u043b\u0435\u0439 \u043f\u043e \u043e\u043a\u043e\u043d\u0447\u0430\u043d\u0438\u0438 \u0444\u0438\u043b\u044c\u043c\u0430 \u0438\u043b\u0438 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0435\u0439 \u0441\u0435\u0440\u0438\u0438."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prehr\u00e1va\u010d v\u00e1s vr\u00e1ti sp\u00e4\u0165 na detail po skon\u010den\u00ed filmu alebo poslednej epiz\u00f3dy."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spelaren returnerar dig till detaljvyn n\u00e4r en film eller seriens sista avsnitt slutar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir film veya dizinin son b\u00f6l\u00fcm\u00fc bitti\u011finde oynat\u0131c\u0131 sizi otomatik olarak detay ekran\u0131na d\u00f6nd\u00fcr\u00fcr."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u0440\u043e\u0433\u0440\u0430\u0432\u0430\u0447 \u043f\u043e\u0432\u0435\u0440\u0442\u0430\u0454 \u0432\u0430\u0441 \u0434\u043e \u043f\u0435\u0440\u0435\u0433\u043b\u044f\u0434\u0443 \u0434\u0435\u0442\u0430\u043b\u0435\u0439 \u043f\u043e \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043d\u043d\u0456 \u0444\u0456\u043b\u044c\u043c\u0443 \u0447\u0438 \u043e\u0441\u0442\u0430\u043d\u043d\u044c\u043e\u0433\u043e \u0435\u043f\u0456\u0437\u043e\u0434\u0443 \u0441\u0435\u0440\u0456\u0430\u043b\u0443."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u7535\u5f71\u6216\u5267\u96c6\u6700\u540e\u4e00\u96c6\u7ed3\u675f\u65f6,\u64ad\u653e\u5668\u4f1a\u81ea\u52a8\u8fd4\u56de\u8be6\u60c5\u9875\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u96fb\u5f71\u6216\u5287\u96c6\u6700\u5f8c\u4e00\u96c6\u7d50\u675f\u6642,\u64ad\u653e\u5668\u6703\u81ea\u52d5\u8fd4\u56de\u8a73\u60c5\u9801\u3002"
          }
        }
      }
    },

    "support.unavailable.subtitle" : {
      "comment" : "Explainer under the unavailable card pointing to sandbox testing",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P\u0159ihlaste se pomoc\u00ed testovac\u00edho \u00fa\u010dtu Sandbox nebo po\u010dkejte na schv\u00e1len\u00ed n\u00e1kup\u016f od Applu. Klepnut\u00edm obnovit."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Log ind med en Sandbox Tester-konto, eller vent p\u00e5, at Apple godkender in-app-k\u00f8bene. Tryk for at pr\u00f8ve igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melde dich mit einem Sandbox-Tester-Account an oder warte, bis Apple die In-App-K\u00e4ufe pr\u00fcft. Zum erneuten Versuchen tippen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a3\u03c5\u03bd\u03b4\u03b5\u03b8\u03b5\u03af\u03c4\u03b5 \u03bc\u03b5 \u03bb\u03bf\u03b3\u03b1\u03c1\u03b9\u03b1\u03c3\u03bc\u03cc Sandbox Tester \u03ae \u03c0\u03b5\u03c1\u03b9\u03bc\u03ad\u03bd\u03b5\u03c4\u03b5 \u03bd\u03b1 \u03b5\u03b3\u03ba\u03c1\u03af\u03bd\u03b5\u03b9 \u03b7 Apple \u03c4\u03b9\u03c2 \u03b1\u03b3\u03bf\u03c1\u03ad\u03c2 \u03b5\u03bd\u03c4\u03cc\u03c2 \u03b5\u03c6\u03b1\u03c1\u03bc\u03bf\u03b3\u03ae\u03c2. \u03a0\u03b1\u03c4\u03ae\u03c3\u03c4\u03b5 \u03b3\u03b9\u03b1 \u03b5\u03c0\u03b1\u03bd\u03ac\u03bb\u03b7\u03c8\u03b7."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sign in with a Sandbox Tester account or wait for Apple to approve the in-app purchases. Tap to retry."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicia sesi\u00f3n con una cuenta Sandbox Tester o espera a que Apple apruebe las compras dentro de la app. Toca para reintentar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kirjaudu sis\u00e4\u00e4n Sandbox Tester -tilill\u00e4 tai odota, ett\u00e4 Apple hyv\u00e4ksyy sovelluksen sis\u00e4iset ostot. Napauta yritt\u00e4\u00e4ksesi uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connectez-vous avec un compte Sandbox Tester ou attendez qu'Apple approuve les achats int\u00e9gr\u00e9s. Appuyez pour r\u00e9essayer."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prijavite se putem Sandbox Tester ra\u010duna ili pri\u010dekajte da Apple odobri kupnje unutar aplikacije. Dodirnite za ponovni poku\u0161aj."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jelentkezz be Sandbox Tester fi\u00f3kkal, vagy v\u00e1rj, am\u00edg az Apple j\u00f3v\u00e1hagyja az alkalmaz\u00e1son bel\u00fcli v\u00e1s\u00e1rl\u00e1sokat. \u00c9rints a pr\u00f3b\u00e1lkoz\u00e1shoz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accedi con un account Sandbox Tester o attendi che Apple approvi gli acquisti in-app. Tocca per riprovare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30b5\u30f3\u30c9\u30dc\u30c3\u30af\u30b9\u30c6\u30b9\u30bf\u30fc\u30a2\u30ab\u30a6\u30f3\u30c8\u3067\u30b5\u30a4\u30f3\u30a4\u30f3\u3059\u308b\u304b\u3001Apple\u304c\u30a2\u30d7\u30ea\u5185\u8ab2\u91d1\u3092\u627f\u8a8d\u3059\u308b\u306e\u3092\u5f85\u3063\u3066\u304f\u3060\u3055\u3044\u3002\u30bf\u30c3\u30d7\u3057\u3066\u518d\u8a66\u884c\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sandbox Tester \uacc4\uc815\uc73c\ub85c \ub85c\uadf8\uc778\ud558\uac70\ub098 Apple\uc774 \uc778\uc571 \uad6c\ub9e4\ub97c \uc2b9\uc778\ud560 \ub54c\uae4c\uc9c0 \uae30\ub2e4\ub9ac\uc138\uc694. \ub2e4\uc2dc \uc2dc\ub3c4\ud558\ub824\uba74 \ud0ed\ud558\uc138\uc694."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Logg inn med en Sandbox Tester-konto, eller vent p\u00e5 at Apple godkjenner kj\u00f8pene i appen. Trykk for \u00e5 pr\u00f8ve igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meld je aan met een Sandbox Tester-account of wacht tot Apple de in-app aankopen goedkeurt. Tik om opnieuw te proberen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaloguj si\u0119 za pomoc\u0105 konta Sandbox Tester lub poczekaj, a\u017c Apple zatwierdzi zakupy w aplikacji. Dotknij, aby ponowi\u0107."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entre com uma conta Sandbox Tester ou aguarde a Apple aprovar as compras no app. Toque para tentar novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicie sess\u00e3o com uma conta Sandbox Tester ou aguarde que a Apple aprove as compras na app. Toque para tentar novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecteaz\u0103-te cu un cont Sandbox Tester sau a\u0219teapt\u0103 ca Apple s\u0103 aprobe achizi\u021biile din aplica\u021bie. Atinge pentru a re\u00eencerca."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0412\u043e\u0439\u0434\u0438\u0442\u0435 \u0441 \u0430\u043a\u043a\u0430\u0443\u043d\u0442\u043e\u043c Sandbox Tester \u0438\u043b\u0438 \u0434\u043e\u0436\u0434\u0438\u0442\u0435\u0441\u044c \u043e\u0434\u043e\u0431\u0440\u0435\u043d\u0438\u044f \u0432\u0441\u0442\u0440\u043e\u0435\u043d\u043d\u044b\u0445 \u043f\u043e\u043a\u0443\u043f\u043e\u043a \u043e\u0442 Apple. \u041a\u043e\u0441\u043d\u0438\u0442\u0435\u0441\u044c, \u0447\u0442\u043e\u0431\u044b \u043f\u043e\u0432\u0442\u043e\u0440\u0438\u0442\u044c."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prihl\u00e1ste sa pomocou \u00fa\u010dtu Sandbox Tester alebo po\u010dkajte na schv\u00e1lenie n\u00e1kupov od Applu. Klepnut\u00edm obnov\u00edte."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Logga in med ett Sandbox Tester-konto eller v\u00e4nta p\u00e5 att Apple godk\u00e4nner app-k\u00f6pen. Tryck f\u00f6r att f\u00f6rs\u00f6ka igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sandbox Tester hesab\u0131yla oturum a\u00e7 veya Apple'\u0131n uygulama i\u00e7i sat\u0131n almalar\u0131 onaylamas\u0131n\u0131 bekle. Yeniden denemek i\u00e7in dokun."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0423\u0432\u0456\u0439\u0434\u0456\u0442\u044c \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u043e\u0431\u043b\u0456\u043a\u043e\u0432\u043e\u0433\u043e \u0437\u0430\u043f\u0438\u0441\u0443 Sandbox Tester \u0430\u0431\u043e \u0437\u0430\u0447\u0435\u043a\u0430\u0439\u0442\u0435, \u043f\u043e\u043a\u0438 Apple \u0441\u0445\u0432\u0430\u043b\u0438\u0442\u044c \u043f\u043e\u043a\u0443\u043f\u043a\u0438 \u0432 \u0434\u043e\u0434\u0430\u0442\u043a\u0443. \u0422\u043e\u0440\u043a\u043d\u0456\u0442\u044c\u0441\u044f, \u0449\u043e\u0431 \u043f\u043e\u0432\u0442\u043e\u0440\u0438\u0442\u0438."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",

        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pula o seletor e entra com o perfil padr\u00e3o automaticamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ignora o seletor e inicia sess\u00e3o com o perfil predefinido automaticamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sari peste selector \u0219i conecteaz\u0103-te automat cu profilul implicit."

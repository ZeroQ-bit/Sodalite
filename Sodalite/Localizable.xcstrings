    "changelog.0_4_0.episodeImages.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N\u00e1hledy epizod s vy\u0161\u0161\u00edm rozli\u0161en\u00edm p\u0159es Jellyfin Screen Grabber."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "H\u00f8jere opl\u00f8sning p\u00e5 episodebilleder via Jellyfins Screen Grabber."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "H\u00f6her aufgel\u00f6ste Episoden-Stills \u00fcber den Screen Grabber von Jellyfin."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u039c\u03b9\u03ba\u03c1\u03bf\u03b3\u03c1\u03b1\u03c6\u03af\u03b5\u03c2 \u03b5\u03c0\u03b5\u03b9\u03c3\u03bf\u03b4\u03af\u03c9\u03bd \u03c5\u03c8\u03b7\u03bb\u03cc\u03c4\u03b5\u03c1\u03b7\u03c2 \u03b1\u03bd\u03ac\u03bb\u03c5\u03c3\u03b7\u03c2 \u03bc\u03ad\u03c3\u03c9 \u03c4\u03bf\u03c5 Screen Grabber \u03c4\u03bf\u03c5 Jellyfin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Higher-resolution episode stills via Jellyfin's Screen Grabber image source."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Capturas de episodios con mayor resoluci\u00f3n mediante el Screen Grabber de Jellyfin."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Korkearesoluutioiset jaksokuvat Jellyfinin Screen Grabber -l\u00e4hteell\u00e4."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captures d'\u00e9pisodes en plus haute r\u00e9solution via le Screen Grabber de Jellyfin."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slike epizoda vi\u0161e rezolucije putem Jellyfin Screen Grabbera."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Magasabb felbont\u00e1s\u00fa epiz\u00f3dk\u00e9pek a Jellyfin Screen Grabber k\u00e9pforr\u00e1s\u00e1b\u00f3l."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anteprime episodi a risoluzione pi\u00f9 alta tramite il Screen Grabber di Jellyfin."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jellyfin\u306eScreen Grabber\u304b\u3089\u53d6\u5f97\u3057\u305f\u3001\u3088\u308a\u9ad8\u89e3\u50cf\u5ea6\u306e\u30a8\u30d4\u30bd\u30fc\u30c9\u9759\u6b62\u753b\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jellyfin\uc758 Screen Grabber \uc774\ubbf8\uc9c0 \uc18c\uc2a4\ub97c \ud1b5\ud55c \uace0\ud574\uc0c1\ub3c4 \uc5d0\ud53c\uc18c\ub4dc \uc2a4\ud2f8."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",

    "changelog.0_4_1.backgroundPause.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P\u0159esun aplikace na pozad\u00ed pozastav\u00ed p\u0159ehr\u00e1v\u00e1n\u00ed. P\u0159ep\u00edna\u010d aplikac\u00ed (dvojit\u00fd Home) p\u0159ehr\u00e1v\u00e1n\u00ed nep\u0159eru\u0161\u00ed."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N\u00e5r appen sendes i baggrunden pauses afspilningen. App-skifteren (dobbelt Home) lader den forts\u00e6tte."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn die App in den Hintergrund geht, pausiert die Wiedergabe. Der App-Umschalter (Home-Doppelklick) l\u00e4sst sie weiterlaufen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u038c\u03c4\u03b1\u03bd \u03b7 \u03b5\u03c6\u03b1\u03c1\u03bc\u03bf\u03b3\u03ae \u03c0\u03ac\u03b5\u03b9 \u03c3\u03c4\u03bf \u03c0\u03b1\u03c1\u03b1\u03c3\u03ba\u03ae\u03bd\u03b9\u03bf, \u03b7 \u03b1\u03bd\u03b1\u03c0\u03b1\u03c1\u03b1\u03b3\u03c9\u03b3\u03ae \u03ba\u03ac\u03bd\u03b5\u03b9 \u03c0\u03b1\u03cd\u03c3\u03b7. \u039f \u03b5\u03bd\u03b1\u03bb\u03bb\u03ac\u03ba\u03c4\u03b7\u03c2 \u03b5\u03c6\u03b1\u03c1\u03bc\u03bf\u03b3\u03ce\u03bd (\u03b4\u03b9\u03c0\u03bb\u03cc Home) \u03c4\u03b7\u03bd \u03b1\u03c6\u03ae\u03bd\u03b5\u03b9 \u03bd\u03b1 \u03c3\u03c5\u03bd\u03b5\u03c7\u03af\u03c3\u03b5\u03b9."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backgrounding the app pauses playback. The app switcher (double-Home) leaves it playing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al enviar la app al fondo, la reproducci\u00f3n se pausa. El selector de apps (doble Home) la deja seguir."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sovelluksen siirt\u00e4minen taustalle keskeytt\u00e4\u00e4 toiston. Sovellusvalitsin (kaksoisnapautus Home) ei."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mettre l'app en arri\u00e8re-plan met la lecture en pause. Le s\u00e9lecteur d'apps (double Home) la laisse continuer."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slanje aplikacije u pozadinu pauzira reprodukciju. Preklopnik aplikacija (dvostruki Home) je ne prekida."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az alkalmaz\u00e1s h\u00e1tt\u00e9rbe k\u00fcld\u00e9se sz\u00fcnetelteti a lej\u00e1tsz\u00e1st. Az alkalmaz\u00e1sv\u00e1lt\u00f3 (dupla Home) tov\u00e1bb engedi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mettere l'app in background mette in pausa. Lo switcher app (doppio Home) la lascia in riproduzione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30a2\u30d7\u30ea\u3092\u30d0\u30c3\u30af\u30b0\u30e9\u30a6\u30f3\u30c9\u306b\u3059\u308b\u3068\u518d\u751f\u304c\u4e00\u6642\u505c\u6b62\u3057\u307e\u3059\u3002\u30a2\u30d7\u30ea\u30b9\u30a4\u30c3\u30c1\u30e3\u30fc(Home\u30dc\u30bf\u30f3\u306e\u30c0\u30d6\u30eb\u30af\u30ea\u30c3\u30af)\u3067\u306f\u518d\u751f\u306f\u7d9a\u304d\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc571\uc744 \ubc31\uadf8\ub77c\uc6b4\ub4dc\ub85c \ubcf4\ub0b4\uba74 \uc7ac\uc0dd\uc774 \uc77c\uc2dc \uc815\uc9c0\ub429\ub2c8\ub2e4. \uc571 \uc804\ud658\uae30(Home \ub354\ube14 \ud074\ub9ad)\uc5d0\uc11c\ub294 \uc7ac\uc0dd\uc774 \uacc4\uc18d\ub429\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u00c5 sende appen i bakgrunnen pauser avspillingen. App-velgeren (dobbelt Home) lar den spille videre."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De app naar de achtergrond sturen pauzeert het afspelen. De app-wisselaar (dubbele Home) niet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wys\u0142anie aplikacji w t\u0142o wstrzymuje odtwarzanie. Prze\u0142\u0105cznik aplikacji (podw\u00f3jny Home) nie przerywa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enviar o app para segundo plano pausa a reprodu\u00e7\u00e3o. O alternador de apps (Home duplo) n\u00e3o."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enviar a app para segundo plano pausa a reprodu\u00e7\u00e3o. O alternador de apps (Home duplo) n\u00e3o."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trimiterea aplica\u021biei \u00een fundal pune redarea \u00een pauz\u0103. Comutatorul de aplica\u021bii (Home dublu) o las\u0103 s\u0103 mearg\u0103."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0421\u0432\u043e\u0440\u0430\u0447\u0438\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0432 \u0444\u043e\u043d \u0441\u0442\u0430\u0432\u0438\u0442 \u0432\u043e\u0441\u043f\u0440\u043e\u0438\u0437\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u043d\u0430 \u043f\u0430\u0443\u0437\u0443. \u041f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0430\u0442\u0435\u043b\u044c \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0439 (\u0434\u0432\u043e\u0439\u043d\u043e\u0439 Home) \u2014 \u043d\u0435\u0442."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Presunutie aplik\u00e1cie na pozadie pozastav\u00ed prehr\u00e1vanie. Prep\u00edna\u010d aplik\u00e1ci\u00ed (dvojit\u00fd Home) ho ponech\u00e1."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att l\u00e4gga appen i bakgrunden pausar uppspelningen. App-v\u00e4xlaren (dubbel Home) l\u00e4mnar den ig\u00e5ng."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uygulamay\u0131 arka plana almak oynatmay\u0131 duraklat\u0131r. Uygulama de\u011fi\u015ftirici (\u00e7ift Home) duraklatmaz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0417\u0433\u043e\u0440\u0442\u0430\u043d\u043d\u044f \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u043d\u043a\u0443 \u0443 \u0444\u043e\u043d \u0441\u0442\u0430\u0432\u0438\u0442\u044c \u0432\u0456\u0434\u0442\u0432\u043e\u0440\u0435\u043d\u043d\u044f \u043d\u0430 \u043f\u0430\u0443\u0437\u0443. \u041f\u0435\u0440\u0435\u043c\u0438\u043a\u0430\u0447 \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u043d\u043a\u0456\u0432 (\u043f\u043e\u0434\u0432\u0456\u0439\u043d\u0438\u0439 Home) \u2014 \u043d\u0456."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5c06\u5e94\u7528\u5207\u5230\u540e\u53f0\u4f1a\u6682\u505c\u64ad\u653e\u3002\u5e94\u7528\u5207\u6362\u5668(\u53cc\u51fb Home)\u5219\u7ee7\u7eed\u64ad\u653e\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5c07\u61c9\u7528\u5207\u5230\u80cc\u666f\u6703\u66ab\u505c\u64ad\u653e\u3002\u61c9\u7528\u5207\u63db\u5668(\u96d9\u64ca Home)\u5247\u7e7c\u7e8c\u64ad\u653e\u3002"
          }
        }
      }
    },

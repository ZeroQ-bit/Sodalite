    "support.restore.error" : {
      "comment" : "Status banner when restore throws an error",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obnoven\u00ed se nezda\u0159ilo. Zkuste to pros\u00edm znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",

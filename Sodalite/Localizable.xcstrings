      }
    },
    "changelog.0_4_1.episodePicker.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P\u0159epn\u011bte na libovolnou epizodu aktu\u00e1ln\u00ed sez\u00f3ny bez opou\u0161t\u011bn\u00ed p\u0159ehr\u00e1va\u010de \u2014 s n\u00e1hledy pro ka\u017ed\u00fd \u0159\u00e1dek."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hop til ethvert afsnit af den aktuelle s\u00e6son uden at forlade afspilleren \u2014 med miniaturer for hver r\u00e6kke."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wechsle ohne den Player zu verlassen direkt zu jeder Folge der Staffel \u2014 mit Vorschau-Bild pro Zeile."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u039c\u03b5\u03c4\u03b1\u03b2\u03b5\u03af\u03c4\u03b5 \u03c3\u03b5 \u03bf\u03c0\u03bf\u03b9\u03bf\u03b4\u03ae\u03c0\u03bf\u03c4\u03b5 \u03b5\u03c0\u03b5\u03b9\u03c3\u03cc\u03b4\u03b9\u03bf \u03c4\u03b7\u03c2 \u03c4\u03c1\u03ad\u03c7\u03bf\u03c5\u03c3\u03b1\u03c2 \u03c3\u03b5\u03b6\u03cc\u03bd \u03c7\u03c9\u03c1\u03af\u03c2 \u03bd\u03b1 \u03b2\u03b3\u03b5\u03af\u03c4\u03b5 \u03b1\u03c0\u03cc \u03c4\u03bf \u03c0\u03c1\u03cc\u03b3\u03c1\u03b1\u03bc\u03bc\u03b1 \u2014 \u03bc\u03b5 \u03c0\u03c1\u03bf\u03b5\u03c0\u03b9\u03c3\u03ba\u03cc\u03c0\u03b7\u03c3\u03b7 \u03b1\u03bd\u03ac \u03b3\u03c1\u03b1\u03bc\u03bc\u03ae."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jump to any episode of the current season without leaving the player \u2014 thumbnail preview per row."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salta a cualquier episodio de la temporada actual sin salir del reproductor \u2014 miniatura por fila."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hypp\u00e4\u00e4 nykyisen kauden mille tahansa jaksolle poistumatta soittimesta \u2014 esikatselukuva rivi\u00e4 kohden."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sautez \u00e0 n'importe quel \u00e9pisode de la saison en cours sans quitter le lecteur \u2014 miniature par ligne."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sko\u010dite na bilo koju epizodu trenutne sezone bez napu\u0161tanja reproduktora \u2014 sli\u010dica u svakom redu."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ugr\u00e1s az aktu\u00e1lis \u00e9vad b\u00e1rmelyik epiz\u00f3dj\u00e1ra an\u00e9lk\u00fcl, hogy elhagyn\u00e1d a lej\u00e1tsz\u00f3t \u2014 el\u0151n\u00e9zeti k\u00e9p soronk\u00e9nt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passa a qualsiasi episodio della stagione attuale senza uscire dal player \u2014 miniatura per riga."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30d7\u30ec\u30fc\u30e4\u30fc\u3092\u96e2\u308c\u305a\u306b\u73fe\u5728\u306e\u30b7\u30fc\u30ba\u30f3\u306e\u4efb\u610f\u306e\u30a8\u30d4\u30bd\u30fc\u30c9\u306b\u79fb\u52d5\u3067\u304d\u307e\u3059 \u2014 \u5404\u884c\u306b\u30b5\u30e0\u30cd\u30a4\u30eb\u4ed8\u304d\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\ud50c\ub808\uc774\uc5b4\ub97c \ub5a0\ub098\uc9c0 \uc54a\uace0 \ud604\uc7ac \uc2dc\uc98c\uc758 \uc5b4\ub5a4 \uc5d0\ud53c\uc18c\ub4dc\ub85c\ub4e0 \uc774\ub3d9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4 \u2014 \uac01 \ud589\uc5d0 \uc378\ub124\uc77c \ud45c\uc2dc."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hopp til hvilken som helst episode i den aktuelle sesongen uten \u00e5 forlate spilleren \u2014 miniatyr per rad."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spring naar elke aflevering van het huidige seizoen zonder de speler te verlaten \u2014 miniatuur per rij."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeskocz do dowolnego odcinka aktualnego sezonu bez opuszczania odtwarzacza \u2014 miniatura w ka\u017cdym wierszu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pule para qualquer epis\u00f3dio da temporada atual sem sair do player \u2014 miniatura por linha."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salta para qualquer epis\u00f3dio da temporada atual sem sair do reprodutor \u2014 miniatura por linha."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sari la orice episod al sezonului curent f\u0103r\u0103 a p\u0103r\u0103si playerul \u2014 miniatur\u0103 pe r\u00e2nd."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0430\u0439\u0442\u0435\u0441\u044c \u043d\u0430 \u043b\u044e\u0431\u0443\u044e \u0441\u0435\u0440\u0438\u044e \u0442\u0435\u043a\u0443\u0449\u0435\u0433\u043e \u0441\u0435\u0437\u043e\u043d\u0430, \u043d\u0435 \u0432\u044b\u0445\u043e\u0434\u044f \u0438\u0437 \u043f\u043b\u0435\u0435\u0440\u0430 \u2014 \u043f\u0440\u0435\u0432\u044c\u044e \u0432 \u043a\u0430\u0436\u0434\u043e\u0439 \u0441\u0442\u0440\u043e\u043a\u0435."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sko\u010dte na ktor\u00fako\u013evek epiz\u00f3du aktu\u00e1lnej sez\u00f3ny bez opustenia prehr\u00e1va\u010da \u2014 miniat\u00fara v ka\u017edom riadku."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoppa till vilket avsnitt som helst i nuvarande s\u00e4song utan att l\u00e4mna spelaren \u2014 miniatyr per rad."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oynat\u0131c\u0131dan \u00e7\u0131kmadan mevcut sezonun herhangi bir b\u00f6l\u00fcm\u00fcne atlay\u0131n \u2014 her sat\u0131rda k\u00fc\u00e7\u00fck resim."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u0435\u0440\u0435\u0439\u0434\u0456\u0442\u044c \u0434\u043e \u0431\u0443\u0434\u044c-\u044f\u043a\u043e\u0433\u043e \u0435\u043f\u0456\u0437\u043e\u0434\u0443 \u043f\u043e\u0442\u043e\u0447\u043d\u043e\u0433\u043e \u0441\u0435\u0437\u043e\u043d\u0443, \u043d\u0435 \u0437\u0430\u043b\u0438\u0448\u0430\u044e\u0447\u0438 \u043f\u0440\u043e\u0433\u0440\u0430\u0432\u0430\u0447 \u2014 \u043c\u0456\u043d\u0456\u0430\u0442\u044e\u0440\u0430 \u0432 \u043a\u043e\u0436\u043d\u043e\u043c\u0443 \u0440\u044f\u0434\u043a\u0443."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u65e0\u9700\u79bb\u5f00\u64ad\u653e\u5668\u5373\u53ef\u8df3\u8f6c\u5230\u5f53\u524d\u5b63\u7684\u4efb\u4f55\u4e00\u96c6 \u2014 \u6bcf\u884c\u90fd\u6709\u7f29\u7565\u56fe\u9884\u89c8\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u7121\u9700\u96e2\u958b\u64ad\u653e\u5668\u5373\u53ef\u8df3\u8f49\u5230\u7576\u524d\u5b63\u7684\u4efb\u4f55\u4e00\u96c6 \u2014 \u6bcf\u884c\u90fd\u6709\u7e2e\u5716\u9810\u89bd\u3002"
          }
        }
      }
    },

            "value" : "Jellyfin\u30c0\u30c3\u30b7\u30e5\u30dc\u30fc\u30c9\u3067\u3053\u306e\u30b3\u30fc\u30c9\u3092\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044"

    "support.error" : {
      "comment" : "Status banner when a purchase throws an error",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N\u00e1kup se nezda\u0159il. Zkuste to pros\u00edm znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "K\u00f8b mislykkedes. Pr\u00f8v venligst igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kauf fehlgeschlagen. Bitte erneut versuchen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0397 \u03b1\u03b3\u03bf\u03c1\u03ac \u03b1\u03c0\u03ad\u03c4\u03c5\u03c7\u03b5. \u0394\u03bf\u03ba\u03b9\u03bc\u03ac\u03c3\u03c4\u03b5 \u03be\u03b1\u03bd\u03ac."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Purchase failed. Please try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compra fallida. Int\u00e9ntalo de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osto ep\u00e4onnistui. Yrit\u00e4 uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'achat a \u00e9chou\u00e9. Veuillez r\u00e9essayer."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kupnja nije uspjela. Poku\u0161ajte ponovno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A v\u00e1s\u00e1rl\u00e1s sikertelen. K\u00e9rj\u00fck, pr\u00f3b\u00e1ld \u00fajra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acquisto fallito. Riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8cfc\u5165\u306b\u5931\u6557\u3057\u307e\u3057\u305f\u3002\u3082\u3046\u4e00\u5ea6\u304a\u8a66\u3057\u304f\u3060\u3055\u3044\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uad6c\ub9e4 \uc2e4\ud328. \ub2e4\uc2dc \uc2dc\ub3c4\ud574 \uc8fc\uc138\uc694."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kj\u00f8pet mislyktes. Pr\u00f8v igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aankoop mislukt. Probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zakup nie powi\u00f3d\u0142 si\u0119. Spr\u00f3buj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falha na compra. Tente novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falha na compra. Tente novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Achizi\u021bia a e\u0219uat. \u00cencearc\u0103 din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u043e\u043a\u0443\u043f\u043a\u0430 \u043d\u0435 \u0443\u0434\u0430\u043b\u0430\u0441\u044c. \u041f\u043e\u043f\u0440\u043e\u0431\u0443\u0439\u0442\u0435 \u0441\u043d\u043e\u0432\u0430."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N\u00e1kup zlyhal. Sk\u00faste to znova."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "K\u00f6pet misslyckades. F\u00f6rs\u00f6k igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sat\u0131n alma ba\u015far\u0131s\u0131z oldu. L\u00fctfen tekrar deneyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u043e\u043a\u0443\u043f\u043a\u0430 \u043d\u0435 \u0432\u0434\u0430\u043b\u0430\u0441\u044f. \u0421\u043f\u0440\u043e\u0431\u0443\u0439\u0442\u0435 \u0449\u0435 \u0440\u0430\u0437."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8d2d\u4e70\u5931\u8d25\u3002\u8bf7\u91cd\u8bd5\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8cfc\u8cb7\u5931\u6557\u3002\u8acb\u91cd\u8a66\u3002"
          }
        }
      }
    },
    "support.header.copy" : {
      "comment" : "Main explainer paragraph on the Support Development screen",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite je v\u00e1\u0161niv\u00fd projekt jedn\u00e9 osoby. V\u0161e v aplikaci je a z\u016fstane zdarma. Spropitn\u00e9 a bal\u00ed\u010dek podporovatele jsou voliteln\u00e9 \u2014 pom\u00e1haj\u00ed pokr\u00fdt poplatek Apple Developer a ukazuj\u00ed, \u017ee si pr\u00e1ce v\u00e1\u017e\u00edte."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite er et passionprojekt lavet af \u00e9n person. Alt i appen er og forbliver gratis. Drikkepenge og Supporter-pakken er valgfri \u2014 de hj\u00e6lper med at d\u00e6kke Apple Developer-gebyret og viser, at arbejdet v\u00e6rds\u00e6ttes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite ist ein Ein-Personen-Projekt aus Leidenschaft. Alles in der App bleibt kostenlos. Trinkgelder und das Supporter-Paket sind optional \u2014 sie helfen, die Apple-Developer-Geb\u00fchr zu decken, und zeigen, dass die Arbeit gesch\u00e4tzt wird."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a4\u03bf Sodalite \u03b5\u03af\u03bd\u03b1\u03b9 \u03ad\u03bd\u03b1 \u03ad\u03c1\u03b3\u03bf \u03c0\u03ac\u03b8\u03bf\u03c5\u03c2 \u03b5\u03bd\u03cc\u03c2 \u03b1\u03c4\u03cc\u03bc\u03bf\u03c5. \u038c\u03bb\u03b1 \u03c3\u03c4\u03b7\u03bd \u03b5\u03c6\u03b1\u03c1\u03bc\u03bf\u03b3\u03ae \u03b5\u03af\u03bd\u03b1\u03b9 \u03ba\u03b1\u03b9 \u03c0\u03b1\u03c1\u03b1\u03bc\u03ad\u03bd\u03bf\u03c5\u03bd \u03b4\u03c9\u03c1\u03b5\u03ac\u03bd. \u03a4\u03b1 \u03c6\u03b9\u03bb\u03bf\u03b4\u03c9\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03c4\u03bf \u03a0\u03b1\u03ba\u03ad\u03c4\u03bf \u03a5\u03c0\u03bf\u03c3\u03c4\u03ae\u03c1\u03b9\u03be\u03b7\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03c0\u03c1\u03bf\u03b1\u03b9\u03c1\u03b5\u03c4\u03b9\u03ba\u03ac \u2014 \u03b2\u03bf\u03b7\u03b8\u03bf\u03cd\u03bd \u03bd\u03b1 \u03ba\u03b1\u03bb\u03c5\u03c6\u03b8\u03b5\u03af \u03b7 \u03c3\u03c5\u03bd\u03b4\u03c1\u03bf\u03bc\u03ae Apple Developer \u03ba\u03b1\u03b9 \u03b4\u03b5\u03af\u03c7\u03bd\u03bf\u03c5\u03bd \u03cc\u03c4\u03b9 \u03b7 \u03b4\u03bf\u03c5\u03bb\u03b5\u03b9\u03ac \u03b5\u03ba\u03c4\u03b9\u03bc\u03ac\u03c4\u03b1\u03b9."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite is a one-person passion project. Everything in the app is and stays free. Tips and the Supporter Pack are optional \u2014 they help cover the Apple Developer fee and show that the work is appreciated."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite es un proyecto de pasi\u00f3n hecho por una sola persona. Todo en la app es y sigue siendo gratis. Las propinas y el Pack de Apoyo son opcionales: ayudan a cubrir la cuota de Apple Developer y muestran que se aprecia el trabajo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite on yhden henkil\u00f6n intohimoprojekti. Kaikki sovelluksessa on ja pysyy ilmaisena. Juomarahat ja Tukijapaketti ovat valinnaisia \u2014 ne auttavat kattamaan Apple Developer -maksun ja osoittavat, ett\u00e4 ty\u00f6t\u00e4 arvostetaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite est un projet passion d'une seule personne. Tout dans l'application est et reste gratuit. Les pourboires et le Pack de soutien sont optionnels \u2014 ils aident \u00e0 couvrir les frais Apple Developer et montrent que le travail est appr\u00e9ci\u00e9."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite je strastan projekt jedne osobe. Sve u aplikaciji jest i ostaje besplatno. Napojnice i Podr\u017eavateljski paket su opcionalni \u2014 poma\u017eu pokriti naknadu Apple Developer i pokazuju da se rad cijeni."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Sodalite egyszem\u00e9lyes szenved\u00e9lyprojekt. Az alkalmaz\u00e1sban minden ingyenes \u00e9s az is marad. A borraval\u00f3k \u00e9s a T\u00e1mogat\u00f3i csomag opcion\u00e1lisak \u2014 seg\u00edtenek fedezni az Apple Developer d\u00edjat \u00e9s mutatj\u00e1k, hogy a munk\u00e1t megbecs\u00fclik."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite \u00e8 un progetto di passione di una sola persona. Tutto nell'app \u00e8 e rimane gratuito. Le mance e il Pacchetto Sostenitore sono opzionali \u2014 aiutano a coprire la quota Apple Developer e mostrano che il lavoro \u00e8 apprezzato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite\u306f\u4e00\u4eba\u3067\u4f5c\u3063\u3066\u3044\u308b\u60c5\u71b1\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3067\u3059\u3002\u30a2\u30d7\u30ea\u306e\u6a5f\u80fd\u306f\u3059\u3079\u3066\u7121\u6599\u3067\u3001\u3053\u308c\u304b\u3089\u3082\u7121\u6599\u306e\u307e\u307e\u3067\u3059\u3002\u30c1\u30c3\u30d7\u3068\u30b5\u30dd\u30fc\u30bf\u30fc\u30d1\u30c3\u30af\u306f\u4efb\u610f\u3067\u3059 \u2014 Apple Developer\u624b\u6570\u6599\u306e\u8ca0\u62c5\u3092\u52a9\u3051\u3001\u4f5c\u696d\u3078\u306e\u611f\u8b1d\u3092\u793a\u3059\u305f\u3081\u306e\u3082\u306e\u3067\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite\ub294 \ud55c \uc0ac\ub78c\uc758 \uc5f4\uc815 \ud504\ub85c\uc81d\ud2b8\uc785\ub2c8\ub2e4. \uc571\uc758 \ubaa8\ub4e0 \uae30\ub2a5\uc740 \ubb34\ub8cc\uc774\uba70 \uc55e\uc73c\ub85c\ub3c4 \ubb34\ub8cc\ub85c \uc720\uc9c0\ub429\ub2c8\ub2e4. \ud301\uacfc \uc11c\ud3ec\ud130 \ud329\uc740 \uc120\ud0dd \uc0ac\ud56d\uc73c\ub85c, Apple Developer \uc218\uc218\ub8cc\ub97c \ucda9\ub2f9\ud558\uace0 \uc791\uc5c5\uc5d0 \ub300\ud55c \uac10\uc0ac\ub97c \ud45c\ud604\ud558\ub294 \ub370 \ub3c4\uc6c0\uc774 \ub429\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite er et lidenskapsprosjekt laget av \u00e9n person. Alt i appen er og forblir gratis. Drikkepenger og Supporter-pakken er valgfrie \u2014 de hjelper med \u00e5 dekke Apple Developer-avgiften og viser at arbeidet settes pris p\u00e5."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite is een passieproject van \u00e9\u00e9n persoon. Alles in de app is en blijft gratis. Fooien en het Supporterspakket zijn optioneel \u2014 ze helpen de Apple Developer-vergoeding te dekken en laten zien dat het werk gewaardeerd wordt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite to projekt pasji jednej osoby. Wszystko w aplikacji jest i pozostanie darmowe. Napiwki i Pakiet Wspieraj\u0105cy s\u0105 opcjonalne \u2014 pomagaj\u0105 pokry\u0107 op\u0142at\u0119 Apple Developer i pokazuj\u0105, \u017ce praca jest doceniana."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite \u00e9 um projeto de paix\u00e3o feito por uma s\u00f3 pessoa. Tudo no app \u00e9 e continua gratuito. Gorjetas e o Pacote de Apoio s\u00e3o opcionais \u2014 ajudam a cobrir a taxa do Apple Developer e mostram que o trabalho \u00e9 apreciado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite \u00e9 um projeto de paix\u00e3o feito por uma s\u00f3 pessoa. Tudo na app \u00e9 e continua gratuito. Gorjetas e o Pacote de Apoio s\u00e3o opcionais \u2014 ajudam a cobrir a taxa do Apple Developer e mostram que o trabalho \u00e9 apreciado."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite este un proiect pasional al unei singure persoane. Totul din aplica\u021bie este \u0219i r\u0103m\u00e2ne gratuit. Bac\u0219i\u0219urile \u0219i Pachetul de Sus\u021bin\u0103tor sunt op\u021bionale \u2014 ajut\u0103 la acoperirea taxei Apple Developer \u0219i arat\u0103 c\u0103 munca este apreciat\u0103."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite \u2014 \u044d\u0442\u043e \u043f\u0440\u043e\u0435\u043a\u0442-\u0441\u0442\u0440\u0430\u0441\u0442\u044c \u043e\u0434\u043d\u043e\u0433\u043e \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430. \u0412\u0441\u0451 \u0432 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0438 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e \u0438 \u0442\u0430\u043a\u0438\u043c \u043e\u0441\u0442\u0430\u043d\u0435\u0442\u0441\u044f. \u0427\u0430\u0435\u0432\u044b\u0435 \u0438 \u041f\u0430\u043a\u0435\u0442 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0438 \u043d\u0435\u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u044b \u2014 \u043e\u043d\u0438 \u043f\u043e\u043c\u043e\u0433\u0430\u044e\u0442 \u043f\u043e\u043a\u0440\u044b\u0442\u044c \u043f\u043b\u0430\u0442\u0443 Apple Developer \u0438 \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u044e\u0442, \u0447\u0442\u043e \u0440\u0430\u0431\u043e\u0442\u0430 \u0446\u0435\u043d\u0438\u0442\u0441\u044f."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite je v\u00e1\u0161niv\u00fd projekt jednej osoby. V\u0161etko v aplik\u00e1cii je a zostane zadarmo. Prepitn\u00e9 a Bal\u00ed\u010dek podporovate\u013ea s\u00fa volite\u013en\u00e9 \u2014 pom\u00e1haj\u00fa pokry\u0165 poplatok Apple Developer a ukazuj\u00fa, \u017ee pr\u00e1ca je cenen\u00e1."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite \u00e4r ett passionsprojekt av en enda person. Allt i appen \u00e4r och f\u00f6rblir gratis. Dricks och Supporterpaketet \u00e4r frivilliga \u2014 de hj\u00e4lper till att t\u00e4cka Apple Developer-avgiften och visar att arbetet uppskattas."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite tek ki\u015finin tutku projesidir. Uygulamadaki her \u015fey \u00fccretsizdir ve \u00f6yle kalacakt\u0131r. Bah\u015fi\u015fler ve Destek\u00e7i Paketi iste\u011fe ba\u011fl\u0131d\u0131r \u2014 Apple Developer \u00fccretini kar\u015f\u0131lamaya yard\u0131mc\u0131 olur ve \u00e7al\u0131\u015fman\u0131n takdir edildi\u011fini g\u00f6sterir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite \u2014 \u0446\u0435 \u043f\u0440\u0438\u0441\u0442\u0440\u0430\u0441\u043d\u0438\u0439 \u043f\u0440\u043e\u0454\u043a\u0442 \u043e\u0434\u043d\u0456\u0454\u0457 \u043b\u044e\u0434\u0438\u043d\u0438. \u0412\u0441\u0435 \u0432 \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u043d\u043a\u0443 \u0431\u0435\u0437\u043a\u043e\u0448\u0442\u043e\u0432\u043d\u0435 \u0456 \u0442\u0430\u043a\u0438\u043c \u0437\u0430\u043b\u0438\u0448\u0438\u0442\u044c\u0441\u044f. \u0427\u0430\u0439\u043e\u0432\u0456 \u0442\u0430 \u041f\u0430\u043a\u0435\u0442 \u043f\u0440\u0438\u0445\u0438\u043b\u044c\u043d\u0438\u043a\u0430 \u043d\u0435\u043e\u0431\u043e\u0432'\u044f\u0437\u043a\u043e\u0432\u0456 \u2014 \u0432\u043e\u043d\u0438 \u0434\u043e\u043f\u043e\u043c\u0430\u0433\u0430\u044e\u0442\u044c \u043f\u043e\u043a\u0440\u0438\u0442\u0438 \u043f\u043b\u0430\u0442\u0443 Apple Developer \u0456 \u043f\u043e\u043a\u0430\u0437\u0443\u044e\u0442\u044c, \u0449\u043e \u0440\u043e\u0431\u043e\u0442\u0443 \u0446\u0456\u043d\u0443\u044e\u0442\u044c."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite \u662f\u4e00\u4e2a\u4eba\u7684\u70ed\u60c5\u9879\u76ee\u3002\u5e94\u7528\u4e2d\u7684\u6240\u6709\u529f\u80fd\u90fd\u662f\u514d\u8d39\u7684\uff0c\u4e14\u5c06\u4fdd\u6301\u514d\u8d39\u3002\u5c0f\u8d39\u548c\u652f\u6301\u8005\u5957\u9910\u662f\u53ef\u9009\u7684\u2014\u2014\u5b83\u4eec\u6709\u52a9\u4e8e\u652f\u4ed8 Apple Developer \u8d39\u7528\uff0c\u5e76\u8868\u660e\u8fd9\u9879\u5de5\u4f5c\u53d7\u5230\u8d5e\u8d4f\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sodalite \u662f\u4e00\u500b\u4eba\u7684\u71b1\u60c5\u5c08\u6848\u3002\u61c9\u7528\u7a0b\u5f0f\u4e2d\u7684\u6240\u6709\u529f\u80fd\u90fd\u662f\u514d\u8cbb\u7684\uff0c\u4e26\u5c07\u4fdd\u6301\u514d\u8cbb\u3002\u5c0f\u8cbb\u548c\u652f\u6301\u8005\u5957\u88dd\u662f\u53ef\u9078\u7684\u2014\u2014\u5b83\u5011\u6709\u52a9\u65bc\u652f\u4ed8 Apple Developer \u8cbb\u7528\uff0c\u4e26\u8868\u660e\u9019\u9805\u5de5\u4f5c\u53d7\u5230\u8b9a\u8cde\u3002"
          }
        }
      }
    },

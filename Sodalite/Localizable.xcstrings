    "settings.playback.subtitle.delay.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Posune titulky v\u016f\u010di zvuku. Z\u00e1porn\u00e9 hodnoty je zobraz\u00ed d\u0159\u00edv."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forskyder underteksterne i forhold til lyden. Negativ = f\u00f8r, positiv = efter."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verschiebt Untertitel relativ zum Ton. Minus = fr\u00fcher, Plus = sp\u00e4ter."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u039c\u03b5\u03c4\u03b1\u03ba\u03b9\u03bd\u03b5\u03af \u03c4\u03bf\u03c5\u03c2 \u03c5\u03c0\u03cc\u03c4\u03b9\u03c4\u03bb\u03bf\u03c5\u03c2 \u03c9\u03c2 \u03c0\u03c1\u03bf\u03c2 \u03c4\u03bf\u03bd \u03ae\u03c7\u03bf. \u0391\u03c1\u03bd\u03b7\u03c4\u03b9\u03ba\u03cc = \u03bd\u03c9\u03c1\u03af\u03c4\u03b5\u03c1\u03b1, \u03b8\u03b5\u03c4\u03b9\u03ba\u03cc = \u03b1\u03c1\u03b3\u03cc\u03c4\u03b5\u03c1\u03b1."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shifts subtitles relative to audio. Negative = earlier, positive = later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desplaza los subt\u00edtulos respecto al audio. Negativo = antes, positivo = despu\u00e9s."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siirt\u00e4\u00e4 tekstitykset suhteessa \u00e4\u00e4neen. Miinus = aikaisempi, plus = my\u00f6hempi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "D\u00e9cale les sous-titres par rapport \u00e0 l'audio. N\u00e9gatif = avant, positif = apr\u00e8s."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pomi\u010de titlove u odnosu na zvuk. Negativno = ranije, pozitivno = kasnije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eltolja a feliratot a hanghoz k\u00e9pest. Negat\u00edv = el\u0151bb, pozit\u00edv = k\u00e9s\u0151bb."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sposta i sottotitoli rispetto all'audio. Negativo = prima, positivo = dopo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u97f3\u58f0\u306b\u5bfe\u3057\u3066\u5b57\u5e55\u3092\u305a\u3089\u3057\u307e\u3059\u3002\u30de\u30a4\u30ca\u30b9=\u65e9\u304f\u3001\u30d7\u30e9\u30b9=\u9045\u304f\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc624\ub514\uc624\ub97c \uae30\uc900\uc73c\ub85c \uc790\ub9c9 \uc2dc\uc810\uc744 \uc774\ub3d9\ud569\ub2c8\ub2e4. \uc74c\uc218 = \ub354 \ube68\ub9ac, \uc591\uc218 = \ub354 \ub2a6\uac8c."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forskyver tekstene i forhold til lyden. Negativ = tidligere, positiv = senere."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verschuift ondertitels ten opzichte van het geluid. Negatief = eerder, positief = later."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przesuwa napisy wzgl\u0119dem d\u017awi\u0119ku. Warto\u015bci ujemne = wcze\u015bniej, dodatnie = p\u00f3\u017aniej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desloca as legendas em rela\u00e7\u00e3o ao \u00e1udio. Negativo = antes, positivo = depois."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desloca as legendas em rela\u00e7\u00e3o ao \u00e1udio. Negativo = antes, positivo = depois."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decaleaz\u0103 subtitr\u0103rile fa\u021b\u0103 de audio. Negativ = mai devreme, pozitiv = mai t\u00e2rziu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0421\u043c\u0435\u0449\u0430\u0435\u0442 \u0441\u0443\u0431\u0442\u0438\u0442\u0440\u044b \u043e\u0442\u043d\u043e\u0441\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u0437\u0432\u0443\u043a\u0430. \u041c\u0438\u043d\u0443\u0441 \u2014 \u0440\u0430\u043d\u044c\u0448\u0435, \u043f\u043b\u044e\u0441 \u2014 \u043f\u043e\u0437\u0436\u0435."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Posunie titulky vo\u010di zvuku. Z\u00e1porn\u00e9 = sk\u00f4r, kladn\u00e9 = nesk\u00f4r."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "F\u00f6rskjuter undertexter mot ljudet. Negativ = tidigare, positiv = senare."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Altyaz\u0131lar\u0131 sese g\u00f6re kayd\u0131r\u0131r. Negatif = daha erken, pozitif = daha ge\u00e7."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0417\u043c\u0456\u0449\u0443\u0454 \u0441\u0443\u0431\u0442\u0438\u0442\u0440\u0438 \u0432\u0456\u0434\u043d\u043e\u0441\u043d\u043e \u0437\u0432\u0443\u043a\u0443. \u041c\u0456\u043d\u0443\u0441 \u2014 \u0440\u0430\u043d\u0456\u0448\u0435, \u043f\u043b\u044e\u0441 \u2014 \u043f\u0456\u0437\u043d\u0456\u0448\u0435."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u76f8\u5bf9\u97f3\u9891\u504f\u79fb\u5b57\u5e55\u65f6\u95f4\u3002\u8d1f\u503c=\u66f4\u65e9,\u6b63\u503c=\u66f4\u665a\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u76f8\u5c0d\u97f3\u8a0a\u504f\u79fb\u5b57\u5e55\u6642\u9593\u3002\u8ca0\u503c=\u66f4\u65e9,\u6b63\u503c=\u66f4\u665a\u3002"
          }
        }
      }
    },

    "changelog.0_4_1.polishFixes.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Robustn\u011bj\u0161\u00ed na\u010d\u00edt\u00e1n\u00ed titulk\u016f u 4K soubor\u016f, \u010diteln\u00e9 tla\u010d\u00edtka s vlastn\u00ed akcentn\u00ed barvou, automatick\u00e9 titulky p\u0159i p\u0159ep\u00edn\u00e1n\u00ed zvuku a dal\u0161\u00ed \u00fapravy fokusu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mere robust undertekstindl\u00e6sning p\u00e5 store 4K-containere, l\u00e6sbare tonede knapper, auto-undertekster ved manuelt lydskifte og diverse fokus-rettelser."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Robusteres Laden von Untertiteln bei gro\u00dfen 4K-Containern, lesbare Akzent-Buttons, automatische Untertitel beim Audio-Wechsel und diverse Focus-Fixes."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a0\u03b9\u03bf \u03b1\u03bd\u03b8\u03b5\u03ba\u03c4\u03b9\u03ba\u03ae \u03c6\u03cc\u03c1\u03c4\u03c9\u03c3\u03b7 \u03c5\u03c0\u03bf\u03c4\u03af\u03c4\u03bb\u03c9\u03bd \u03c3\u03b5 \u03bc\u03b5\u03b3\u03ac\u03bb\u03b1 4K \u03b1\u03c1\u03c7\u03b5\u03af\u03b1, \u03b5\u03c5\u03b1\u03bd\u03ac\u03b3\u03bd\u03c9\u03c3\u03c4\u03b1 \u03ba\u03bf\u03c5\u03bc\u03c0\u03b9\u03ac \u03bc\u03b5 \u03c7\u03c1\u03ce\u03bc\u03b1 \u03ad\u03bc\u03c6\u03b1\u03c3\u03b7\u03c2, \u03b1\u03c5\u03c4\u03cc\u03bc\u03b1\u03c4\u03bf\u03b9 \u03c5\u03c0\u03cc\u03c4\u03b9\u03c4\u03bb\u03bf\u03b9 \u03c3\u03b5 \u03b1\u03bb\u03bb\u03b1\u03b3\u03ae \u03ae\u03c7\u03bf\u03c5, \u03ba\u03b1\u03b9 \u03b4\u03b9\u03bf\u03c1\u03b8\u03ce\u03c3\u03b5\u03b9\u03c2 \u03b5\u03c3\u03c4\u03af\u03b1\u03c3\u03b7\u03c2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subtitle loading more resilient on big 4K containers, accent-tint buttons readable, auto-subs fire on manual audio switch, plus various focus fixes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carga de subt\u00edtulos m\u00e1s resistente en archivos 4K grandes, botones con color de acento legibles, auto-subs al cambiar audio y varios arreglos de foco."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekstitysten lataus kest\u00e4v\u00e4mpi suurissa 4K-tiedostoissa, korostusv\u00e4riset painikkeet luettavissa, auto-tekstitykset toimivat manuaalisessa \u00e4\u00e4nenvaihdossa ja erilaisia kohdistuskorjauksia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chargement de sous-titres plus robuste sur les gros conteneurs 4K, boutons accent-teint\u00e9s lisibles, auto-sous-titres au changement audio manuel, et divers correctifs de focus."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otpornije u\u010ditavanje titlova na velikim 4K spremnicima, \u010ditljivi gumbi s nagla\u0161enom bojom, automatski titlovi pri ru\u010dnoj promjeni zvuka, i razne ispravke fokusa."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kitart\u00f3bb felirat-bet\u00f6lt\u00e9s nagy 4K f\u00e1jlokon, olvashat\u00f3 kiemel\u0151sz\u00edn\u0171 gombok, automatikus feliratok k\u00e9zi hangv\u00e1lt\u00e1skor \u00e9s k\u00fcl\u00f6nf\u00e9le f\u00f3kusz-jav\u00edt\u00e1sok."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caricamento sottotitoli pi\u00f9 robusto su grandi contenitori 4K, pulsanti con colore accento leggibili, auto-sub al cambio audio manuale e varie correzioni di focus."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5927\u304d\u306a4K\u30b3\u30f3\u30c6\u30ca\u3067\u306e\u5b57\u5e55\u8aad\u307f\u8fbc\u307f\u304c\u3088\u308a\u5805\u7262\u306b\u3001\u30a2\u30af\u30bb\u30f3\u30c8\u8272\u306e\u30dc\u30bf\u30f3\u304c\u8aad\u307f\u3084\u3059\u304f\u3001\u624b\u52d5\u30aa\u30fc\u30c7\u30a3\u30aa\u5207\u66ff\u6642\u306e\u81ea\u52d5\u5b57\u5e55\u3001\u305d\u306e\u4ed6\u30d5\u30a9\u30fc\u30ab\u30b9\u4fee\u6b63\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\ud070 4K \ucee8\ud14c\uc774\ub108\uc5d0\uc11c \uc790\ub9c9 \ub85c\ub529\uc774 \ub354 \uacac\uace0\ud574\uc9c0\uace0, \uac15\uc870\uc0c9 \ubc84\ud2bc\uc774 \uc77d\uae30 \uc26c\uc6cc\uc9c0\uba70, \uc218\ub3d9 \uc624\ub514\uc624 \uc804\ud658 \uc2dc \uc790\ub3d9 \uc790\ub9c9\uc774 \uc791\ub3d9\ud558\uace0, \ub2e4\uc591\ud55c \ud3ec\ucee4\uc2a4 \uc218\uc815."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mer robust tekstingsinnlasting p\u00e5 store 4K-containere, lesbare aksent-knapper, auto-tekst ved manuelt lydskifte og diverse fokus-rettelser."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Robuustere ondertitelladen bij grote 4K-bestanden, leesbare accent-knoppen, auto-ondertitels bij handmatige audio-wissel, plus diverse focusfixes."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wytrwalsze \u0142adowanie napis\u00f3w dla du\u017cych plik\u00f3w 4K, czytelne przyciski w kolorze akcentu, automatyczne napisy przy r\u0119cznej zmianie \u015bcie\u017cki audio, oraz r\u00f3\u017cne poprawki fokusu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carregamento de legendas mais resiliente em arquivos 4K grandes, bot\u00f5es coloridos leg\u00edveis, auto-legendas ao trocar \u00e1udio manualmente, e v\u00e1rias corre\u00e7\u00f5es de foco."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carregamento de legendas mais resiliente em ficheiros 4K grandes, bot\u00f5es com cor de destaque leg\u00edveis, auto-legendas ao mudar \u00e1udio manualmente, e v\u00e1rias corre\u00e7\u00f5es de foco."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u00cenc\u0103rcare mai robust\u0103 a subtitr\u0103rilor pe containere 4K mari, butoane cu nuan\u021b\u0103 accent lizibile, sub-uri automate la schimbarea audio manual\u0103, \u0219i diverse corecturi de focus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0411\u043e\u043b\u0435\u0435 \u0443\u0441\u0442\u043e\u0439\u0447\u0438\u0432\u0430\u044f \u0437\u0430\u0433\u0440\u0443\u0437\u043a\u0430 \u0441\u0443\u0431\u0442\u0438\u0442\u0440\u043e\u0432 \u0434\u043b\u044f \u0431\u043e\u043b\u044c\u0448\u0438\u0445 4K-\u0444\u0430\u0439\u043b\u043e\u0432, \u0447\u0438\u0442\u0430\u0435\u043c\u044b\u0435 \u043a\u043d\u043e\u043f\u043a\u0438 \u0441 \u0430\u043a\u0446\u0435\u043d\u0442\u043d\u044b\u043c \u0446\u0432\u0435\u0442\u043e\u043c, \u0430\u0432\u0442\u043e-\u0441\u0443\u0431\u0442\u0438\u0442\u0440\u044b \u043f\u0440\u0438 \u0440\u0443\u0447\u043d\u043e\u043c \u043f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0438 \u0437\u0432\u0443\u043a\u0430 \u0438 \u0440\u0430\u0437\u043d\u044b\u0435 \u043f\u0440\u0430\u0432\u043a\u0438 \u0444\u043e\u043a\u0443\u0441\u0430."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odolnej\u0161ie na\u010d\u00edtanie titulkov pri ve\u013ek\u00fdch 4K s\u00faboroch, \u010ditate\u013en\u00e9 tla\u010didl\u00e1 s akcentovou farbou, automatick\u00e9 titulky pri ru\u010dnej zmene zvuku, a r\u00f4zne opravy fokusu."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mer robust undertextladdning p\u00e5 stora 4K-filer, l\u00e4sbara accentf\u00e4rgade knappar, auto-undertext vid manuellt ljudbyte och diverse fokusfixar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B\u00fcy\u00fck 4K dosyalar\u0131nda daha dayan\u0131kl\u0131 altyaz\u0131 y\u00fcklemesi, vurgu rengi okunabilir d\u00fc\u011fmeler, manuel ses de\u011fi\u015ftirmede otomatik altyaz\u0131lar ve \u00e7e\u015fitli odak d\u00fczeltmeleri."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0421\u0442\u0456\u0439\u043a\u0456\u0448\u0435 \u0437\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0435\u043d\u043d\u044f \u0441\u0443\u0431\u0442\u0438\u0442\u0440\u0456\u0432 \u0434\u043b\u044f \u0432\u0435\u043b\u0438\u043a\u0438\u0445 4K-\u0444\u0430\u0439\u043b\u0456\u0432, \u0447\u0438\u0442\u0430\u0431\u0435\u043b\u044c\u043d\u0456 \u043a\u043d\u043e\u043f\u043a\u0438 \u0437 \u043a\u043e\u043b\u044c\u043e\u0440\u043e\u043c \u0430\u043a\u0446\u0435\u043d\u0442\u0443, \u0430\u0432\u0442\u043e\u0441\u0443\u0431\u0442\u0438\u0442\u0440\u0438 \u043f\u0440\u0438 \u0440\u0443\u0447\u043d\u043e\u043c\u0443 \u043f\u0435\u0440\u0435\u043c\u0438\u043a\u0430\u043d\u043d\u0456 \u0437\u0432\u0443\u043a\u0443, \u0442\u0430 \u0440\u0456\u0437\u043d\u0456 \u043f\u0440\u0430\u0432\u043a\u0438 \u0444\u043e\u043a\u0443\u0441\u0443."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5927\u578b 4K \u6587\u4ef6\u4e0a\u5b57\u5e55\u52a0\u8f7d\u66f4\u7a33\u5065,\u5f3a\u8c03\u8272\u6309\u94ae\u6062\u590d\u53ef\u8bfb,\u624b\u52a8\u5207\u6362\u97f3\u8f68\u65f6\u81ea\u52a8\u542f\u7528\u5b57\u5e55,\u4ee5\u53ca\u591a\u9879\u7126\u70b9\u4fee\u590d\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5927\u578b 4K \u6a94\u6848\u4e0a\u5b57\u5e55\u8f09\u5165\u66f4\u7a69\u5065,\u5f37\u8abf\u8272\u6309\u9215\u6062\u5fa9\u53ef\u8b80,\u624b\u52d5\u5207\u63db\u97f3\u8ecc\u6642\u81ea\u52d5\u555f\u7528\u5b57\u5e55,\u4ee5\u53ca\u591a\u9805\u7126\u9ede\u4fee\u5fa9\u3002"
          }
        }
      }
    },

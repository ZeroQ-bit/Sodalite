            "value" : "\u0394\u03b5\u03bd \u03b5\u03bc\u03c6\u03b1\u03bd\u03af\u03b6\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c7\u03c1\u03ae\u03c3\u03c4\u03b5\u03c2 \u03b1\u03c0\u03cc \u03c4\u03bf\u03bd \u03b4\u03b9\u03b1\u03ba\u03bf\u03bc\u03b9\u03c3\u03c4\u03ae. \u03a3\u03c5\u03bd\u03b4\u03b5\u03b8\u03b5\u03af\u03c4\u03b5 \u03c7\u03b5\u03b9\u03c1\u03bf\u03ba\u03af\u03bd\u03b7\u03c4\u03b1."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No users visible from the server. Sign in manually instead."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No hay usuarios visibles del servidor. Inicia sesi\u00f3n manualmente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Palvelimelta ei n\u00e4y k\u00e4ytt\u00e4ji\u00e4. Kirjaudu sis\u00e4\u00e4n manuaalisesti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucun utilisateur visible depuis le serveur. Connectez-vous manuellement."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sa servera nisu vidljivi korisnici. Prijavite se ru\u010dno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nincsenek l\u00e1that\u00f3 felhaszn\u00e1l\u00f3k a szerveren. Jelentkezz be k\u00e9zzel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nessun utente visibile dal server. Accedi manualmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30b5\u30fc\u30d0\u30fc\u304b\u3089\u8868\u793a\u3067\u304d\u308b\u30e6\u30fc\u30b6\u30fc\u304c\u3044\u307e\u305b\u3093\u3002\u624b\u52d5\u3067\u30b5\u30a4\u30f3\u30a4\u30f3\u3057\u3066\u304f\u3060\u3055\u3044\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc11c\ubc84\uc5d0\uc11c \ud45c\uc2dc \uac00\ub2a5\ud55c \uc0ac\uc6a9\uc790\uac00 \uc5c6\uc2b5\ub2c8\ub2e4. \uc218\ub3d9\uc73c\ub85c \ub85c\uadf8\uc778\ud558\uc138\uc694."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen brukere er synlige fra serveren. Logg inn manuelt i stedet."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geen gebruikers zichtbaar vanaf de server. Meld je handmatig aan."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak widocznych u\u017cytkownik\u00f3w z serwera. Zaloguj si\u0119 r\u0119cznie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nenhum usu\u00e1rio vis\u00edvel no servidor. Entre manualmente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nenhum utilizador vis\u00edvel no servidor. Inicie sess\u00e3o manualmente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niciun utilizator vizibil de pe server. Conecteaz\u0103-te manual."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0438 \u043d\u0430 \u0441\u0435\u0440\u0432\u0435\u0440\u0435 \u043d\u0435 \u043e\u0442\u043e\u0431\u0440\u0430\u0436\u0430\u044e\u0442\u0441\u044f. \u0412\u043e\u0439\u0434\u0438\u0442\u0435 \u0432\u0440\u0443\u0447\u043d\u0443\u044e."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zo servera nie s\u00fa vidite\u013en\u00ed \u017eiadni pou\u017e\u00edvatelia. Prihl\u00e1ste sa manu\u00e1lne."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inga anv\u00e4ndare synliga fr\u00e5n servern. Logga in manuellt ist\u00e4llet."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sunucudan g\u00f6r\u00fcn\u00fcr kullan\u0131c\u0131 yok. Manuel olarak giri\u015f yap."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041d\u0430 \u0441\u0435\u0440\u0432\u0435\u0440\u0456 \u043d\u0435 \u0432\u0438\u0434\u043d\u043e \u043a\u043e\u0440\u0438\u0441\u0442\u0443\u0432\u0430\u0447\u0456\u0432. \u0423\u0432\u0456\u0439\u0434\u0456\u0442\u044c \u0432\u0440\u0443\u0447\u043d\u0443."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u670d\u52a1\u5668\u4e2d\u6ca1\u6709\u53ef\u89c1\u7528\u6237\u3002\u8bf7\u624b\u52a8\u767b\u5f55\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {

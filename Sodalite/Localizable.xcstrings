    "profile.forget.message" : {
      "comment" : "Explanatory text under the forget-profile confirm dialog",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P\u0159i p\u0159\u00ed\u0161t\u00edm v\u00fdb\u011bru tohoto profilu se budete muset znovu p\u0159ihl\u00e1sit."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du skal logge ind igen n\u00e6ste gang du v\u00e6lger denne profil."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du musst dich erneut anmelden, wenn du dieses Profil das n\u00e4chste Mal ausw\u00e4hlst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0398\u03b1 \u03c7\u03c1\u03b5\u03b9\u03b1\u03c3\u03c4\u03b5\u03af \u03bd\u03b1 \u03c3\u03c5\u03bd\u03b4\u03b5\u03b8\u03b5\u03af\u03c4\u03b5 \u03be\u03b1\u03bd\u03ac \u03c4\u03b7\u03bd \u03b5\u03c0\u03cc\u03bc\u03b5\u03bd\u03b7 \u03c6\u03bf\u03c1\u03ac \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03b5\u03c0\u03b9\u03bb\u03ad\u03be\u03b5\u03c4\u03b5 \u03b1\u03c5\u03c4\u03cc \u03c4\u03bf \u03c0\u03c1\u03bf\u03c6\u03af\u03bb."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You'll need to sign in again the next time you pick this profile."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tendr\u00e1s que iniciar sesi\u00f3n de nuevo la pr\u00f3xima vez que elijas este perfil."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sinun t\u00e4ytyy kirjautua uudelleen sis\u00e4\u00e4n, kun valitset t\u00e4m\u00e4n profiilin seuraavan kerran."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous devrez vous reconnecter la prochaine fois que vous choisirez ce profil."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Morat \u0107ete se ponovno prijaviti sljede\u0107i put kad odaberete ovaj profil."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A profil k\u00f6vetkez\u0151 kiv\u00e1laszt\u00e1sakor \u00fajra be kell jelentkezned."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dovrai accedere di nuovo la prossima volta che scegli questo profilo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u6b21\u56de\u3053\u306e\u30d7\u30ed\u30d5\u30a1\u30a4\u30eb\u3092\u9078\u3076\u3068\u304d\u306f\u3001\u518d\u5ea6\u30b5\u30a4\u30f3\u30a4\u30f3\u304c\u5fc5\u8981\u3067\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc774 \ud504\ub85c\ud544\uc744 \ub2e4\uc2dc \uc120\ud0dd\ud560 \ub54c \ub2e4\uc2dc \ub85c\uadf8\uc778\ud574\uc57c \ud569\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du m\u00e5 logge inn p\u00e5 nytt neste gang du velger denne profilen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je moet opnieuw inloggen de volgende keer dat je dit profiel kiest."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nast\u0119pnym razem po wybraniu tego profilu trzeba b\u0119dzie zalogowa\u0107 si\u0119 ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voc\u00ea precisar\u00e1 entrar novamente na pr\u00f3xima vez que escolher este perfil."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ter\u00e1 de iniciar sess\u00e3o novamente da pr\u00f3xima vez que escolher este perfil."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Va trebui s\u0103 te conectezi din nou data viitoare c\u00e2nd alegi acest profil."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u0440\u0438 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u043c \u0432\u044b\u0431\u043e\u0440\u0435 \u044d\u0442\u043e\u0433\u043e \u043f\u0440\u043e\u0444\u0438\u043b\u044f \u043f\u043e\u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044f \u0432\u043e\u0439\u0442\u0438 \u0437\u0430\u043d\u043e\u0432\u043e."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pri \u010fal\u0161om v\u00fdbere tohto profilu sa budete musie\u0165 znova prihl\u00e1si\u0165."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du m\u00e5ste logga in igen n\u00e4sta g\u00e5ng du v\u00e4ljer den h\u00e4r profilen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu profili bir dahaki sefere se\u00e7ti\u011finde tekrar oturum a\u00e7man gerekecek."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0412\u0430\u043c \u0434\u043e\u0432\u0435\u0434\u0435\u0442\u044c\u0441\u044f \u0432\u0432\u0456\u0439\u0442\u0438 \u0437\u043d\u043e\u0432\u0443, \u043a\u043e\u043b\u0438 \u043d\u0430\u0441\u0442\u0443\u043f\u043d\u043e\u0433\u043e \u0440\u0430\u0437\u0443 \u0432\u0438\u0431\u0435\u0440\u0435\u0442\u0435 \u0446\u0435\u0439 \u043f\u0440\u043e\u0444\u0456\u043b\u044c."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u4e0b\u6b21\u9009\u62e9\u6b64\u914d\u7f6e\u6587\u4ef6\u65f6\u9700\u8981\u91cd\u65b0\u767b\u5f55\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u4e0b\u6b21\u9078\u64c7\u6b64\u8a2d\u5b9a\u6a94\u6642\u9700\u8981\u91cd\u65b0\u767b\u5165\u3002"
          }
        }
      }
    },

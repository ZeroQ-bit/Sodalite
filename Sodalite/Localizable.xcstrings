            "value" : "Presko\u010di\u0165 v\u00fdber a automaticky prihl\u00e1si\u0165 predvolen\u00fd profil."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoppa \u00f6ver v\u00e4ljaren och logga in som standardprofilen automatiskt."

    "auth.quickConnect.instruction" : {
      "comment" : "Instruction text for Quick Connect code",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro autorizaci zadejte tento k\u00f3d na panelu Jellyfin"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indtast denne kode i dit Jellyfin-dashboard"

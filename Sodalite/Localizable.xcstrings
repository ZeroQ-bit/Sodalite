    "changelog.0_4_0.siri.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0158ekn\u011bte \u201eOtev\u0159i Sodalite\u201c Siri Remote, iPhonu nebo HomePodu. Dostupn\u00e9 ve 26 jazyc\u00edch."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sig \u201e\u00c5bn Sodalite\u201c til Siri-fjernbetjeningen, iPhone eller HomePod. Tilg\u00e6ngelig p\u00e5 26 sprog."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sag \u201eSodalite \u00f6ffnen\u201c zur Siri Remote, zum iPhone oder zum HomePod. Verf\u00fcgbar in 26 Sprachen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a0\u03b5\u03af\u03c4\u03b5 \u201e\u0386\u03bd\u03bf\u03b9\u03be\u03b5 \u03c4\u03bf Sodalite\u201c \u03c3\u03c4\u03bf Siri Remote, \u03c3\u03c4\u03bf iPhone \u03ae \u03c3\u03c4\u03bf HomePod. \u0394\u03b9\u03b1\u03b8\u03ad\u03c3\u03b9\u03bc\u03bf \u03c3\u03b5 26 \u03b3\u03bb\u03ce\u03c3\u03c3\u03b5\u03c2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Say \u201cOpen Sodalite\u201d to the Siri Remote, iPhone, or HomePod. Available in 26 languages."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Di \u00abAbrir Sodalite\u00bb al mando Siri, al iPhone o al HomePod. Disponible en 26 idiomas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sano \u201eAvaa Sodalite\u201c Siri-kaukos\u00e4\u00e4timelle, iPhonelle tai HomePodille. Saatavilla 26 kielell\u00e4."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dites \u00ab Ouvre Sodalite \u00bb \u00e0 la Siri Remote, \u00e0 l\u2019iPhone ou au HomePod. Disponible en 26 langues."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recite \u201eOtvori Sodalite\u201c Siri Remoteu, iPhoneu ili HomePodu. Dostupno na 26 jezika."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mondd: \u201eNyisd meg a Sodalite appot\u201c a Siri Remote-nak, iPhone-nak vagy HomePodnak. 26 nyelven el\u00e9rhet\u0151."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "D\u00ec \u00abApri Sodalite\u00bb al Siri Remote, all\u2019iPhone o all\u2019HomePod. Disponibile in 26 lingue."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri Remote\u3001iPhone\u3001HomePod\u306b\u300cSodalite\u3092\u958b\u304f\u300d\u3068\u8a71\u3057\u304b\u3051\u3066\u304f\u3060\u3055\u3044\u300226\u8a00\u8a9e\u3067\u5229\u7528\u53ef\u80fd\u3002"

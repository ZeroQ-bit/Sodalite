          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sla de kiezer over en log automatisch in als het standaardprofiel."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pomi\u0144 selektor i zaloguj si\u0119 automatycznie jako profil domy\u015blny."

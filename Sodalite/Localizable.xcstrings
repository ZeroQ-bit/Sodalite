        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gib diesen Code in deinem Jellyfin-Dashboard ein"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0395\u03b9\u03c3\u03b1\u03b3\u03ac\u03b3\u03b5\u03c4\u03b5 \u03b1\u03c5\u03c4\u03cc\u03bd \u03c4\u03bf\u03bd \u03ba\u03c9\u03b4\u03b9\u03ba\u03cc \u03c3\u03c4\u03bf\u03bd \u03c0\u03af\u03bd\u03b1\u03ba\u03b1 Jellyfin \u03b3\u03b9\u03b1 \u03b5\u03be\u03bf\u03c5\u03c3\u03b9\u03bf\u03b4\u03cc\u03c4\u03b7\u03c3\u03b7"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enter this code in your Jellyfin dashboard to authorize"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Introduce este c\u00f3digo en tu panel de Jellyfin"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sy\u00f6t\u00e4 t\u00e4m\u00e4 koodi Jellyfin-hallintapaneelissa valtuuttaaksesi"

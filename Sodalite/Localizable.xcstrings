    "changelog.0_5_0.foregroundReload.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N\u00e1vrat z pozad\u00ed p\u0159ist\u00e1v\u00e1 p\u0159\u00edmo na obnoven\u00e9m sn\u00edmku m\u00edsto \u010dern\u00e9ho z\u00e1blesku \u2014 engine te\u010f p\u0159ed pozastaven\u00edm \u010dek\u00e1 na prvn\u00ed dek\u00f3dovan\u00fd sn\u00edmek."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "At vende tilbage fra baggrunden lander p\u00e5 det faktiske genoptagne billede i stedet for et sort blink \u2014 motoren venter nu p\u00e5 det f\u00f8rste afkodede billede, f\u00f8r den paus\u00e9r."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die R\u00fcckkehr aus dem Hintergrund landet jetzt direkt am Resume-Frame statt auf Schwarz \u2014 die Engine wartet auf das erste dekodierte Bild, bevor sie pausiert."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0397 \u03b5\u03c0\u03b9\u03c3\u03c4\u03c1\u03bf\u03c6\u03ae \u03b1\u03c0\u03cc \u03c4\u03bf \u03c0\u03b1\u03c1\u03b1\u03c3\u03ba\u03ae\u03bd\u03b9\u03bf \u03c6\u03c4\u03ac\u03bd\u03b5\u03b9 \u03c3\u03c4\u03bf \u03c0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03b9\u03ba\u03cc \u03ba\u03b1\u03c1\u03ad \u03c3\u03c5\u03bd\u03ad\u03c7\u03b9\u03c3\u03b7\u03c2 \u03b1\u03bd\u03c4\u03af \u03b3\u03b9\u03b1 \u03bc\u03b9\u03b1 \u03bc\u03b1\u03cd\u03c1\u03b7 \u03b1\u03bd\u03b1\u03bb\u03b1\u03bc\u03c0\u03ae \u2014 \u03b7 \u03bc\u03b7\u03c7\u03b1\u03bd\u03ae \u03c0\u03b5\u03c1\u03b9\u03bc\u03ad\u03bd\u03b5\u03b9 \u03c4\u03ce\u03c1\u03b1 \u03c4\u03bf \u03c0\u03c1\u03ce\u03c4\u03bf \u03b1\u03c0\u03bf\u03ba\u03c9\u03b4\u03b9\u03ba\u03bf\u03c0\u03bf\u03b9\u03b7\u03bc\u03ad\u03bd\u03bf \u03ba\u03b1\u03c1\u03ad \u03c0\u03c1\u03b9\u03bd \u03c0\u03b1\u03cd\u03c3\u03b5\u03b9."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coming back from background lands on the actual resumed frame instead of a black flash \u2014 the engine now waits for the first decoded frame before pausing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al volver desde segundo plano la app aterriza en el fotograma reanudado real en lugar de un parpadeo negro \u2014 el motor ahora espera al primer fotograma decodificado antes de pausar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Taustalta palaaminen p\u00e4\u00e4tyy oikeaan jatkokuvaan mustan v\u00e4l\u00e4hdyksen sijaan \u2014 moottori odottaa nyt ensimm\u00e4isen puretun kuvan ennen taukoa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le retour depuis l'arri\u00e8re-plan affiche directement l'image reprise au lieu d'un flash noir \u2014 le moteur attend d\u00e9sormais la premi\u00e8re image d\u00e9cod\u00e9e avant de mettre en pause."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povratak iz pozadine sada slije\u0107e na stvarni kadar nastavka umjesto crnog bljeska \u2014 engine sada \u010deka prvi dekodirani kadar prije pauziranja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A h\u00e1tt\u00e9rb\u0151l val\u00f3 visszat\u00e9r\u00e9s a t\u00e9nyleges folytat\u00e1si k\u00e9pkock\u00e1n landol egy fekete villan\u00e1s helyett \u2014 a motor mostant\u00f3l megv\u00e1rja az els\u0151 dek\u00f3dolt k\u00e9pkock\u00e1t, miel\u0151tt sz\u00fcneteltetne."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tornando dal background si arriva direttamente al fotogramma di ripresa invece che a un flash nero \u2014 il motore ora attende il primo fotogramma decodificato prima di mettere in pausa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30d0\u30c3\u30af\u30b0\u30e9\u30a6\u30f3\u30c9\u304b\u3089\u623b\u3063\u305f\u3068\u304d\u3001\u9ed2\u3044\u4e00\u77ac\u306e\u8868\u793a\u3067\u306f\u306a\u304f\u5b9f\u969b\u306e\u30ec\u30b8\u30e5\u30fc\u30e0\u30fb\u30d5\u30ec\u30fc\u30e0\u304b\u3089\u59cb\u307e\u308a\u307e\u3059\u3002\u30a8\u30f3\u30b8\u30f3\u304c\u4e00\u6642\u505c\u6b62\u3059\u308b\u524d\u306b\u6700\u521d\u306e\u30c7\u30b3\u30fc\u30c9\u6e08\u307f\u30d5\u30ec\u30fc\u30e0\u3092\u5f85\u3064\u3088\u3046\u306b\u306a\u308a\u307e\u3057\u305f\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\ubc31\uadf8\ub77c\uc6b4\ub4dc\uc5d0\uc11c \ub3cc\uc544\uc62c \ub54c \uac80\uc740 \ud654\uba74 \ub300\uc2e0 \uc2e4\uc81c \uc7ac\uac1c \ud504\ub808\uc784\uc5d0\uc11c \uc2dc\uc791\ud569\ub2c8\ub2e4 \u2014 \uc5d4\uc9c4\uc774 \uc77c\uc2dc \uc815\uc9c0\ud558\uae30 \uc804\uc5d0 \uccab \ub514\ucf54\ub529\ub41c \ud504\ub808\uc784\uc744 \uae30\ub2e4\ub9bd\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u00c5 komme tilbake fra bakgrunnen lander p\u00e5 den faktiske gjenopptatte rammen i stedet for et svart blink \u2014 motoren venter n\u00e5 p\u00e5 den f\u00f8rste dekodede rammen f\u00f8r den pauser."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terugkeren uit de achtergrond komt direct uit op het hervatte frame in plaats van op een zwarte flits \u2014 de engine wacht nu op het eerste gedecodeerde frame voordat hij pauzeert."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powr\u00f3t z t\u0142a ko\u0144czy si\u0119 na faktycznym wznowionym kadrze zamiast na czarnym b\u0142ysku \u2014 silnik czeka teraz na pierwsz\u0105 zdekodowan\u0105 klatk\u0119 przed wstrzymaniem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voltar do segundo plano leva direto ao quadro retomado em vez de um flash preto \u2014 o motor agora espera o primeiro quadro decodificado antes de pausar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regressar do segundo plano leva directamente ao fotograma retomado em vez de um flash preto \u2014 o motor agora espera o primeiro fotograma descodificado antes de fazer pausa."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revenirea din fundal aterizeaz\u0103 pe cadrul real de reluare \u00een loc de un fulger negru \u2014 motorul a\u0219teapt\u0103 acum primul cadru decodat \u00eenainte de a face pauz\u0103."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0412\u043e\u0437\u0432\u0440\u0430\u0442 \u0438\u0437 \u0444\u043e\u043d\u0430 \u0442\u0435\u043f\u0435\u0440\u044c \u043f\u0440\u0438\u0445\u043e\u0434\u0438\u0442 \u043d\u0430 \u0440\u0435\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u0430\u0434\u0440 \u0432\u043e\u0437\u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u044f \u0432\u043c\u0435\u0441\u0442\u043e \u0447\u0451\u0440\u043d\u043e\u0433\u043e \u043c\u0438\u0433\u0430\u043d\u0438\u044f \u2014 \u0434\u0432\u0438\u0436\u043e\u043a \u0434\u043e\u0436\u0438\u0434\u0430\u0435\u0442\u0441\u044f \u043f\u0435\u0440\u0432\u043e\u0433\u043e \u0434\u0435\u043a\u043e\u0434\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0433\u043e \u043a\u0430\u0434\u0440\u0430 \u043f\u0435\u0440\u0435\u0434 \u043f\u0430\u0443\u0437\u043e\u0439."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N\u00e1vrat z pozadia teraz pristane priamo na obnovenom sn\u00edmku namiesto \u010dierneho z\u00e1blesku \u2014 engine pred pozastaven\u00edm \u010dak\u00e1 na prv\u00fd dek\u00f3dovan\u00fd sn\u00edmok."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att komma tillbaka fr\u00e5n bakgrunden landar p\u00e5 den faktiska \u00e5terupptagna bildrutan ist\u00e4llet f\u00f6r en svart blinkning \u2014 motorn v\u00e4ntar nu p\u00e5 den f\u00f6rsta avkodade bildrutan innan den pausar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arka plandan d\u00f6n\u00fc\u015f art\u0131k siyah bir par\u0131lt\u0131 yerine do\u011frudan devam eden kareye d\u00fc\u015f\u00fcyor \u2014 motor duraklatmadan \u00f6nce ilk \u00e7\u00f6z\u00fclm\u00fc\u015f kareyi bekliyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u043e\u0432\u0435\u0440\u043d\u0435\u043d\u043d\u044f \u0437 \u0444\u043e\u043d\u0443 \u043f\u043e\u0442\u0440\u0430\u043f\u043b\u044f\u0454 \u043d\u0430 \u0441\u043f\u0440\u0430\u0432\u0436\u043d\u0456\u0439 \u043a\u0430\u0434\u0440 \u0432\u0456\u0434\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u044f \u0437\u0430\u043c\u0456\u0441\u0442\u044c \u0447\u043e\u0440\u043d\u043e\u0433\u043e \u0441\u043f\u0430\u043b\u0430\u0445\u0443 \u2014 \u0440\u0443\u0448\u0456\u0439 \u0442\u0435\u043f\u0435\u0440 \u0447\u0435\u043a\u0430\u0454 \u043d\u0430 \u043f\u0435\u0440\u0448\u0438\u0439 \u0434\u0435\u043a\u043e\u0434\u043e\u0432\u0430\u043d\u0438\u0439 \u043a\u0430\u0434\u0440 \u043f\u0435\u0440\u0435\u0434 \u043f\u0430\u0443\u0437\u043e\u044e."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u4ece\u540e\u53f0\u8fd4\u56de\u65f6\u76f4\u63a5\u5b9a\u4f4d\u5230\u771f\u6b63\u7684\u6062\u590d\u5e27,\u4e0d\u518d\u51fa\u73b0\u9ed1\u8272\u95ea\u70c1\u2014\u2014\u5f15\u64ce\u73b0\u5728\u4f1a\u7b49\u5230\u7b2c\u4e00\u5e27\u89e3\u7801\u5b8c\u6210\u540e\u518d\u6682\u505c\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5f9e\u80cc\u666f\u8fd4\u56de\u6642\u76f4\u63a5\u5b9a\u4f4d\u5230\u5be6\u969b\u7684\u6062\u5fa9\u5e40,\u4e0d\u518d\u51fa\u73fe\u9ed1\u8272\u9583\u720d\u2014\u2014\u5f15\u64ce\u73fe\u5728\u6703\u7b49\u5230\u7b2c\u4e00\u5e40\u89e3\u78bc\u5b8c\u6210\u5f8c\u518d\u66ab\u505c\u3002"
          }
        }
      }
    },

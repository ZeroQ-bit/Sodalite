    "settings.appearance.locked.subtitle" : {
      "comment" : "Explainer on the locked Appearance screen",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odemkn\u011bte zv\u00fdraz\u0148ovac\u00ed barvy spolu s pr\u00e9miovou \u00favodn\u00ed ikonou a odznakem podporovatele."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L\u00e5s op for fremh\u00e6vningsfarver sammen med det premium splash-ikon og supporter-badget."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schalte die Akzentfarben zusammen mit dem Premium-Splash-Icon und dem Supporter-Abzeichen frei."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u039e\u03b5\u03ba\u03bb\u03b5\u03b9\u03b4\u03ce\u03c3\u03c4\u03b5 \u03c4\u03b1 \u03c7\u03c1\u03ce\u03bc\u03b1\u03c4\u03b1 \u03ad\u03bc\u03c6\u03b1\u03c3\u03b7\u03c2 \u03bc\u03b1\u03b6\u03af \u03bc\u03b5 \u03c4\u03bf premium \u03b5\u03b9\u03ba\u03bf\u03bd\u03af\u03b4\u03b9\u03bf \u03ad\u03bd\u03b1\u03c1\u03be\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03c4\u03bf \u03c3\u03ae\u03bc\u03b1 \u03c5\u03c0\u03bf\u03c3\u03c4\u03b7\u03c1\u03b9\u03ba\u03c4\u03ae."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock accent colors along with the premium splash icon and supporter badge."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloquea los colores de acento junto con el icono de inicio premium y la insignia de apoyo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avaa korostusv\u00e4rit premium-k\u00e4ynnistyskuvakkeen ja tukija-merkin kanssa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "D\u00e9bloquez les couleurs d'accent avec l'ic\u00f4ne de lancement premium et le badge de soutien."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otklju\u010dajte naglasne boje zajedno s premium uvodnom ikonom i podr\u017eavateljskom zna\u010dkom."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oldd fel a kiemel\u0151sz\u00edneket a pr\u00e9mium nyit\u00f3ikonnal \u00e9s a t\u00e1mogat\u00f3i jelv\u00e9nnyel egy\u00fctt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sblocca i colori di accento insieme all'icona iniziale premium e al badge sostenitore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30d7\u30ec\u30df\u30a2\u30e0\u30b9\u30d7\u30e9\u30c3\u30b7\u30e5\u30a2\u30a4\u30b3\u30f3\u3068\u30b5\u30dd\u30fc\u30bf\u30fc\u30d0\u30c3\u30b8\u3068\u4e00\u7dd2\u306b\u30a2\u30af\u30bb\u30f3\u30c8\u30ab\u30e9\u30fc\u3092\u30a2\u30f3\u30ed\u30c3\u30af\u3057\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\ud504\ub9ac\ubbf8\uc5c4 \uc2a4\ud50c\ub798\uc2dc \uc544\uc774\ucf58 \ubc0f \uc11c\ud3ec\ud130 \ubc30\uc9c0\uc640 \ud568\uaed8 \uac15\uc870 \uc0c9\uc0c1\uc744 \uc7a0\uae08 \ud574\uc81c\ud558\uc138\uc694."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L\u00e5s opp aksentfarger sammen med premium splash-ikonet og supporter-merket."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ontgrendel accentkleuren samen met het premium splash-icoon en de supportersbadge."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odblokuj kolory akcentu wraz z premiow\u0105 ikon\u0105 powitaln\u0105 i odznak\u0105 wspieraj\u0105cego."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueie cores de destaque junto com o \u00edcone de abertura premium e o distintivo de apoiador."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueie cores de realce juntamente com o \u00edcone de abertura premium e o distintivo de apoiante."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deblocheaz\u0103 culorile de accent \u00eempreun\u0103 cu pictograma de pornire premium \u0219i insigna de sus\u021bin\u0103tor."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0420\u0430\u0437\u0431\u043b\u043e\u043a\u0438\u0440\u0443\u0439\u0442\u0435 \u0430\u043a\u0446\u0435\u043d\u0442\u043d\u044b\u0435 \u0446\u0432\u0435\u0442\u0430 \u0432\u043c\u0435\u0441\u0442\u0435 \u0441 \u043f\u0440\u0435\u043c\u0438\u0430\u043b\u044c\u043d\u043e\u0439 \u0437\u0430\u0441\u0442\u0430\u0432\u043a\u043e\u0439 \u0438 \u0437\u043d\u0430\u0447\u043a\u043e\u043c \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0438."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odomknite zv\u00fdraz\u0148ovacie farby spolu s pr\u00e9miovou \u00favodnou ikonou a odznakom podporovate\u013ea."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L\u00e5s upp accentf\u00e4rger tillsammans med premium-startikonen och supporter-m\u00e4rket."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium a\u00e7\u0131l\u0131\u015f simgesi ve destek\u00e7i rozeti ile birlikte vurgu renklerinin kilidini a\u00e7\u0131n."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0420\u043e\u0437\u0431\u043b\u043e\u043a\u0443\u0439\u0442\u0435 \u0430\u043a\u0446\u0435\u043d\u0442\u043d\u0456 \u043a\u043e\u043b\u044c\u043e\u0440\u0438 \u0440\u0430\u0437\u043e\u043c \u0456\u0437 \u043f\u0440\u0435\u043c\u0456\u0430\u043b\u044c\u043d\u043e\u044e \u0437\u0430\u0441\u0442\u0430\u0432\u043a\u043e\u044e \u0442\u0430 \u0437\u043d\u0430\u0447\u043a\u043e\u043c \u043f\u0440\u0438\u0445\u0438\u043b\u044c\u043d\u0438\u043a\u0430."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u89e3\u9501\u5f3a\u8c03\u8272\u4ee5\u53ca\u9ad8\u7ea7\u542f\u52a8\u56fe\u6807\u548c\u652f\u6301\u8005\u5fbd\u7ae0\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u89e3\u9396\u5f37\u8abf\u8272\u4ee5\u53ca\u9ad8\u7d1a\u555f\u52d5\u5716\u793a\u548c\u652f\u6301\u8005\u5fbd\u7ae0\u3002"
          }
        }
      }
    },

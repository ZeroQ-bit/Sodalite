          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30b5\u30fc\u30d0\u30fc\u306b\u63a5\u7d9a\u3067\u304d\u307e\u305b\u3093\u3002\u63a5\u7d9a\u3092\u78ba\u8a8d\u3057\u3066\u3082\u3046\u4e00\u5ea6\u304a\u8a66\u3057\u304f\u3060\u3055\u3044\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc11c\ubc84\uc5d0 \uc5f0\uacb0\ud560 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4. \uc5f0\uacb0\uc744 \ud655\uc778\ud558\uace0 \ub2e4\uc2dc \uc2dc\ub3c4\ud558\uc138\uc694."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kunne ikke n\u00e5 serveren. Sjekk forbindelsen og pr\u00f8v p\u00e5 nytt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kan je server niet bereiken. Controleer de verbinding en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie mo\u017cna po\u0142\u0105czy\u0107 si\u0119 z serwerem. Sprawd\u017a po\u0142\u0105czenie i spr\u00f3buj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N\u00e3o foi poss\u00edvel alcan\u00e7ar o servidor. Verifique a conex\u00e3o e tente novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N\u00e3o foi poss\u00edvel alcan\u00e7ar o servidor. Verifica a liga\u00e7\u00e3o e tenta novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Serverul nu poate fi accesat. Verific\u0103 conexiunea \u0219i \u00eencearc\u0103 din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041d\u0435 \u0443\u0434\u0430\u043b\u043e\u0441\u044c \u0441\u0432\u044f\u0437\u0430\u0442\u044c\u0441\u044f \u0441 \u0441\u0435\u0440\u0432\u0435\u0440\u043e\u043c. \u041f\u0440\u043e\u0432\u0435\u0440\u044c\u0442\u0435 \u043f\u043e\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435 \u0438 \u043f\u043e\u043f\u0440\u043e\u0431\u0443\u0439\u0442\u0435 \u0441\u043d\u043e\u0432\u0430."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nepodarilo sa pripoji\u0165 k serveru. Skontroluj pripojenie a sk\u00fas to znova."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kunde inte n\u00e5 servern. Kontrollera anslutningen och f\u00f6rs\u00f6k igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sunucuya ula\u015f\u0131lamad\u0131. Ba\u011flant\u0131y\u0131 kontrol edip tekrar dene."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041d\u0435 \u0432\u0434\u0430\u043b\u043e\u0441\u044f \u0437\u0432'\u044f\u0437\u0430\u0442\u0438\u0441\u044f \u0437 \u0441\u0435\u0440\u0432\u0435\u0440\u043e\u043c. \u041f\u0435\u0440\u0435\u0432\u0456\u0440 \u0437'\u0454\u0434\u043d\u0430\u043d\u043d\u044f \u0442\u0430 \u0441\u043f\u0440\u043e\u0431\u0443\u0439 \u0437\u043d\u043e\u0432\u0443."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u65e0\u6cd5\u8fde\u63a5\u5230\u670d\u52a1\u5668\u3002\u8bf7\u68c0\u67e5\u7f51\u7edc\u540e\u91cd\u8bd5\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u7121\u6cd5\u9023\u7dda\u5230\u4f3a\u670d\u5668\u3002\u8acb\u6aa2\u67e5\u9023\u7dda\u5f8c\u91cd\u8a66\u3002"
          }
        }
      }
    },
    "search.hint.connectSeerr" : {
      "comment" : "Hint shown under search.hint.startTyping when Seerr isn't connected yet",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P\u0159ipoj Seerr v Nastaven\u00ed, abys mohl prohled\u00e1vat i katalog nov\u00fdch film\u016f a seri\u00e1l\u016f."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forbind Seerr i Indstillinger for ogs\u00e5 at s\u00f8ge i kataloget efter nye film og serier."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbinde Seerr in den Einstellungen, um auch im Katalog nach neuen Filmen und Serien zu suchen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a3\u03cd\u03bd\u03b4\u03b5\u03c3\u03b5 \u03c4\u03bf Seerr \u03c3\u03c4\u03b9\u03c2 \u03a1\u03c5\u03b8\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03b1\u03bd\u03b1\u03b6\u03b7\u03c4\u03ac\u03c2 \u03b5\u03c0\u03af\u03c3\u03b7\u03c2 \u03bd\u03ad\u03b5\u03c2 \u03c4\u03b1\u03b9\u03bd\u03af\u03b5\u03c2 \u03ba\u03b1\u03b9 \u03c3\u03b5\u03b9\u03c1\u03ad\u03c2 \u03c3\u03c4\u03bf\u03bd \u03ba\u03b1\u03c4\u03ac\u03bb\u03bf\u03b3\u03bf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connect Seerr in Settings to also search the catalog for new movies and shows."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecta Seerr en Ajustes para buscar tambi\u00e9n en el cat\u00e1logo nuevas pel\u00edculas y series."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yhdist\u00e4 Seerr asetuksissa, jotta voit hakea my\u00f6s luettelosta uusia elokuvia ja sarjoja."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connecte Seerr dans les R\u00e9glages pour rechercher aussi dans le catalogue de nouveaux films et s\u00e9ries."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pove\u017ei Seerr u Postavkama kako bi pretra\u017eivao i katalog za nove filmove i serije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Csatlakoztasd a Seerr-t a Be\u00e1ll\u00edt\u00e1sokban, hogy a katal\u00f3gusban is kereshess \u00faj filmeket \u00e9s sorozatokat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Collega Seerr nelle Impostazioni per cercare anche nel catalogo nuovi film e serie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8a2d\u5b9a\u3067 Seerr \u3092\u63a5\u7d9a\u3059\u308b\u3068\u3001\u65b0\u3057\u3044\u6620\u753b\u3084\u756a\u7d44\u306e\u30ab\u30bf\u30ed\u30b0\u3082\u691c\u7d22\u3067\u304d\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc124\uc815\uc5d0\uc11c Seerr\ub97c \uc5f0\uacb0\ud558\uba74 \uc0c8 \uc601\ud654\uc640 \uc2dc\ub9ac\uc988 \uce74\ud0c8\ub85c\uadf8\ub3c4 \uac80\uc0c9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koble til Seerr i Innstillinger for ogs\u00e5 \u00e5 s\u00f8ke i katalogen etter nye filmer og serier."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbind Seerr in Instellingen om ook de catalogus te doorzoeken op nieuwe films en series."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po\u0142\u0105cz Seerr w Ustawieniach, aby przeszukiwa\u0107 tak\u017ce katalog nowych film\u00f3w i seriali."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecte o Seerr nos Ajustes para tamb\u00e9m pesquisar o cat\u00e1logo por novos filmes e s\u00e9ries."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liga o Seerr nas Defini\u00e7\u00f5es para pesquisares tamb\u00e9m no cat\u00e1logo novos filmes e s\u00e9ries."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecteaz\u0103 Seerr \u00een Set\u0103ri pentru a c\u0103uta \u0219i \u00een catalog filme \u0219i seriale noi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u043e\u0434\u043a\u043b\u044e\u0447\u0438\u0442\u0435 Seerr \u0432 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0430\u0445, \u0447\u0442\u043e\u0431\u044b \u0442\u0430\u043a\u0436\u0435 \u0438\u0441\u043a\u0430\u0442\u044c \u043d\u043e\u0432\u044b\u0435 \u0444\u0438\u043b\u044c\u043c\u044b \u0438 \u0441\u0435\u0440\u0438\u0430\u043b\u044b \u0432 \u043a\u0430\u0442\u0430\u043b\u043e\u0433\u0435."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pripoj Seerr v Nastaveniach, aby si mohol preh\u013ead\u00e1va\u0165 aj katal\u00f3g nov\u00fdch filmov a seri\u00e1lov."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anslut Seerr i Inst\u00e4llningar f\u00f6r att ocks\u00e5 s\u00f6ka i katalogen efter nya filmer och serier."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeni filmler ve diziler i\u00e7in katalo\u011fu da aramak \u00fczere Ayarlar'dan Seerr'i ba\u011fla."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u0456\u0434\u043a\u043b\u044e\u0447\u0456\u0442\u044c Seerr \u0443 \u041d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f\u0445, \u0449\u043e\u0431 \u0442\u0430\u043a\u043e\u0436 \u0448\u0443\u043a\u0430\u0442\u0438 \u043d\u043e\u0432\u0456 \u0444\u0456\u043b\u044c\u043c\u0438 \u0442\u0430 \u0441\u0435\u0440\u0456\u0430\u043b\u0438 \u0432 \u043a\u0430\u0442\u0430\u043b\u043e\u0437\u0456."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5728\u8bbe\u7f6e\u4e2d\u8fde\u63a5 Seerr\uff0c\u5373\u53ef\u5728\u76ee\u5f55\u4e2d\u641c\u7d22\u65b0\u7535\u5f71\u548c\u5267\u96c6\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5728\u8a2d\u5b9a\u4e2d\u9023\u63a5 Seerr\uff0c\u5373\u53ef\u5728\u76ee\u9304\u4e2d\u641c\u5c0b\u65b0\u96fb\u5f71\u548c\u5287\u96c6\u3002"
          }
        }
      }
    },

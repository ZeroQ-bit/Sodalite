            "state" : "translated",
            "value" : "Bem-vindo a bordo! Pacote de Apoio desbloqueado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bem-vindo a bordo! Pacote de Apoio desbloqueado."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bine ai venit! Pachet de Sus\u021bin\u0103tor deblocat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0414\u043e\u0431\u0440\u043e \u043f\u043e\u0436\u0430\u043b\u043e\u0432\u0430\u0442\u044c! \u041f\u0430\u043a\u0435\u0442 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0438 \u0440\u0430\u0437\u0431\u043b\u043e\u043a\u0438\u0440\u043e\u0432\u0430\u043d."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vitajte! Bal\u00ed\u010dek podporovate\u013ea odomknut\u00fd."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V\u00e4lkommen ombord! Supporterpaket uppl\u00e5st."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aram\u0131za ho\u015f geldin! Destek\u00e7i Paketi kilidi a\u00e7\u0131ld\u0131."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041b\u0430\u0441\u043a\u0430\u0432\u043e \u043f\u0440\u043e\u0441\u0438\u043c\u043e \u043d\u0430 \u0431\u043e\u0440\u0442! \u041f\u0430\u043a\u0435\u0442 \u043f\u0440\u0438\u0445\u0438\u043b\u044c\u043d\u0438\u043a\u0430 \u0440\u043e\u0437\u0431\u043b\u043e\u043a\u043e\u0432\u0430\u043d\u043e."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {

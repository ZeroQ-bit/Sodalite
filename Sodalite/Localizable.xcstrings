    "changelog.0_5_0.touchpadAccuracy.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rychlostn\u00ed limit na dotykov\u00e9 plo\u0161e Siri Remote ignoruje posun prstu p\u0159ed kliknut\u00edm, tak\u017ee op\u0159en\u00fd palec u\u017e n\u00e1hodn\u011b neposune zam\u011b\u0159en\u00ed na dal\u0161\u00ed tla\u010d\u00edtko."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En hastighedsgr\u00e6nse p\u00e5 Siri Remote-touchpad'en ignorerer fingerflytning f\u00f8r et klik, s\u00e5 det at hvile tommelfingeren ikke l\u00e6ngere ved et uheld flytter fokus til den n\u00e6ste knap."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Geschwindigkeits-Schwelle am Siri-Remote-Touchpad ignoriert Finger-Drift vor einem Klick, sodass ein abgesetzter Daumen nicht mehr versehentlich den Fokus auf den n\u00e4chsten Button verschiebt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0388\u03bd\u03b1 \u03cc\u03c1\u03b9\u03bf \u03c4\u03b1\u03c7\u03cd\u03c4\u03b7\u03c4\u03b1\u03c2 \u03c3\u03c4\u03bf touchpad \u03c4\u03bf\u03c5 Siri Remote \u03b1\u03b3\u03bd\u03bf\u03b5\u03af \u03c4\u03b7 \u03bc\u03b5\u03c4\u03b1\u03c4\u03cc\u03c0\u03b9\u03c3\u03b7 \u03c4\u03bf\u03c5 \u03b4\u03b1\u03ba\u03c4\u03cd\u03bb\u03bf\u03c5 \u03c0\u03c1\u03b9\u03bd \u03b1\u03c0\u03cc \u03c4\u03bf \u03ba\u03bb\u03b9\u03ba, \u03ce\u03c3\u03c4\u03b5 \u03b7 \u03b1\u03bd\u03ac\u03c0\u03b1\u03c5\u03c3\u03b7 \u03c4\u03bf\u03c5 \u03b1\u03bd\u03c4\u03af\u03c7\u03b5\u03b9\u03c1\u03b1 \u03bd\u03b1 \u03bc\u03b7 \u03bc\u03b5\u03c4\u03b1\u03ba\u03b9\u03bd\u03b5\u03af \u03c0\u03b9\u03b1 \u03ba\u03b1\u03c4\u03ac \u03bb\u03ac\u03b8\u03bf\u03c2 \u03c4\u03b7\u03bd \u03b5\u03c3\u03c4\u03af\u03b1\u03c3\u03b7 \u03c3\u03c4\u03bf \u03b5\u03c0\u03cc\u03bc\u03b5\u03bd\u03bf \u03ba\u03bf\u03c5\u03bc\u03c0\u03af."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A velocity gate on the Siri Remote touchpad ignores finger drift before a click, so resting your thumb no longer accidentally moves focus to the next button."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un umbral de velocidad en el touchpad del Siri Remote ignora el desplazamiento del dedo antes de un clic, as\u00ed que apoyar el pulgar ya no mueve por accidente el foco al bot\u00f3n siguiente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nopeusraja Siri Remoten kosketuslevyll\u00e4 j\u00e4tt\u00e4\u00e4 huomiotta sormen liikkeen ennen napsautusta, joten peukalon lepuuttaminen ei en\u00e4\u00e4 siirr\u00e4 kohdistusta vahingossa seuraavaan painikkeeseen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un seuil de vitesse sur le pav\u00e9 tactile du Siri Remote ignore le glissement du doigt avant un clic, donc poser le pouce ne d\u00e9place plus accidentellement le focus sur le bouton suivant."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brzinski prag na dodirnoj plohi Siri Remotea ignorira pomicanje prsta prije klika, pa odlaganje palca vi\u0161e ne mi\u010de fokus na sljede\u0107u tipku slu\u010dajno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Siri Remote \u00e9rint\u0151fel\u00fclet\u00e9n l\u00e9v\u0151 sebess\u00e9gk\u00fcsz\u00f6b figyelmen k\u00edv\u00fcl hagyja az ujj elcs\u00fasz\u00e1s\u00e1t kattint\u00e1s el\u0151tt, \u00edgy a h\u00fcvelykujj megpihentet\u00e9se t\u00f6bb\u00e9 nem mozgatja v\u00e9letlen\u00fcl a f\u00f3kuszt a k\u00f6vetkez\u0151 gombra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una soglia di velocit\u00e0 sul touchpad del Siri Remote ignora la deriva del dito prima di un clic, cos\u00ec appoggiare il pollice non sposta pi\u00f9 per sbaglio il focus sul pulsante successivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri Remote\u306e\u30bf\u30c3\u30c1\u30d1\u30c3\u30c9\u306b\u901f\u5ea6\u3057\u304d\u3044\u5024\u3092\u8a2d\u3051\u305f\u3053\u3068\u3067\u3001\u30af\u30ea\u30c3\u30af\u524d\u306e\u6307\u306e\u305a\u308c\u304c\u7121\u8996\u3055\u308c\u307e\u3059\u3002\u89aa\u6307\u3092\u7f6e\u3044\u3066\u3082\u30d5\u30a9\u30fc\u30ab\u30b9\u304c\u610f\u56f3\u305b\u305a\u96a3\u306e\u30dc\u30bf\u30f3\u3078\u52d5\u304f\u3053\u3068\u306f\u306a\u304f\u306a\u308a\u307e\u3057\u305f\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri Remote \ud130\uce58\ud328\ub4dc\uc5d0 \uc18d\ub3c4 \uc784\uacc4\uac12\uc744 \ub450\uc5b4 \ud074\ub9ad \uc804 \uc190\uac00\ub77d \ub4dc\ub9ac\ud504\ud2b8\ub97c \ubb34\uc2dc\ud569\ub2c8\ub2e4. \uc5c4\uc9c0\ub97c \uc62c\ub824\ub46c\ub3c4 \ud3ec\ucee4\uc2a4\uac00 \uc6b0\uc5f0\ud788 \ub2e4\uc74c \ubc84\ud2bc\uc73c\ub85c \uc774\ub3d9\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En hastighetsgrense p\u00e5 Siri Remote-pekeflaten ignorerer fingerforskyvning f\u00f8r et klikk, s\u00e5 \u00e5 la tommelen hvile flytter ikke lenger fokus til neste knapp ved et uhell."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een snelheidsgrens op het touchpad van de Siri Remote negeert vingerafwijking voor een klik, zodat het neerleggen van je duim de focus niet langer per ongeluk naar de volgende knop verplaatst."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pr\u00f3g pr\u0119dko\u015bci na touchpadzie Siri Remote ignoruje przesuni\u0119cie palca przed klikni\u0119ciem, wi\u0119c oparcie kciuka nie przesuwa ju\u017c przypadkowo fokusu na nast\u0119pny przycisk."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um limite de velocidade no touchpad do Siri Remote ignora o deslizamento do dedo antes de um clique, ent\u00e3o apoiar o polegar n\u00e3o move mais o foco para o bot\u00e3o seguinte por acidente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um limite de velocidade no touchpad do Siri Remote ignora o deslizamento do dedo antes de um clique, por isso apoiar o polegar j\u00e1 n\u00e3o move o foco para o bot\u00e3o seguinte por acidente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un prag de vitez\u0103 pe touchpad-ul Siri Remote ignor\u0103 alunecarea degetului \u00eenainte de clic, astfel \u00eenc\u00e2t sprijinirea degetului mare nu mai mut\u0103 accidental focusul pe butonul urm\u0103tor."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u043e\u0440\u043e\u0433 \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u0438 \u043d\u0430 \u0442\u0430\u0447\u043f\u0430\u0434\u0435 Siri Remote \u0438\u0433\u043d\u043e\u0440\u0438\u0440\u0443\u0435\u0442 \u0441\u043c\u0435\u0449\u0435\u043d\u0438\u0435 \u043f\u0430\u043b\u044c\u0446\u0430 \u043f\u0435\u0440\u0435\u0434 \u043d\u0430\u0436\u0430\u0442\u0438\u0435\u043c, \u0442\u0430\u043a \u0447\u0442\u043e \u043f\u043e\u043b\u043e\u0436\u0435\u043d\u043d\u044b\u0439 \u0431\u043e\u043b\u044c\u0448\u043e\u0439 \u043f\u0430\u043b\u0435\u0446 \u0431\u043e\u043b\u044c\u0448\u0435 \u043d\u0435 \u0441\u043c\u0435\u0449\u0430\u0435\u0442 \u0444\u043e\u043a\u0443\u0441 \u043d\u0430 \u0441\u043e\u0441\u0435\u0434\u043d\u044e\u044e \u043a\u043d\u043e\u043f\u043a\u0443 \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u043e."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R\u00fdchlostn\u00fd limit na dotykovej ploche Siri Remote ignoruje posun prsta pred kliknut\u00edm, tak\u017ee opret\u00fd palec u\u017e n\u00e1hodne neposunie zameranie na \u010fal\u0161ie tla\u010didlo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En hastighetstr\u00f6skel p\u00e5 Siri Remote-pekplattan ignorerar fingerf\u00f6rskjutning f\u00f6re ett klick, s\u00e5 att vila tummen inte l\u00e4ngre r\u00e5kar flytta fokus till n\u00e4sta knapp."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri Remote dokunmatik y\u00fczeyindeki h\u0131z e\u015fi\u011fi, t\u0131klamadan \u00f6nceki parmak kaymas\u0131n\u0131 yok sayar; b\u00f6ylece ba\u015fparma\u011f\u0131n\u0131z\u0131 dayad\u0131\u011f\u0131n\u0131zda odak yanl\u0131\u015fl\u0131kla bir sonraki d\u00fc\u011fmeye kaymaz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u043e\u0440\u0456\u0433 \u0448\u0432\u0438\u0434\u043a\u043e\u0441\u0442\u0456 \u043d\u0430 \u0442\u0440\u0435\u043a\u043f\u0430\u0434\u0456 Siri Remote \u0456\u0433\u043d\u043e\u0440\u0443\u0454 \u0437\u043c\u0456\u0449\u0435\u043d\u043d\u044f \u043f\u0430\u043b\u044c\u0446\u044f \u043f\u0435\u0440\u0435\u0434 \u043d\u0430\u0442\u0438\u0441\u043a\u0430\u043d\u043d\u044f\u043c, \u0442\u043e\u0436 \u043f\u043e\u043a\u043b\u0430\u0434\u0435\u043d\u0438\u0439 \u0432\u0435\u043b\u0438\u043a\u0438\u0439 \u043f\u0430\u043b\u0435\u0446\u044c \u0431\u0456\u043b\u044c\u0448\u0435 \u043d\u0435 \u0437\u043c\u0456\u0449\u0443\u0454 \u0444\u043e\u043a\u0443\u0441 \u043d\u0430 \u0441\u0443\u0441\u0456\u0434\u043d\u044e \u043a\u043d\u043e\u043f\u043a\u0443 \u0432\u0438\u043f\u0430\u0434\u043a\u043e\u0432\u043e."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri Remote \u89e6\u63a7\u677f\u4e0a\u7684\u901f\u5ea6\u9608\u503c\u4f1a\u5ffd\u7565\u70b9\u51fb\u524d\u7684\u624b\u6307\u6f02\u79fb,\u56e0\u6b64\u5c06\u62c7\u6307\u653e\u5728\u89e6\u63a7\u677f\u4e0a\u4e0d\u4f1a\u518d\u610f\u5916\u628a\u7126\u70b9\u79fb\u5230\u4e0b\u4e00\u4e2a\u6309\u94ae\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri Remote \u89f8\u63a7\u677f\u4e0a\u7684\u901f\u5ea6\u95be\u503c\u6703\u5ffd\u7565\u9ede\u64ca\u524d\u7684\u624b\u6307\u6f02\u79fb,\u6240\u4ee5\u5c07\u62c7\u6307\u653e\u5728\u89f8\u63a7\u677f\u4e0a\u4e0d\u6703\u518d\u610f\u5916\u628a\u7126\u9ede\u79fb\u5230\u4e0b\u4e00\u500b\u6309\u9215\u3002"
          }
        }
      }
    },

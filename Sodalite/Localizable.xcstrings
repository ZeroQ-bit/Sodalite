    "settings.seerr.description" : {
      "comment" : "Settings description",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P\u0159ipojte Seerr k proch\u00e1zen\u00ed obl\u00edben\u00e9ho obsahu a \u017e\u00e1d\u00e1n\u00ed o nov\u00e9 filmy nebo seri\u00e1ly."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forbind Seerr for at gennemse popul\u00e6rt indhold og anmode om nye film eller serier."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbinde Seerr, um beliebte Inhalte zu entdecken und neue Filme oder Serien anzufordern."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a3\u03c5\u03bd\u03b4\u03ad\u03c3\u03c4\u03b5 \u03c4\u03bf Seerr \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03c0\u03b5\u03c1\u03b9\u03b7\u03b3\u03b7\u03b8\u03b5\u03af\u03c4\u03b5 \u03c3\u03b5 \u03b4\u03b7\u03bc\u03bf\u03c6\u03b9\u03bb\u03ad\u03c2 \u03c0\u03b5\u03c1\u03b9\u03b5\u03c7\u03cc\u03bc\u03b5\u03bd\u03bf \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03b6\u03b7\u03c4\u03ae\u03c3\u03b5\u03c4\u03b5 \u03bd\u03ad\u03b5\u03c2 \u03c4\u03b1\u03b9\u03bd\u03af\u03b5\u03c2 \u03ae \u03c3\u03b5\u03b9\u03c1\u03ad\u03c2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connect Seerr to browse popular content and request new movies or shows."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecta Seerr para explorar contenido popular y solicitar nuevas pel\u00edculas o series."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yhdist\u00e4 Seerr selataksesi suosittua sis\u00e4lt\u00f6\u00e4 ja pyyt\u00e4\u00e4ksesi uusia elokuvia tai sarjoja."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connectez Seerr pour parcourir les contenus populaires et demander de nouveaux films ou s\u00e9ries."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pove\u017eite Seerr za pregledavanje popularnog sadr\u017eaja i zahtijevanje novih filmova ili serija."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Csatlakoztasd a Seerr-t a n\u00e9pszer\u0171 tartalmak b\u00f6ng\u00e9sz\u00e9s\u00e9hez \u00e9s \u00faj filmek vagy sorozatok k\u00e9r\u00e9s\u00e9hez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Collega Seerr per sfogliare i contenuti popolari e richiedere nuovi film o serie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seerr \u306b\u63a5\u7d9a\u3059\u308b\u3068\u3001\u4eba\u6c17\u30b3\u30f3\u30c6\u30f3\u30c4\u3092\u95b2\u89a7\u3057\u305f\u308a\u3001\u65b0\u3057\u3044\u6620\u753b\u3084\u756a\u7d44\u3092\u30ea\u30af\u30a8\u30b9\u30c8\u3067\u304d\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seerr\uc5d0 \uc5f0\uacb0\ud558\uc5ec \uc778\uae30 \ucf58\ud150\uce20\ub97c \ub458\ub7ec\ubcf4\uace0 \uc0c8 \uc601\ud654\ub098 \ud504\ub85c\uadf8\ub7a8\uc744 \uc694\uccad\ud558\uc138\uc694."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koble til Seerr for \u00e5 bla gjennom popul\u00e6rt innhold og be om nye filmer eller serier."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbind Seerr om populaire content te bekijken en nieuwe films of series aan te vragen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po\u0142\u0105cz Seerr, aby przegl\u0105da\u0107 popularne tre\u015bci i prosi\u0107 o nowe filmy lub seriale."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecte o Seerr para navegar por conte\u00fado popular e solicitar novos filmes ou s\u00e9ries."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ligue o Seerr para explorar conte\u00fado popular e pedir novos filmes ou s\u00e9ries."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecteaz\u0103 Seerr pentru a r\u0103sfoi con\u021binut popular \u0219i a solicita noi filme sau seriale."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041f\u043e\u0434\u043a\u043b\u044e\u0447\u0438\u0442\u0435 Seerr, \u0447\u0442\u043e\u0431\u044b \u043f\u0440\u043e\u0441\u043c\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044c \u043f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u044b\u0439 \u043a\u043e\u043d\u0442\u0435\u043d\u0442 \u0438 \u0437\u0430\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0442\u044c \u043d\u043e\u0432\u044b\u0435 \u0444\u0438\u043b\u044c\u043c\u044b \u0438\u043b\u0438 \u0441\u0435\u0440\u0438\u0430\u043b\u044b."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pripojte Seerr na prehliadanie ob\u013e\u00faben\u00e9ho obsahu a \u017eiadanie o nov\u00e9 filmy alebo seri\u00e1ly."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anslut Seerr f\u00f6r att bl\u00e4ddra bland popul\u00e4rt inneh\u00e5ll och beg\u00e4ra nya filmer eller serier."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pop\u00fcler i\u00e7eriklere g\u00f6z atmak ve yeni filmler veya diziler istemek i\u00e7in Seerr'i ba\u011flay\u0131n."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",

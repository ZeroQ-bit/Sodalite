    "changelog.0_4_1.resumeButton.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tla\u010d\u00edtko P\u0159ehr\u00e1t v detailech ukazuje epizodu, \u010dasovou zna\u010dku a indik\u00e1tor postupu ve va\u0161\u00ed akcentn\u00ed barv\u011b."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afspil-knappen i detaljevisningen viser episode, tidsstempel og en fremgangsbj\u00e6lke i din accentfarve."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Abspielen-Button in den Detailansichten zeigt Folge, Zeitstempel und einen Fortschrittsbalken in deiner Akzentfarbe."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a4\u03bf \u03ba\u03bf\u03c5\u03bc\u03c0\u03af \u03b1\u03bd\u03b1\u03c0\u03b1\u03c1\u03b1\u03b3\u03c9\u03b3\u03ae\u03c2 \u03c3\u03c4\u03b9\u03c2 \u03bb\u03b5\u03c0\u03c4\u03bf\u03bc\u03ad\u03c1\u03b5\u03b9\u03b5\u03c2 \u03b4\u03b5\u03af\u03c7\u03bd\u03b5\u03b9 \u03c4\u03bf \u03b5\u03c0\u03b5\u03b9\u03c3\u03cc\u03b4\u03b9\u03bf, \u03c4\u03b7 \u03c7\u03c1\u03bf\u03bd\u03b9\u03ba\u03ae \u03c3\u03c6\u03c1\u03b1\u03b3\u03af\u03b4\u03b1 \u03ba\u03b1\u03b9 \u03bc\u03c0\u03ac\u03c1\u03b1 \u03c0\u03c1\u03bf\u03cc\u03b4\u03bf\u03c5 \u03c3\u03c4\u03bf \u03c7\u03c1\u03ce\u03bc\u03b1 \u03ad\u03bc\u03c6\u03b1\u03c3\u03b7\u03c2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detail-view play button now shows the episode, timestamp, and a progress bar in your accent colour."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El bot\u00f3n de reproducir en detalles muestra ahora el episodio, marca de tiempo y barra de progreso con tu color de acento."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tieto\u00adn\u00e4kym\u00e4n toistopainike n\u00e4ytt\u00e4\u00e4 nyt jakson, aikaleiman ja edistymispalkin korostusv\u00e4rill\u00e4si."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le bouton Lecture de la vue d\u00e9tail affiche d\u00e9sormais l'\u00e9pisode, l'horodatage et une barre de progression dans votre couleur d'accent."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gumb Reproduciraj u detaljima sad prikazuje epizodu, vremenski \u017eig i traku napretka u boji naglaska."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A r\u00e9szletek n\u00e9zet lej\u00e1tsz\u00e1s gombja most mutatja az epiz\u00f3dot, az id\u0151b\u00e9lyeget \u00e9s egy folyamatjelz\u0151t a kiemel\u0151sz\u00ednedben."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il pulsante Riproduci nella vista dettagli mostra ora l'episodio, il timestamp e una barra di avanzamento nel tuo colore d'accento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8a73\u7d30\u753b\u9762\u306e\u518d\u751f\u30dc\u30bf\u30f3\u306b\u3001\u30a8\u30d4\u30bd\u30fc\u30c9\u3001\u30bf\u30a4\u30e0\u30b9\u30bf\u30f3\u30d7\u3001\u30a2\u30af\u30bb\u30f3\u30c8\u30ab\u30e9\u30fc\u306e\u9032\u6357\u30d0\u30fc\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc0c1\uc138 \ud654\uba74\uc758 \uc7ac\uc0dd \ubc84\ud2bc\uc774 \uc774\uc81c \uc5d0\ud53c\uc18c\ub4dc, \ud0c0\uc784\uc2a4\ud0ec\ud504, \uac15\uc870\uc0c9\uc758 \uc9c4\ud589\ub960 \ubc14\ub97c \ud45c\uc2dc\ud569\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spill av-knappen i detaljvisningen viser n\u00e5 episode, tidsstempel og en fremdriftsindikator i aksentfargen din."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De afspelen-knop in de detailweergave toont nu de aflevering, tijdstempel en een voortgangsbalk in jouw accentkleur."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przycisk Odtw\u00f3rz w widoku szczeg\u00f3\u0142\u00f3w pokazuje teraz odcinek, znacznik czasu i pasek post\u0119pu w Twoim kolorze akcentu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O bot\u00e3o Reproduzir nos detalhes agora mostra o epis\u00f3dio, o timestamp e uma barra de progresso na sua cor de destaque."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O bot\u00e3o Reproduzir nos detalhes mostra agora o epis\u00f3dio, o registo temporal e uma barra de progresso na sua cor de destaque."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Butonul de redare \u00een detalii afi\u0219eaz\u0103 acum episodul, marca de timp \u0219i o bar\u0103 de progres \u00een culoarea ta de accent."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041a\u043d\u043e\u043f\u043a\u0430 \u0432\u043e\u0441\u043f\u0440\u043e\u0438\u0437\u0432\u0435\u0434\u0435\u043d\u0438\u044f \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435 \u0434\u0435\u0442\u0430\u043b\u0435\u0439 \u0442\u0435\u043f\u0435\u0440\u044c \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u044d\u043f\u0438\u0437\u043e\u0434, \u043c\u0435\u0442\u043a\u0443 \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u0438 \u0438\u043d\u0434\u0438\u043a\u0430\u0442\u043e\u0440 \u043f\u0440\u043e\u0433\u0440\u0435\u0441\u0441\u0430 \u0432 \u0432\u0430\u0448\u0435\u043c \u0430\u043a\u0446\u0435\u043d\u0442\u043d\u043e\u043c \u0446\u0432\u0435\u0442\u0435."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tla\u010didlo Prehra\u0165 v detailoch teraz ukazuje epiz\u00f3du, \u010dasov\u00fa zna\u010dku a indik\u00e1tor postupu vo va\u0161ej akcentovej farbe."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spela-knappen i detaljvyn visar nu avsnittet, tidsst\u00e4mpeln och en f\u00f6rloppsindikator i din accentf\u00e4rg."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detay g\u00f6r\u00fcn\u00fcm\u00fcndeki Oynat d\u00fc\u011fmesi art\u0131k b\u00f6l\u00fcm\u00fc, zaman damgas\u0131n\u0131 ve vurgu renginizde bir ilerleme \u00e7ubu\u011fu g\u00f6sterir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041a\u043d\u043e\u043f\u043a\u0430 \u0432\u0456\u0434\u0442\u0432\u043e\u0440\u0435\u043d\u043d\u044f \u043d\u0430 \u0435\u043a\u0440\u0430\u043d\u0456 \u0434\u0435\u0442\u0430\u043b\u0435\u0439 \u0442\u0435\u043f\u0435\u0440 \u043f\u043e\u043a\u0430\u0437\u0443\u0454 \u0435\u043f\u0456\u0437\u043e\u0434, \u043c\u0456\u0442\u043a\u0443 \u0447\u0430\u0441\u0443 \u0442\u0430 \u0441\u043c\u0443\u0433\u0443 \u043f\u0440\u043e\u0433\u0440\u0435\u0441\u0443 \u0443 \u0432\u0430\u0448\u043e\u043c\u0443 \u0430\u043a\u0446\u0435\u043d\u0442\u043d\u043e\u043c\u0443 \u043a\u043e\u043b\u044c\u043e\u0440\u0456."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8be6\u60c5\u9875\u7684\u64ad\u653e\u6309\u94ae\u73b0\u5728\u663e\u793a\u5267\u96c6\u3001\u65f6\u95f4\u6233\u4ee5\u53ca\u60a8\u5f3a\u8c03\u8272\u7684\u8fdb\u5ea6\u6761\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8a73\u60c5\u9801\u7684\u64ad\u653e\u6309\u9215\u73fe\u5728\u986f\u793a\u96c6\u6578\u3001\u6642\u9593\u6233\u4ee5\u53ca\u60a8\u5f37\u8abf\u8272\u7684\u9032\u5ea6\u689d\u3002"
          }
        }
      }
    },

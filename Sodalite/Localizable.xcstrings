    },
    "settings.seerr.quickConnectNote" : {
      "comment" : "Explanation shown when Jellyfin-credentials toggle is on but no password cached (Quick Connect user)",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do Jellyfin jste se p\u0159ihl\u00e1sili pomoc\u00ed Quick Connect, tak\u017ee va\u0161e heslo nezn\u00e1me. Zadejte ho pro p\u0159ihl\u00e1\u0161en\u00ed do Seerr."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du loggede ind p\u00e5 Jellyfin med Quick Connect, s\u00e5 vi har ikke din adgangskode. Indtast den for at logge ind p\u00e5 Seerr."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast dich bei Jellyfin mit Quick Connect angemeldet, daher kennen wir dein Passwort nicht. Bitte gib es ein, um dich bei Seerr anzumelden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a3\u03c5\u03bd\u03b4\u03b5\u03b8\u03ae\u03ba\u03b1\u03c4\u03b5 \u03c3\u03c4\u03bf Jellyfin \u03bc\u03b5 Quick Connect, \u03bf\u03c0\u03cc\u03c4\u03b5 \u03b4\u03b5\u03bd \u03ad\u03c7\u03bf\u03c5\u03bc\u03b5 \u03c4\u03bf\u03bd \u03ba\u03c9\u03b4\u03b9\u03ba\u03cc \u03c3\u03b1\u03c2. \u0395\u03b9\u03c3\u03b1\u03b3\u03ac\u03b3\u03b5\u03c4\u03ad \u03c4\u03bf\u03bd \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03c3\u03c5\u03bd\u03b4\u03b5\u03b8\u03b5\u03af\u03c4\u03b5 \u03c3\u03c4\u03bf Seerr."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You signed in to Jellyfin with Quick Connect, so we don't have your password. Please enter it to sign in to Seerr."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iniciaste sesi\u00f3n en Jellyfin con Quick Connect, por lo que no tenemos tu contrase\u00f1a. Introd\u00facela para iniciar sesi\u00f3n en Seerr."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kirjauduit Jellyfiniin Quick Connectilla, joten meill\u00e4 ei ole salasanaasi. Anna se kirjautuaksesi Seerriin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous vous \u00eates connect\u00e9 \u00e0 Jellyfin avec Quick Connect, nous n'avons donc pas votre mot de passe. Veuillez le saisir pour vous connecter \u00e0 Seerr."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prijavili ste se na Jellyfin putem Quick Connect, pa nemamo va\u0161u lozinku. Unesite je za prijavu na Seerr."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Connecttel jelentkezt\u00e9l be a Jellyfinbe, ez\u00e9rt nincs meg a jelszavad. Add meg a Seerr-be val\u00f3 bejelentkez\u00e9shez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai effettuato l'accesso a Jellyfin con Quick Connect, quindi non abbiamo la tua password. Inseriscila per accedere a Seerr."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Connect \u3067 Jellyfin \u306b\u30b5\u30a4\u30f3\u30a4\u30f3\u3057\u305f\u305f\u3081\u3001\u30d1\u30b9\u30ef\u30fc\u30c9\u304c\u4fdd\u5b58\u3055\u308c\u3066\u3044\u307e\u305b\u3093\u3002Seerr \u306b\u30b5\u30a4\u30f3\u30a4\u30f3\u3059\u308b\u306b\u306f\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Connect\ub85c Jellyfin\uc5d0 \ub85c\uadf8\uc778\ud558\uc168\uae30 \ub54c\ubb38\uc5d0 \ube44\ubc00\ubc88\ud638\uac00 \uc800\uc7a5\ub418\uc9c0 \uc54a\uc558\uc2b5\ub2c8\ub2e4. Seerr\uc5d0 \ub85c\uadf8\uc778\ud558\ub824\uba74 \ube44\ubc00\ubc88\ud638\ub97c \uc785\ub825\ud558\uc138\uc694."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du logget p\u00e5 Jellyfin med Quick Connect, s\u00e5 vi har ikke passordet ditt. Skriv det inn for \u00e5 logge p\u00e5 Seerr."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je bent bij Jellyfin aangemeld met Quick Connect, dus we hebben je wachtwoord niet. Voer het in om je bij Seerr aan te melden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zalogowa\u0142e\u015b si\u0119 do Jellyfin przez Quick Connect, wi\u0119c nie mamy Twojego has\u0142a. Wprowad\u017a je, aby zalogowa\u0107 si\u0119 do Seerr."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voc\u00ea entrou no Jellyfin com Quick Connect, ent\u00e3o n\u00e3o temos sua senha. Digite-a para entrar no Seerr."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iniciou sess\u00e3o no Jellyfin com Quick Connect, por isso n\u00e3o temos a sua palavra-passe. Introduza-a para iniciar sess\u00e3o no Seerr."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V-a\u021bi autentificat \u00een Jellyfin cu Quick Connect, a\u0219a c\u0103 nu avem parola dvs. Introduce\u021bi-o pentru a v\u0103 autentifica \u00een Seerr."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0412\u044b \u0432\u043e\u0448\u043b\u0438 \u0432 Jellyfin \u0447\u0435\u0440\u0435\u0437 Quick Connect, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u0443 \u043d\u0430\u0441 \u043d\u0435\u0442 \u0432\u0430\u0448\u0435\u0433\u043e \u043f\u0430\u0440\u043e\u043b\u044f. \u0412\u0432\u0435\u0434\u0438\u0442\u0435 \u0435\u0433\u043e \u0434\u043b\u044f \u0432\u0445\u043e\u0434\u0430 \u0432 Seerr."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do Jellyfin ste sa prihl\u00e1sili cez Quick Connect, preto nem\u00e1me va\u0161e heslo. Zadajte ho na prihl\u00e1senie do Seerr."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du loggade in p\u00e5 Jellyfin med Quick Connect, s\u00e5 vi har inte ditt l\u00f6senord. Ange det f\u00f6r att logga in p\u00e5 Seerr."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jellyfin'e Quick Connect ile giri\u015f yapt\u0131n\u0131z, bu y\u00fczden parolan\u0131z bizde yok. Seerr'e giri\u015f yapmak i\u00e7in l\u00fctfen parolan\u0131z\u0131 girin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0412\u0438 \u0432\u0432\u0456\u0439\u0448\u043b\u0438 \u0432 Jellyfin \u0447\u0435\u0440\u0435\u0437 Quick Connect, \u0442\u043e\u043c\u0443 \u0443 \u043d\u0430\u0441 \u043d\u0435\u043c\u0430\u0454 \u0432\u0430\u0448\u043e\u0433\u043e \u043f\u0430\u0440\u043e\u043b\u044f. \u0412\u0432\u0435\u0434\u0456\u0442\u044c \u0439\u043e\u0433\u043e, \u0449\u043e\u0431 \u0443\u0432\u0456\u0439\u0442\u0438 \u0432 Seerr."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u4f60\u901a\u8fc7 Quick Connect \u767b\u5f55\u4e86 Jellyfin,\u56e0\u6b64\u6211\u4eec\u6ca1\u6709\u4f60\u7684\u5bc6\u7801\u3002\u8bf7\u8f93\u5165\u5bc6\u7801\u4ee5\u767b\u5f55 Seerr\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u4f60\u900f\u904e Quick Connect \u767b\u5165\u4e86 Jellyfin,\u56e0\u6b64\u6211\u5011\u6c92\u6709\u4f60\u7684\u5bc6\u78bc\u3002\u8acb\u8f38\u5165\u5bc6\u78bc\u4ee5\u767b\u5165 Seerr\u3002"
          }
        }
      }
    },

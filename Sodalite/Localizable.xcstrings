    "settings.playback.subtitle.size.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "M\u011b\u0159\u00edtko p\u00edsma textov\u00fdch titulk\u016f."

    "settings.playback.subtitle.background.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jak titulky kontrastuj\u00ed s obrazem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvordan underteksterne kontrasterer mod billedet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie sich Untertitel vom Bild abheben."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a0\u03ce\u03c2 \u03be\u03b5\u03c7\u03c9\u03c1\u03af\u03b6\u03bf\u03c5\u03bd \u03bf\u03b9 \u03c5\u03c0\u03cc\u03c4\u03b9\u03c4\u03bb\u03bf\u03b9 \u03b1\u03c0\u03cc \u03c4\u03b7\u03bd \u03b5\u03b9\u03ba\u03cc\u03bd\u03b1."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How subtitles read against the picture."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C\u00f3mo se distinguen los subt\u00edtulos de la imagen."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Miten tekstitys erottuu kuvasta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comment les sous-titres se d\u00e9tachent de l'image."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kako se titlovi isti\u010du na slici."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A felirat olvashat\u00f3s\u00e1ga a k\u00e9ppel szemben."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Come i sottotitoli risaltano sull'immagine."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5b57\u5e55\u306e\u6620\u50cf\u3068\u306e\u898b\u3048\u65b9\u3067\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc790\ub9c9\uc774 \uc601\uc0c1\uacfc \uc5b4\ub5bb\uac8c \ub300\ube44\ub418\ub294\uc9c0."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvordan tekstene leses mot bildet."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoe ondertitels afsteken tegen het beeld."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jak napisy odcinaj\u0105 si\u0119 od obrazu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Como as legendas se destacam da imagem."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Como as legendas se destacam da imagem."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cum se eviden\u021biaz\u0103 subtitr\u0103rile pe imagine."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041a\u0430\u043a \u0441\u0443\u0431\u0442\u0438\u0442\u0440\u044b \u0432\u044b\u0434\u0435\u043b\u044f\u044e\u0442\u0441\u044f \u043d\u0430 \u0444\u043e\u043d\u0435 \u0432\u0438\u0434\u0435\u043e."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako titulky kontrastuj\u00fa s obrazom."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hur undertexter syns mot bilden."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Altyaz\u0131lar\u0131n g\u00f6r\u00fcnt\u00fc \u00fczerinde nas\u0131l okundu\u011fu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u042f\u043a \u0441\u0443\u0431\u0442\u0438\u0442\u0440\u0438 \u0432\u0438\u0434\u0456\u043b\u044f\u044e\u0442\u044c\u0441\u044f \u043d\u0430 \u0442\u043b\u0456 \u0432\u0456\u0434\u0435\u043e."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5b57\u5e55\u4e0e\u753b\u9762\u7684\u5bf9\u6bd4\u65b9\u5f0f\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {

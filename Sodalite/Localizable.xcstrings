    "settings.profile.launch.default.detail" : {
      "comment" : "Explanation under 'Use default profile' option",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P\u0159esko\u010d\u00ed v\u00fdb\u011br a automaticky p\u0159ihl\u00e1s\u00ed v\u00fdchoz\u00ed profil."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spring v\u00e6lgeren over og log ind som standardprofilen automatisk."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Auswahl \u00fcberspringen und direkt mit dem Standardprofil anmelden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a0\u03b1\u03c1\u03b1\u03ba\u03ac\u03bc\u03c0\u03c4\u03b5\u03b9 \u03c4\u03b7\u03bd \u03b5\u03c0\u03b9\u03bb\u03bf\u03b3\u03ae \u03ba\u03b1\u03b9 \u03c3\u03c5\u03bd\u03b4\u03ad\u03b5\u03c4\u03b1\u03b9 \u03b1\u03c5\u03c4\u03cc\u03bc\u03b1\u03c4\u03b1 \u03bc\u03b5 \u03c4\u03bf \u03c0\u03c1\u03bf\u03b5\u03c0\u03b9\u03bb\u03b5\u03b3\u03bc\u03ad\u03bd\u03bf \u03c0\u03c1\u03bf\u03c6\u03af\u03bb."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skip the picker and sign in as the default profile automatically."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omite la selecci\u00f3n y accede autom\u00e1ticamente con el perfil predeterminado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ohittaa valitsimen ja kirjautuu sis\u00e4\u00e4n oletusprofiililla automaattisesti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ignorer le s\u00e9lecteur et se connecter automatiquement avec le profil par d\u00e9faut."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preska\u010de odabir i automatski se prijavljuje kao zadani profil."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kihagyja a v\u00e1laszt\u00f3t \u00e9s automatikusan bejelentkezik az alap\u00e9rtelmezett profillal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salta il selettore ed effettua l'accesso automaticamente con il profilo predefinito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30d4\u30c3\u30ab\u30fc\u3092\u30b9\u30ad\u30c3\u30d7\u3057\u3066\u3001\u30c7\u30d5\u30a9\u30eb\u30c8\u306e\u30d7\u30ed\u30d5\u30a1\u30a4\u30eb\u3067\u81ea\u52d5\u7684\u306b\u30b5\u30a4\u30f3\u30a4\u30f3\u3057\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc120\ud0dd\uae30\ub97c \uac74\ub108\ub6f0\uace0 \uae30\ubcf8 \ud504\ub85c\ud544\ub85c \uc790\ub3d9 \ub85c\uadf8\uc778\ud569\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",

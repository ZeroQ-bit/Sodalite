    "support.pending" : {
      "comment" : "Status banner when a purchase is pending parental approval or SCA",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u010cek\u00e1 se na schv\u00e1len\u00ed. N\u00e1kup bude dokon\u010den po schv\u00e1len\u00ed."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afventer godkendelse. K\u00f8bet afsluttes, n\u00e5r det er godkendt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warten auf Freigabe. Der Kauf wird abgeschlossen, sobald er genehmigt ist."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0391\u03bd\u03b1\u03bc\u03bf\u03bd\u03ae \u03b3\u03b9\u03b1 \u03ad\u03b3\u03ba\u03c1\u03b9\u03c3\u03b7. \u0397 \u03b1\u03b3\u03bf\u03c1\u03ac \u03b8\u03b1 \u03bf\u03bb\u03bf\u03ba\u03bb\u03b7\u03c1\u03c9\u03b8\u03b5\u03af \u03bc\u03cc\u03bb\u03b9\u03c2 \u03b5\u03b3\u03ba\u03c1\u03b9\u03b8\u03b5\u03af."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Waiting for approval. The purchase will complete once approved."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperando aprobaci\u00f3n. La compra se completar\u00e1 una vez aprobada."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odotetaan hyv\u00e4ksynt\u00e4\u00e4. Osto viimeistell\u00e4\u00e4n, kun se on hyv\u00e4ksytty."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En attente d'approbation. L'achat sera finalis\u00e9 une fois approuv\u00e9."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u010ceka se odobrenje. Kupnja \u0107e biti dovr\u0161ena nakon odobrenja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "J\u00f3v\u00e1hagy\u00e1sra v\u00e1rva. A v\u00e1s\u00e1rl\u00e1s j\u00f3v\u00e1hagy\u00e1s ut\u00e1n fejez\u0151dik be."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In attesa di approvazione. L'acquisto sar\u00e0 completato una volta approvato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u627f\u8a8d\u5f85\u3061\u3067\u3059\u3002\u627f\u8a8d\u5f8c\u3001\u8cfc\u5165\u304c\u5b8c\u4e86\u3057\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc2b9\uc778 \ub300\uae30 \uc911. \uc2b9\uc778\ub418\uba74 \uad6c\ub9e4\uac00 \uc644\ub8cc\ub429\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Venter p\u00e5 godkjenning. Kj\u00f8pet fullf\u00f8res n\u00e5r det er godkjent."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wachten op goedkeuring. De aankoop wordt voltooid na goedkeuring."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oczekiwanie na zatwierdzenie. Zakup zostanie zako\u0144czony po zatwierdzeniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aguardando aprova\u00e7\u00e3o. A compra ser\u00e1 conclu\u00edda ap\u00f3s a aprova\u00e7\u00e3o."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A aguardar aprova\u00e7\u00e3o. A compra ser\u00e1 conclu\u00edda ap\u00f3s a aprova\u00e7\u00e3o."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se a\u0219teapt\u0103 aprobarea. Achizi\u021bia se va finaliza dup\u0103 aprobare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041e\u0436\u0438\u0434\u0430\u043d\u0438\u0435 \u043f\u043e\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043d\u0438\u044f. \u041f\u043e\u043a\u0443\u043f\u043a\u0430 \u0431\u0443\u0434\u0435\u0442 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043d\u0430 \u043f\u043e\u0441\u043b\u0435 \u043f\u043e\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043d\u0438\u044f."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u010cak\u00e1 sa na schv\u00e1lenie. N\u00e1kup sa dokon\u010d\u00ed po schv\u00e1len\u00ed."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V\u00e4ntar p\u00e5 godk\u00e4nnande. K\u00f6pet slutf\u00f6rs n\u00e4r det \u00e4r godk\u00e4nt."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Onay bekleniyor. Sat\u0131n alma onayland\u0131\u011f\u0131nda tamamlanacak."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041e\u0447\u0456\u043a\u0443\u0432\u0430\u043d\u043d\u044f \u0441\u0445\u0432\u0430\u043b\u0435\u043d\u043d\u044f. \u041f\u043e\u043a\u0443\u043f\u043a\u0443 \u0431\u0443\u0434\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043d\u043e \u043f\u0456\u0441\u043b\u044f \u0441\u0445\u0432\u0430\u043b\u0435\u043d\u043d\u044f."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u7b49\u5f85\u6279\u51c6\u3002\u6279\u51c6\u540e\u8d2d\u4e70\u5c06\u5b8c\u6210\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u7b49\u5f85\u6279\u51c6\u3002\u6279\u51c6\u5f8c\u8cfc\u8cb7\u5c07\u5b8c\u6210\u3002"
          }
        }
      }
    },

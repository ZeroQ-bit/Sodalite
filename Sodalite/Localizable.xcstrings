    "settings.profile.launch.picker.detail" : {
      "comment" : "Explanation under 'Show picker' option",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P\u0159i ka\u017ed\u00e9m spu\u0161t\u011bn\u00ed aplikace vyberte, kdo se d\u00edv\u00e1."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V\u00e6lg hvem der ser hver gang appen \u00e5bnes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bei jedem App-Start ausw\u00e4hlen, wer gerade schaut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0395\u03c0\u03b9\u03bb\u03ad\u03be\u03c4\u03b5 \u03c0\u03bf\u03b9\u03bf\u03c2 \u03c0\u03b1\u03c1\u03b1\u03ba\u03bf\u03bb\u03bf\u03c5\u03b8\u03b5\u03af \u03ba\u03ac\u03b8\u03b5 \u03c6\u03bf\u03c1\u03ac \u03c0\u03bf\u03c5 \u03b1\u03bd\u03bf\u03af\u03b3\u03b5\u03b9 \u03b7 \u03b5\u03c6\u03b1\u03c1\u03bc\u03bf\u03b3\u03ae."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pick who's watching every time the app opens."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige qui\u00e9n est\u00e1 viendo cada vez que se abre la app."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valitse kuka katselee aina, kun sovellus avataan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez qui regarde \u00e0 chaque ouverture de l'app."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odaberite tko gleda svaki put kad se aplikacija otvori."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V\u00e1laszd ki, ki n\u00e9zi, valah\u00e1nyszor megny\u00edlik az alkalmaz\u00e1s."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli chi sta guardando ogni volta che l'app viene aperta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u30a2\u30d7\u30ea\u3092\u958b\u304f\u305f\u3073\u306b\u8996\u8074\u3059\u308b\u4eba\u3092\u9078\u629e\u3057\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc571\uc744 \uc5f4 \ub54c\ub9c8\ub2e4 \uc2dc\uccad\ud560 \uc0ac\ub78c\uc744 \uc120\ud0dd\ud569\ub2c8\ub2e4."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velg hvem som ser p\u00e5 hver gang appen \u00e5pnes."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kies wie er kijkt telkens wanneer de app wordt geopend."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybierz kto ogl\u0105da za ka\u017cdym razem gdy aplikacja si\u0119 otwiera."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha quem est\u00e1 assistindo sempre que o app abrir."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha quem est\u00e1 a ver sempre que a app abrir."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alege cine se uit\u0103 de fiecare dat\u0103 c\u00e2nd se deschide aplica\u021bia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0412\u044b\u0431\u0438\u0440\u0430\u0439\u0442\u0435, \u043a\u0442\u043e \u0441\u043c\u043e\u0442\u0440\u0438\u0442, \u043f\u0440\u0438 \u043a\u0430\u0436\u0434\u043e\u043c \u0437\u0430\u043f\u0443\u0441\u043a\u0435 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte, kto sa pozer\u00e1 pri ka\u017edom spusten\u00ed aplik\u00e1cie."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V\u00e4lj vem som tittar varje g\u00e5ng appen \u00f6ppnas."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uygulama her a\u00e7\u0131ld\u0131\u011f\u0131nda kimin izledi\u011fini se\u00e7."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u0412\u0438\u0431\u0438\u0440\u0430\u0439\u0442\u0435, \u0445\u0442\u043e \u0434\u0438\u0432\u0438\u0442\u044c\u0441\u044f, \u0449\u043e\u0440\u0430\u0437\u0443 \u043f\u0456\u0434 \u0447\u0430\u0441 \u0432\u0456\u0434\u043a\u0440\u0438\u0442\u0442\u044f \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u043d\u043a\u0443."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u6bcf\u6b21\u6253\u5f00\u5e94\u7528\u65f6\u9009\u62e9\u8c01\u5728\u89c2\u770b\u3002"
          }
        },
        "zh-Hant" : {

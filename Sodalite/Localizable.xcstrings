    "catalog.empty.noServer.description" : {
      "comment" : "Instruction text when Seerr not configured",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nastavte Seerr v Nastaven\u00ed, abyste mohli proch\u00e1zet a \u017e\u00e1dat o nov\u00e9 filmy a seri\u00e1ly."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konfigurer Seerr i Indstillinger for at gennemse og anmode om nye film og serier."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Richte Seerr in den Einstellungen ein, um neue Filme und Serien zu entdecken und anzufordern."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u03a1\u03c5\u03b8\u03bc\u03af\u03c3\u03c4\u03b5 \u03c4\u03bf Seerr \u03c3\u03c4\u03b9\u03c2 \u03a1\u03c5\u03b8\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03c0\u03b5\u03c1\u03b9\u03b7\u03b3\u03b7\u03b8\u03b5\u03af\u03c4\u03b5 \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03b6\u03b7\u03c4\u03ae\u03c3\u03b5\u03c4\u03b5 \u03bd\u03ad\u03b5\u03c2 \u03c4\u03b1\u03b9\u03bd\u03af\u03b5\u03c2 \u03ba\u03b1\u03b9 \u03c3\u03b5\u03b9\u03c1\u03ad\u03c2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set up Seerr in Settings to browse and request new movies and shows."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configura Seerr en Ajustes para explorar y solicitar nuevas pel\u00edculas y series."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "M\u00e4\u00e4rit\u00e4 Seerr asetuksissa selataksesi ja pyyt\u00e4\u00e4ksesi uusia elokuvia ja sarjoja."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configurez Seerr dans les R\u00e9glages pour parcourir et demander de nouveaux films et s\u00e9ries."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Postavite Seerr u Postavkama za pregledavanje i zahtijevanje novih filmova i serija."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u00c1ll\u00edtsd be a Seerr-t a Be\u00e1ll\u00edt\u00e1sokban \u00faj filmek \u00e9s sorozatok b\u00f6ng\u00e9sz\u00e9s\u00e9hez \u00e9s k\u00e9r\u00e9s\u00e9hez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configura Seerr nelle Impostazioni per sfogliare e richiedere nuovi film e serie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u8a2d\u5b9a\u3067 Seerr \u3092\u30bb\u30c3\u30c8\u30a2\u30c3\u30d7\u3057\u3066\u3001\u65b0\u3057\u3044\u6620\u753b\u3084\u756a\u7d44\u3092\u95b2\u89a7\u30fb\u30ea\u30af\u30a8\u30b9\u30c8\u3067\u304d\u307e\u3059\u3002"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\uc124\uc815\uc5d0\uc11c Seerr\ub97c \uad6c\uc131\ud558\uc5ec \uc0c8 \uc601\ud654\uc640 \ud504\ub85c\uadf8\ub7a8\uc744 \ud0d0\uc0c9\ud558\uace0 \uc694\uccad\ud558\uc138\uc694."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sett opp Seerr i Innstillinger for \u00e5 bla gjennom og be om nye filmer og serier."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stel Seerr in bij Instellingen om nieuwe films en series te bekijken en aan te vragen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skonfiguruj Seerr w Ustawieniach, aby przegl\u0105da\u0107 i prosi\u0107 o nowe filmy oraz seriale."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configure o Seerr em Configura\u00e7\u00f5es para navegar e solicitar novos filmes e s\u00e9ries."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configure o Seerr nas Defini\u00e7\u00f5es para explorar e pedir novos filmes e s\u00e9ries."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configureaz\u0103 Seerr \u00een Set\u0103ri pentru a r\u0103sfoi \u0219i solicita noi filme \u0219i seriale."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u0442\u0435 Seerr \u0432 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0430\u0445, \u0447\u0442\u043e\u0431\u044b \u043f\u0440\u043e\u0441\u043c\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044c \u0438 \u0437\u0430\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0442\u044c \u043d\u043e\u0432\u044b\u0435 \u0444\u0438\u043b\u044c\u043c\u044b \u0438 \u0441\u0435\u0440\u0438\u0430\u043b\u044b."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nastavte Seerr v Nastaveniach, aby ste mohli prehliada\u0165 a \u017eiada\u0165 o nov\u00e9 filmy a seri\u00e1ly."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konfigurera Seerr i Inst\u00e4llningar f\u00f6r att bl\u00e4ddra bland och beg\u00e4ra nya filmer och serier."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeni filmlere ve dizilere g\u00f6z atmak ve istekte bulunmak i\u00e7in Ayarlar'da Seerr'i kurun."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u041d\u0430\u043b\u0430\u0448\u0442\u0443\u0439\u0442\u0435 Seerr \u0443 \u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430\u0445, \u0449\u043e\u0431 \u043f\u0435\u0440\u0435\u0433\u043b\u044f\u0434\u0430\u0442\u0438 \u0442\u0430 \u0437\u0430\u043f\u0438\u0442\u0443\u0432\u0430\u0442\u0438 \u043d\u043e\u0432\u0456 \u0444\u0456\u043b\u044c\u043c\u0438 \u0439 \u0441\u0435\u0440\u0456\u0430\u043b\u0438."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5728\u8bbe\u7f6e\u4e2d\u914d\u7f6e Seerr,\u4ee5\u4fbf\u6d4f\u89c8\u5e76\u8bf7\u6c42\u65b0\u7684\u7535\u5f71\u548c\u5267\u96c6\u3002"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\u5728\u300c\u8a2d\u5b9a\u300d\u4e2d\u8a2d\u5b9a Seerr,\u4ee5\u700f\u89bd\u4e26\u8acb\u6c42\u65b0\u7684\u96fb\u5f71\u8207\u5f71\u96c6\u3002"
          }
        }
      }
    },
